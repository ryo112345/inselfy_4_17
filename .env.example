# このファイルを .env にコピーして実値を設定する（.env は gitignore 済み・コミット禁止）。
#   cp .env.example .env
# 実値の追加が必要になったら、このファイルにもキーとダミー値を追記すること。

# --- Database (docker compose のローカル PostgreSQL) ---
DB_USER=user
DB_PASSWORD=password
DB_NAME=inselfy
DB_PORT=5434
DB_HOST=localhost
DB_SSLMODE=disable
DATABASE_URL=postgres://user:password@localhost:5434/inselfy?sslmode=disable

# --- API ---
API_PORT=8081
APP_URL=http://localhost:5173
JWT_SECRET=dev-secret-change-me

# --- Google OAuth ---
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# --- LINE (未使用なら空でよい) ---
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_REDIRECT_URI=http://localhost:5173/auth/callback

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- Admin ---
INITIAL_ADMIN_EMAIL=admin@example.com
ADMIN_API_KEY=

# --- Storage ("local" or "r2") ---
STORAGE_BACKEND=local
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# --- Frontend ---
INTERNAL_API_URL=http://localhost:8081
