-- 04-4. ブランドストラテジスト（デザインファーム特有）
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
  required_qualifications, preferred_qualifications,
  work_location, work_location_change_scope, job_description_change_scope,
  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd0040000-0000-0000-0000-000000000004',
  'b0000000-0000-0000-0000-000000000004',
  'c0004000-0000-0000-0000-000000000002',
  'b1000000-0000-0000-0000-000000000004',
  'open',
  'ブランドストラテジスト｜企業の本質を見抜きブランドに命を吹き込む',
  'その他',
  '正社員',
  '1名',
  'クライアント企業のブランド戦略の策定を担当します。企業のビジョン・ミッション・バリューの言語化から、ブランドアーキテクチャの設計、ブランドガイドラインの策定、ネーミング・タグライン開発まで、ブランディングの上流工程を一手に担います。市場調査、競合分析、ステークホルダーインタビューを通じてブランドのポジショニングを定義し、VI（ビジュアルアイデンティティ）デザインチームと連携してブランドの世界観を具現化します。',
  '企業の本質を見抜き、言葉とデザインで表現するという知的刺激に満ちた仕事です。スタートアップのブランド立ち上げから老舗企業のリブランディングまで、多様なプロジェクトに携われます。戦略からビジュアルまでを一貫して手がけるノヴァクリエイティブだからこそ、ブランド戦略が実際にデザインとして形になる過程を最初から最後まで見届けられます。大阪を拠点にしながら全国の企業と仕事ができる環境です。',
  'ブランド戦略は抽象的な概念を扱うため、クライアントの経営層と対等に議論できる知識と表現力が必要です。定性的な調査結果を論理的に構造化し、説得力のある戦略に落とし込む能力が求められます。また、デザインチームが戦略を正しく解釈してビジュアルに変換できるよう、的確なブリーフィングを行うコミュニケーション力も不可欠です。',
  'ブランディングチーム5名で、戦略担当とVI担当が密に連携しています。コピーライターも在籍し、言葉とビジュアルの両面からブランドを作り上げるチームです。',
  'ブランド戦略の策定スキル、市場調査・競合分析力、クライアントの経営層との折衝経験が身につきます。',
  '[]'::jsonb,
  '["ブランド戦略","ブランディング","市場調査","VI設計","コピーライティング","ストラテジー"]'::jsonb,
  'ブランディング、マーケティング、広告いずれかの領域で3年以上の実務経験。クライアントへの戦略提案経験。',
  'ブランドコンサルティングファームでの経験。VIデザインの知識。コピーライティングのスキル。MBA等のビジネス学位。',
  '大阪府大阪市',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  'フレックスタイム制（コアタイム11:00-16:00）標準労働時間8時間',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇',
  500, 850,
  '月給42万円〜71万円（固定残業代30時間分を含む）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙',
  E'デザインツール・ソフトウェア費用全額負担\n書籍購入費月1万円補助\nカンファレンス・セミナー参加費補助\n副業OK\n交通費全額支給',
  '出社（クライアント訪問あり）',
  '書類選考 → ポートフォリオ・実績レビュー → 戦略課題プレゼンテーション → 最終面接 → 内定',
  now()
) ON CONFLICT DO NOTHING;

-- ============================================================
-- 企業05: フィンクロス（フィンテック）
-- teams: バックエンドエンジニア=c0005..1, コンプライアンス=c0005..2, ビジネス開発=c0005..3
-- ============================================================

-- 05-1. エンジニア
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
  required_qualifications, preferred_qualifications,
  work_location, work_location_change_scope, job_description_change_scope,
  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd0050000-0000-0000-0000-000000000001',
  'b0000000-0000-0000-0000-000000000005',
  'c0005000-0000-0000-0000-000000000001',
  'b1000000-0000-0000-0000-000000000005',
  'open',
  'バックエンドエンジニア｜決済基盤を支えるセキュアなシステム設計',
  'エンジニア',
  '正社員',
  '2名',
  'フィンクロスのBtoB決済プラットフォームのバックエンド開発を担当します。決済処理のコアロジック実装、銀行APIとの連携、トランザクション管理、不正検知システムの構築が主な業務です。金融グレードの可用性（99.99%）とセキュリティ要件を満たすシステム設計が求められます。PCI DSS準拠のインフラ上で、Go言語を用いたマイクロサービスアーキテクチャで開発を進めています。月間数億円規模の決済を処理するシステムの信頼性を担保する重要なポジションです。',
  '金融機関レベルのセキュリティとパフォーマンスが求められるシステム開発に携わることで、エンジニアとしてのスキルが飛躍的に向上します。決済という社会インフラを支える責任感と、自分が設計したシステムで数億円のお金が動くスケール感は大きなやりがいです。フィンテック領域の専門性は市場価値が非常に高く、キャリアの幅が大きく広がります。',
  '金融システム特有の厳格なセキュリティ要件とコンプライアンス対応が常に求められます。障害が直接的な金銭的損害につながるため、テストやコードレビューの基準が一般的なWebサービスより格段に高いです。また、銀行ごとに異なるAPI仕様への対応や、資金決済法の改正への迅速な対応も必要です。',
  'バックエンドエンジニアチーム8名で、決済コア、連携API、不正検知の3つのサブチームに分かれています。元銀行システムエンジニアやセキュリティスペシャリストも在籍しています。',
  '金融システムの設計・開発スキル、セキュアコーディングの実践力、高可用性システムの構築・運用経験が身につきます。',
  '[]'::jsonb,
  '["Go","PostgreSQL","AWS","決済システム","セキュリティ","マイクロサービス","PCI DSS"]'::jsonb,
  'バックエンド開発経験3年以上。Go、Java等でのシステム開発経験。RDBMSの設計・運用経験。',
  '金融システムの開発経験。PCI DSS準拠環境での開発経験。セキュリティに関する資格（情報処理安全確保支援士等）。API設計の経験。',
  '東京都中央区（リモート併用可）',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  'フレックスタイム制（コアタイム10:00-15:00）標準労働時間8時間',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇',
  600, 1100,
  '月給50万円〜92万円（固定残業代40時間分を含む）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙（喫煙専用室あり）',
  E'ストックオプション制度\n資格取得支援（受験費用全額負担）\n書籍購入費月2万円補助\nリモートワーク手当月3万円\n副業OK（届出制）',
  'リモート併用（週2出社推奨）',
  '書類選考 → 技術面接（セキュリティ設計ディスカッション含む） → コーディングテスト → 最終面接 → 内定',
  now()
) ON CONFLICT DO NOTHING;

-- 05-2. セールス
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
