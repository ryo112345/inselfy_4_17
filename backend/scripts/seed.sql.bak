  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd0190000-0000-0000-0000-000000000002',
  'b0000000-0000-0000-0000-000000000019',
  'c0019000-0000-0000-0000-000000000002',
  'b1000000-0000-0000-0000-000000000019',
  'open',
  'プロダクトマネージャー｜ケアマネジャーの業務効率化を実現するSaaS企画',
  'PM',
  '正社員',
  '1名',
  'ケアマネジャー向け業務支援SaaSのプロダクトマネジメントを担当していただきます。ケアマネジャーへのユーザーインタビューや施設訪問を通じた課題発見、プロダクトロードマップの策定、機能要件の定義、開発チームとの連携によるスプリント管理が主な業務です。ケアプラン作成の半自動化、サービス事業所との連絡調整のデジタル化、介護報酬シミュレーション機能の企画など、ケアマネジャーの膨大な事務作業を減らすためのプロダクトを設計します。競合分析や市場調査に基づく事業戦略の立案にも携わります。',
  'ケアマネジャーは日本に約18万人が活動しており、その業務負担の軽減は社会的な課題です。プロダクトの改善が数万人の働き方を変え得るスケールの大きなテーマに取り組めます。名古屋には介護事業所が集中しており、ユーザーとの距離が近いフィードバックループを構築できるのが強みです。介護保険制度の知識が自然と身につき、社会保障分野のドメインエキスパートとしてのキャリアも築けます。',
  '介護保険制度は複雑で、ケアマネジャーの業務フローを深く理解するまでにはドメイン知識の習得が不可欠です。利用者（高齢者やその家族）の状況は一人一人異なり、画一的なソリューションでは対応しきれないケースも多々あります。介護報酬の計算ロジックは自治体ごとの加算項目があり、網羅的な対応が必要です。制度の改定に先んじてプロダクトを進化させる先見性が求められます。',
  'ケアマネ支援チーム3名で、プロダクト企画・ドメインエキスパート・カスタマーサポートの各役割を担当。介護福祉士やケアマネ経験者がドメイン知識を提供し、プロダクト企画をサポートします。',
  '介護SaaSのプロダクトマネジメントスキル、介護保険制度のドメイン知識、ユーザーリサーチの実践力、BtoBtoC型プロダクトの設計力が身につきます。',
  '[]'::jsonb,
  '["プロダクトマネジメント","介護","SaaS","ケアプラン","UXリサーチ","BtoB"]'::jsonb,
  'プロダクトマネジメントまたは事業企画の実務経験3年以上。ユーザーインタビューに基づく機能企画の経験。開発チームとの協業経験。',
  '介護・福祉業界での実務経験。SaaS企業でのPM経験。ケアマネジャー資格または介護福祉士資格。BtoB SaaSのグロース経験。',
  '愛知県名古屋市中区（週2日リモート可）',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  '9:00〜18:00（実働8時間）',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇、介護休暇（法定以上）',
  500, 800,
  '月給42万円〜67万円（固定残業代30時間分を含む）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙（喫煙専用室あり）',
  E'介護関連資格取得支援\n施設見学・研修制度\n書籍購入費補助\n副業OK',
  '週2日リモート可',
  '書類選考 → 面接（2回） → 最終面接 → 内定',
  now()
) ON CONFLICT DO NOTHING;

-- 19-3. セールス
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
  required_qualifications, preferred_qualifications,
  work_location, work_location_change_scope, job_description_change_scope,
  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd0190000-0000-0000-0000-000000000003',
  'b0000000-0000-0000-0000-000000000019',
  'c0019000-0000-0000-0000-000000000003',
  'b1000000-0000-0000-0000-000000000019',
  'open',
  '法人営業｜介護DXで人手不足を解決するソリューション提案営業',
  'セールス',
  '正社員',
  '2名',
  '介護施設や自治体に対する当社プロダクトの提案営業を担当していただきます。特別養護老人ホーム、介護老人保健施設、有料老人ホーム、居宅介護支援事業所などの介護事業者に対し、業務支援プラットフォームの導入提案を行います。現場訪問によるニーズヒアリング、デモンストレーション、見積作成、契約締結、導入サポートまでの一連の営業プロセスを担当。自治体のDX推進部門への提案や、介護業界の展示会・セミナーでのリード獲得活動にも参加します。介護報酬制度や補助金に関する知識を活かした提案が差別化のポイントです。',
  '介護DXは国の施策としても推進されており、追い風の市場環境です。介護事業者の多くはまだデジタル化が進んでおらず、新規開拓の余地が大きい成長市場で営業経験を積めます。東海地方には多くの介護施設が集中しており、効率的な営業活動が可能です。営業活動を通じて介護現場の実態を深く理解でき、社会課題の解決に直接貢献している実感を得られるポジションです。',
  '介護施設の意思決定者（施設長・理事長）はIT導入に慎重なケースが多く、信頼関係の構築に時間がかかることがあります。また、介護報酬の算定構造や加算の仕組みを理解していないと適切な提案ができないため、入社後のドメイン知識習得が重要です。複数の施設を運営する法人への大口提案では、各施設の状況に合わせたカスタマイズ提案が求められるなど、ソリューション営業としての高い提案力が試されます。',
  '経営企画チームの一員として、セールス・マーケティング・カスタマーサクセスの機能を横断的にカバー。週次の営業会議で案件進捗を共有し、チームでの受注を目指しています。',
  '介護業界向けソリューション営業スキル、介護保険制度・補助金の専門知識、BtoBおよびBtoG営業力、SaaSの導入提案力が身につきます。',
  '[]'::jsonb,
  '["法人営業","介護DX","SaaS","ソリューション営業","BtoB","BtoG"]'::jsonb,
  '法人営業経験2年以上。顧客への提案営業の経験。普通自動車免許（施設訪問のため）。',
  'SaaS企業での営業経験。介護・福祉業界の知識。自治体向け営業の経験。CRMツール（Salesforce等）の活用経験。',
  '愛知県名古屋市中区（直行直帰あり）',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  '9:00〜18:00（実働8時間）',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇、介護休暇（法定以上）',
  400, 650,
  '月給33万円〜54万円（固定残業代30時間分を含む、別途インセンティブあり）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙（喫煙専用室あり）',
  E'営業インセンティブ制度\n介護関連資格取得支援\n社用車貸与\n副業OK',
  '週1日リモート可',
  '書類選考 → 面接（2回） → 最終面接 → 内定',
  now()
) ON CONFLICT DO NOTHING;

-- 19-4. 人事
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
  required_qualifications, preferred_qualifications,
  work_location, work_location_change_scope, job_description_change_scope,
  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd0190000-0000-0000-0000-000000000004',
  'b0000000-0000-0000-0000-000000000019',
  'c0019000-0000-0000-0000-000000000003',
  'b1000000-0000-0000-0000-000000000019',
  'open',
  '採用人事｜介護×テクノロジーで社会を変える仲間を集めるリクルーター',
  '人事',
  '正社員',
  '1名',
  '急成長する介護DXスタートアップの採用活動全般を担当していただきます。エンジニア・デザイナー・ビジネス職の中途採用を中心に、採用戦略の立案、求人票の作成、ダイレクトリクルーティング、面談・面接の実施、内定後のクロージング・オンボーディングまでを一貫して手がけます。採用広報として、テックブログの企画・運営、採用イベントの企画・実施、SNSでの情報発信にも携わります。また、組織拡大に伴う人事制度（評価制度、等級制度、研修制度）の設計にも参画していただきます。',
  '社会課題の解決というミッションに共感する人材を集める採用活動に、やりがいの大きいポジションです。スタートアップの急成長フェーズで採用機能をゼロから構築する経験は、人事としてのキャリアにおいて大きな資産になります。介護業界とテクノロジー業界の両方の採用市場を理解し、多様なバックグラウンドの人材を採用する力が身につきます。経営陣との距離が近く、事業戦略と連動した人事戦略の立案に関われます。',
  '介護DXという比較的ニッチな分野で、エンジニアを中心とした優秀な人材を採用するのは容易ではありません。「介護」というキーワードにネガティブなイメージを持つ候補者もおり、テクノロジーでの社会課題解決という魅力をいかに伝えるかが腕の見せどころです。名古屋拠点のためリモート採用の割合が高く、物理的に会えない候補者との関係構築にも工夫が必要です。組織の急拡大に伴う人事制度の整備も急務であり、採用と制度設計を並行して進める実行力が求められます。',
  '経営企画チームに所属し、代表直下で人事機能を担当。現在は採用を1名で担当しており、組織の成長に合わせて人事チームの拡大も見据えています。',
  'スタートアップの採用戦略立案・実行スキル、エンジニア採用のリクルーティング力、人事制度設計の知見、採用広報の企画力が身につきます。',
  '[]'::jsonb,
  '["採用","人事","ダイレクトリクルーティング","採用広報","制度設計","スタートアップ"]'::jsonb,
  '中途採用の実務経験2年以上。面接・面談の実施経験。採用媒体の運用経験。',
  'エンジニア採用の経験。スタートアップでの人事経験。人事制度の設計・運用経験。採用広報の経験。社会保険労務士資格。',
  '愛知県名古屋市中区（週2日リモート可）',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  '9:00〜18:00（実働8時間）',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇、介護休暇（法定以上）',
  400, 600,
  '月給33万円〜50万円（固定残業代30時間分を含む）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙（喫煙専用室あり）',
  E'介護関連資格取得支援\n書籍購入費補助\n研修参加費補助\n副業OK',
  '週2日リモート可',
  '書類選考 → 面接（2回） → 最終面接 → 内定',
  now()
) ON CONFLICT DO NOTHING;

-- ============================================================
-- 1a. オトノバ（音楽テック / 京都市）
-- ============================================================

-- 1a-1. サウンドエンジニア（AI音声処理）
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
  required_qualifications, preferred_qualifications,
  work_location, work_location_change_scope, job_description_change_scope,
  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd01a0000-0000-0000-0000-000000000001',
  'b0000000-0000-0000-0000-00000000001a',
  'c001a000-0000-0000-0000-000000000001',
  'b1000000-0000-0000-0000-00000000001a',
  'open',
  'AIサウンドエンジニア｜機械学習で音楽制作の未来を切り拓く音響技術者',
  'エンジニア',
  '正社員',
  '1名',
  'AI音声合成・音楽生成モデルの研究開発を担当していただきます。ボーカル音声合成エンジンの改善、楽器音色のモデリング、自動マスタリングアルゴリズムの開発、リアルタイム音声エフェクト処理の実装が主な業務です。音楽理論と信号処理の知識をベースに、深層学習モデル（Transformer、Diffusionモデル等）を活用した音楽AIの研究・実装を行います。また、DAW（Digital Audio Workstation）プラグインとしてのリアルタイム推論の最適化や、Web Audio APIを活用したブラウザベースの音楽制作ツールの開発にも携わります。京都の音楽文化と最先端のAI技術を融合させるユニークなポジションです。',
  '音楽とAIの両方に情熱を持つ方にとって理想的な環境です。最新の音楽生成AI技術を実プロダクトに落とし込む経験は、音楽テック業界でも希少な価値を持ちます。京都という文化的な環境で、伝統音楽からポップスまで幅広いジャンルの音楽に触れながら研究開発ができます。学術コミュニティとの連携も積極的で、国際学会での発表や論文執筆も奨励されています。',
  '音楽AIは生成結果の品質評価が主観的になりやすく、定量的な改善指標の設定が難しい分野です。リアルタイム処理のレイテンシ要件を満たしつつ、品質を維持するための最適化は技術的に高度な課題です。また、アーティストが求める「音楽的な表現」をAIモデルに反映させるためには、音楽制作の現場感覚を理解した上でのモデル設計が必要であり、純粋な技術力だけでなく音楽的センスも問われます。',
  'サウンドエンジニアチーム3名で、音声合成・音楽生成・音響処理の各領域を担当。DTM経験者が多く、チーム内で実際に楽曲を制作しながらプロダクトの検証を行う文化があります。',
  '音声合成・音楽生成AIの研究開発スキル、リアルタイム音声処理の実装力、C++/Python での信号処理の専門知識、音楽テック業界の知見が身につきます。',
  '[]'::jsonb,
  '["AI","音声合成","機械学習","C++","Python","DSP","音楽生成"]'::jsonb,
  '音声処理・信号処理の実務経験または研究経験2年以上。Python, C++ のいずれかでの実務経験。深層学習フレームワーク（PyTorch等）の使用経験。',
  '音楽制作（DTM）の経験。音声合成・音楽情報処理に関する論文発表経験。DAWプラグイン（VST/AU）の開発経験。Web Audio APIの使用経験。',
  '京都府京都市中京区（週2日リモート可）',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  'フレックスタイム制（コアタイム11:00-15:00）標準労働時間8時間',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇',
  500, 850,
  '月給42万円〜71万円（固定残業代30時間分を含む）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙（喫煙専用室あり）',
