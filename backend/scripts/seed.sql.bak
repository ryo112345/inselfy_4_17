-- 13-1: フルスタックエンジニア
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
  required_qualifications, preferred_qualifications,
  work_location, work_location_change_scope, job_description_change_scope,
  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd0130000-0000-0000-0000-000000000001',
  'b0000000-0000-0000-0000-000000000013',
  'c0013000-0000-0000-0000-000000000001',
  'b1000000-0000-0000-0000-000000000013',
  'open',
  'フルスタックエンジニア｜ウェアラブルデバイス連携のヘルスケアアプリを開発',
  'エンジニア',
  '正社員',
  '2名',
  'ヴィタリスが開発するスポーツ・ウェルネスプラットフォームのフルスタック開発を担当していただきます。ウェアラブルデバイス（Apple Watch / Garmin / Fitbit等）からの生体データ連携、パーソナライズされたトレーニングプログラムの自動生成、栄養管理機能、コミュニティ機能、トレーナー向け管理画面など、プラットフォームの幅広い機能を開発します。React Native でのモバイルアプリ開発と Go / PostgreSQL でのバックエンドAPI開発の両方を担当し、HealthKit / Google Fit等のヘルスケアAPIとの連携実装も行います。',
  'ヘルスケア×テクノロジーの成長市場で、人々の健康に直接貢献するプロダクトを開発できるポジションです。ウェアラブルデバイスのデータを活用したパーソナライゼーションは技術的に面白く、機械学習との連携も進めています。横浜のオフィスにはジムを併設しており、開発したアプリを自ら使いながらドッグフーディングできる環境です。スポーツ好きなメンバーが多く、ランニングクラブやヨガ部などの社内アクティビティも活発です。',
  'ウェアラブルデバイスは機種ごとにAPIの仕様やデータ形式が異なるため、統一的なデータモデルの設計が大きな技術課題です。また、ヘルスケアデータは機微な個人情報であり、厳格なデータ保護とプライバシー管理が求められます。リアルタイムの生体データ処理と長期的なトレンド分析の両方に対応するデータパイプラインの設計も重要なテーマです。',
  'エンジニアチーム5名で、モバイル2名・バックエンド2名・データエンジニア1名の構成です。全員がスポーツやフィットネスに関心が高く、プロダクトのヘビーユーザーです。',
  'ヘルスケアAPI連携の実装スキル、React Nativeでのモバイル開発力、生体データ処理の知識、パーソナライゼーション機能の設計力が身につきます。',
  '[]'::jsonb,
  '["React Native","Go","PostgreSQL","HealthKit","ウェアラブル","ヘルスケア","モバイル"]'::jsonb,
  'Webまたはモバイルアプリケーション開発経験3年以上。フロントエンド・バックエンドの両方の開発経験。',
  'React Native / Flutter等のクロスプラットフォーム開発経験。HealthKit / Google Fit APIの利用経験。ヘルスケア・フィットネス業界での開発経験。データ分析の基礎知識。',
  '神奈川県横浜市（リモート併用可）',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  'フレックスタイム制（コアタイム10:00〜15:00）標準労働時間8時間',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇',
  500, 850,
  '月給42万円〜71万円（固定残業代40時間分を含む）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙（喫煙専用室あり）',
  E'リモートワーク手当月2万円\nジム利用無料（社内ジム）\nウェルネス手当（月1万円）\n副業OK',
  'リモート併用（週2日出社）',
  '書類選考 → 技術面接 → 最終面接 → 内定',
  now()
) ON CONFLICT DO NOTHING;

-- 13-2: PM
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
  required_qualifications, preferred_qualifications,
  work_location, work_location_change_scope, job_description_change_scope,
  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd0130000-0000-0000-0000-000000000002',
  'b0000000-0000-0000-0000-000000000013',
  'c0013000-0000-0000-0000-000000000002',
  'b1000000-0000-0000-0000-000000000013',
  'open',
  'プロダクトマネージャー｜データドリブンでウェルネス体験を設計',
  'PM',
  '正社員',
  '1名',
  'スポーツ・ウェルネスプラットフォームのプロダクト戦略策定と実行を担当していただきます。一般ユーザー向けアプリ、トレーナー向け管理ツール、法人向け健康経営サービスという3つのプロダクトラインのロードマップ策定、ユーザーリサーチ、要件定義、開発チームとの連携、KPI設計・効果測定までを一貫して推進します。ウェアラブルデバイスの生体データを活用したパーソナライゼーション戦略の立案や、行動変容理論に基づいたエンゲージメント施策の設計も重要な業務です。スポーツ科学の知見をプロダクトに反映するために、社内のスポーツサイエンティストとの協業も行います。',
  'ウェルネス×テクノロジーという成長市場でPMとしてのキャリアを築けるポジションです。ユーザーの健康状態やフィットネスレベルを可視化し、行動変容を促すプロダクト設計は、PMとして非常にやりがいのあるテーマです。スポーツ科学のエビデンスに基づいたプロダクト開発は他社にはないユニークな強みであり、学際的な知識を活かせます。横浜のオフィスは自然環境に恵まれており、ランニングやウォーキングをしながらアイデアを練る文化があります。',
  'ヘルスケアデータの活用はユーザーのプライバシーに直結するため、データ利活用とプライバシー保護のバランスが常に重要なテーマです。ウェアラブルデバイスのエコシステムは変化が速く、新デバイスへの対応とプロダクト品質の維持を両立させる判断力が求められます。また、一般ユーザー・トレーナー・法人という異なるステークホルダーのニーズを調整するマルチプロダクトのPMスキルも必要です。',
  'プロダクトチーム4名で、PM1名・デザイナー1名・スポーツサイエンティスト1名・リサーチャー1名の構成です。エンジニアチームとワンチームで動いています。',
  'ヘルスケアプロダクトのPMスキル、行動変容デザインの知見、データドリブンな意思決定力、マルチプロダクトのマネジメントスキルが身につきます。',
  '[]'::jsonb,
  '["PM","ヘルスケア","ウェルネス","プロダクトマネジメント","データ分析","行動変容"]'::jsonb,
  'プロダクトマネジメントの実務経験3年以上。データに基づく意思決定の経験。ユーザーリサーチの経験。',
  'ヘルスケア・フィットネス業界での業務経験。モバイルアプリのPM経験。行動変容デザインの知識。SQLを用いたデータ分析の経験。',
  '神奈川県横浜市（リモート併用可）',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  'フレックスタイム制（コアタイム10:00〜15:00）標準労働時間8時間',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇',
  550, 900,
  '月給46万円〜75万円（固定残業代40時間分を含む）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙（喫煙専用室あり）',
  E'リモートワーク手当月2万円\nジム利用無料（社内ジム）\nウェルネス手当（月1万円）\n副業OK',
  'リモート併用（週2日出社）',
  '書類選考 → 一次面接 → ケース面接 → 最終面接 → 内定',
  now()
) ON CONFLICT DO NOTHING;

-- 13-3: セールス
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
