  headline = '植物工場の技術で、食の安定供給と地域農業の未来を切り拓く',
  description = '完全閉鎖型植物工場の設計・建設と、栽培管理AIプラットフォーム「GrowOS」の開発を行うアグリテック企業です。独自のLED光源制御技術とAI環境最適化により、露地栽培比で水使用量を95%削減しながら、レタスやハーブ類を年間を通じて安定生産しています。東北を拠点に全国12か所の植物工場を運営し、スーパーマーケットや外食チェーンへの直接供給体制を構築。海外からの技術ライセンス契約の引き合いも増加中です。',
  industry = '農業機械・アグリテック',
  location = '宮城県仙台市青葉区',
  founded_year = 2017,
