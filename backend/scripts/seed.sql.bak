  'd0170000-0000-0000-0000-000000000001',
  'b0000000-0000-0000-0000-000000000017',
  'c0017000-0000-0000-0000-000000000001',
  'b1000000-0000-0000-0000-000000000017',
  'open',
  '衛星システムエンジニア｜小型衛星コンステレーションの設計で宇宙インフラを構築',
  'エンジニア',
  '正社員',
  '1〜2名',
  '小型衛星コンステレーションの設計・開発・運用を担当していただきます。衛星のシステム設計、サブシステム間のインターフェース定義、熱解析・構造解析のレビュー、環境試験の計画・実施、軌道上での衛星運用が主な業務です。地上局との通信設計や、衛星搭載ペイロードの要件定義にも携わります。当社は地球観測データを活用した防災・農業・物流分野へのソリューション提供を目指しており、ユーザーニーズを理解した上でのシステム設計が求められます。福岡という宇宙ビジネスの新たな拠点から、日本の宇宙産業を牽引するプロジェクトに参画できます。',
  '小型衛星の設計から打ち上げ、軌道上運用までの全工程に関われる貴重な環境です。福岡市の宇宙ビジネス振興施策の支援を受けており、九州大学や地元企業との連携も活発です。衛星1機を少人数で開発するため、システム全体を俯瞰するスキルが自然と身につきます。宇宙産業の急成長に伴い、この経験は今後のキャリアにおいて非常に希少価値の高いものになります。',
  '小型衛星開発は限られた質量・電力の制約の中で最大のパフォーマンスを引き出す設計が求められ、トレードオフの判断が頻繁に発生します。また、宇宙空間という過酷な環境での動作を保証するために、地上での十分な検証が不可欠です。打ち上げスケジュールに合わせた開発マイルストーンの管理も重要で、遅延が許されないプレッシャーの中でのプロジェクト推進力が求められます。',
  '衛星開発チーム3名で、システム設計・電装設計・構造設計の各領域を担当。少人数ゆえに領域横断的な知識共有が日常的に行われます。',
  '衛星システム設計の全体知識、環境試験の計画・実施スキル、宇宙品質基準に基づく設計手法、軌道力学の実践的知識が身につきます。',
  '[]'::jsonb,
  '["衛星開発","宇宙","システム設計","組み込み","C/C++","地球観測"]'::jsonb,
  '機械工学・電気工学・航空宇宙工学のいずれかの学士以上。組み込みシステム開発または機械設計の実務経験2年以上。',
  '人工衛星やロケットの開発経験。宇宙品質基準（ECSS等）に基づく設計経験。環境試験の計画・実施経験。MATLAB/Simulinkの使用経験。',
  '福岡県福岡市博多区',
  '当面なし',
  '当面なし',
  '無期',
  '入社後6ヶ月（条件変更なし）',
  '9:00〜18:00（実働8時間）',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇',
  500, 850,
  '月給42万円〜71万円（固定残業代30時間分を含む）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙（喫煙専用室あり）',
  E'学会参加費補助\n論文発表奨励金\n引越し手当（入社時）\n副業OK',
  '原則出社（打ち上げ前後はリモート不可）',
  '書類選考 → 技術面接 → 最終面接 → 内定',
  now()
) ON CONFLICT DO NOTHING;

-- 17-2. フライトソフトウェアエンジニア
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
  required_qualifications, preferred_qualifications,
  work_location, work_location_change_scope, job_description_change_scope,
  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd0170000-0000-0000-0000-000000000002',
  'b0000000-0000-0000-0000-000000000017',
  'c0017000-0000-0000-0000-000000000002',
  'b1000000-0000-0000-0000-000000000017',
  'open',
  'フライトソフトウェアエンジニア｜衛星搭載ソフトウェアで宇宙空間の自律制御を実現',
  'エンジニア',
  '正社員',
  '1名',
  '小型衛星に搭載するフライトソフトウェアの設計・実装・検証を担当していただきます。姿勢制御システム（ADCS）のアルゴリズム実装、衛星の自律運用ソフトウェアの開発、地上局との通信プロトコル設計、搭載カメラの撮像制御ソフトの開発が主な業務です。リアルタイムOS上でのCプログラミング、ハードウェアとの連携テスト、軌道上でのソフトウェアアップデート機能の実装にも携わります。衛星の「頭脳」を作るポジションとして、ミッション成否に直結する重要な役割を担っていただきます。',
  '自分が書いたコードが宇宙空間で動くという、エンジニアにとって最もエキサイティングな経験ができます。フライトソフトウェアエンジニアは日本国内でも希少な存在であり、この経験は宇宙産業だけでなく、自動車の自動運転やロボティクスなど他の高信頼性システム分野でも高く評価されます。少人数チームのため、アーキテクチャ設計から実装・テストまで全工程に主体的に関われます。',
  'フライトソフトウェアは一度打ち上げた後のデバッグが極めて困難なため、地上での徹底的な検証が求められます。限られた計算リソース（CPU、メモリ）の中で必要な処理を実現する最適化力、放射線によるビットフリップなどの宇宙特有の障害への対策設計が必要です。また、リアルタイム性と信頼性を両立させるための設計判断は、一般的なソフトウェア開発とは異なるアプローチが求められます。',
  'フライトソフトウェアチーム3名で、姿勢制御・ミッション制御・通信系の各領域を担当。HILSを用いた統合試験を定期的に実施しています。',
  'リアルタイムOS上でのフライトソフトウェア開発スキル、姿勢制御アルゴリズムの実装力、宇宙品質のソフトウェア検証手法、HILS構築・運用の知見が身につきます。',
  '[]'::jsonb,
  '["C","C++","RTOS","組み込み","衛星","姿勢制御","宇宙"]'::jsonb,
  '組み込みソフトウェア開発経験3年以上。C/C++での実務経験。リアルタイムシステムの開発経験。',
  '人工衛星のフライトソフトウェア開発経験。RTOS（FreeRTOS, VxWorks等）の使用経験。姿勢制御アルゴリズムの知識。MATLAB/Simulinkでのシミュレーション経験。',
  '福岡県福岡市博多区',
  '当面なし',
  '当面なし',
  '無期',
  '入社後6ヶ月（条件変更なし）',
  '9:00〜18:00（実働8時間）',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇',
  550, 900,
  '月給46万円〜75万円（固定残業代30時間分を含む）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙（喫煙専用室あり）',
  E'学会参加費補助\n論文発表奨励金\n引越し手当（入社時）\n副業OK',
  '原則出社（一部リモート相談可）',
  '書類選考 → 技術面接（コーディングテスト含む） → 最終面接 → 内定',
  now()
) ON CONFLICT DO NOTHING;

-- 17-3. 事業開発
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
  required_qualifications, preferred_qualifications,
  work_location, work_location_change_scope, job_description_change_scope,
  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd0170000-0000-0000-0000-000000000003',
  'b0000000-0000-0000-0000-000000000017',
  'c0017000-0000-0000-0000-000000000003',
  'b1000000-0000-0000-0000-000000000017',
  'open',
  '事業開発｜衛星データ×社会課題で新規事業を創出するビジネスプロデューサー',
  '企画',
  '正社員',
  '1名',
  '衛星データを活用した新規事業の企画・開発を担当していただきます。防災、農業、物流、都市計画など多様な分野の顧客や自治体と連携し、衛星データの活用ニーズの発掘から、ソリューションの企画立案、概念実証（PoC）の推進、事業化までを一貫して手がけます。官公庁の公募プロジェクトへの提案や、JAXA・内閣府等の宇宙政策関連の補助金申請も重要な業務です。国内外の宇宙ビジネスカンファレンスへの参加や、海外の衛星データプロバイダーとのパートナーシップ構築にも携わっていただきます。',
  '宇宙ビジネスという急成長市場で、衛星データを起点にした事業開発を経験できます。防災から農業まで、社会的インパクトの大きい課題解決に衛星データという新しいツールで挑める点が大きな魅力です。福岡を拠点に九州の自治体や一次産業との連携が豊富で、都市部のスタートアップとは異なる地に足のついた事業開発ができます。宇宙関連の国際カンファレンスにも定期的に参加でき、グローバルなネットワークを構築できます。',
  '衛星データビジネスは技術的な可能性と市場ニーズのマッチングが難しく、顧客が何を求めているかを深く理解した上で、衛星データで何ができるかを分かりやすく伝える翻訳力が求められます。官公庁案件は提案書の作成や審査対応に相当の時間がかかり、採択されない場合もあります。不確実性の高い環境で粘り強く事業の種を育てていく忍耐力と情熱が問われるポジションです。',
  '事業開発チーム3名で、防災・農業・物流の各領域を担当。エンジニアチームと密に連携し、技術的なフィジビリティを確認しながら事業開発を進めています。',
  '宇宙ビジネスの事業開発スキル、官公庁向け提案・補助金申請のノウハウ、衛星データ活用の知見、BtoBおよびBtoG営業力が身につきます。',
  '[]'::jsonb,
  '["事業開発","衛星データ","宇宙ビジネス","BtoG","防災","農業DX"]'::jsonb,
  '新規事業開発または法人営業の実務経験3年以上。提案書・企画書の作成経験。ステークホルダーとの折衝経験。',
  '宇宙関連産業での実務経験。官公庁向けの営業・提案経験。GIS（地理情報システム）の知識。英語でのビジネスコミュニケーション力。',
  '福岡県福岡市博多区（出張あり）',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  '9:00〜18:00（実働8時間）',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇',
  500, 800,
  '月給42万円〜67万円（固定残業代30時間分を含む）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙（喫煙専用室あり）',
  E'出張手当\nカンファレンス参加費補助\n書籍購入費補助\n副業OK',
  '週1日リモート可',
  '書類選考 → 面接（2回） → 最終面接 → 内定',
  now()
) ON CONFLICT DO NOTHING;

-- 17-4. PM
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
  required_qualifications, preferred_qualifications,
  work_location, work_location_change_scope, job_description_change_scope,
  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd0170000-0000-0000-0000-000000000004',
  'b0000000-0000-0000-0000-000000000017',
  'c0017000-0000-0000-0000-000000000003',
  'b1000000-0000-0000-0000-000000000017',
  'open',
  'プロジェクトマネージャー｜衛星開発プロジェクトを打ち上げ成功に導くPM',
  'PM',
  '正社員',
  '1名',
  '小型衛星の開発プロジェクト全体のマネジメントを担当していただきます。開発スケジュールの策定・管理、品質管理計画の立案・実行、サプライヤーとの調整、打ち上げプロバイダーとの契約交渉・スケジュール調整、予算管理が主な業務です。衛星開発の各フェーズ（PDR、CDR、FM製造、環境試験、打ち上げ、初期運用）のマイルストーン管理と、関連するドキュメント管理も重要な役割です。社内の開発チームだけでなく、外部パートナーや顧客との調整窓口としてプロジェクトの円滑な進行を支えます。',
  '衛星という「やり直しのきかない」プロダクトのプロジェクトマネジメントは、他業界では得られない高い緊張感と達成感があります。打ち上げ成功の瞬間に立ち会えるのは、このポジションならではの特権です。宇宙産業のプロジェクトマネジメント経験は国内外で極めて希少であり、キャリアの差別化に直結します。福岡の成長するスタートアップエコシステムの中で、宇宙産業のハブを築く中核メンバーになれます。',
  '衛星開発は打ち上げ日程が外部要因で変動しやすく、それに合わせた開発スケジュールの柔軟な調整が求められます。部品の調達リードタイムが長い宇宙品質部品の在庫管理や、複数のサプライヤーとの並行した技術調整など、一般的なIT系PMとは異なるスキルセットが必要です。限られた予算と人員の中で最大の成果を出すためのリソースマネジメント力が試されます。',
  '事業開発チームに所属しつつ、衛星開発チーム・ソフトウェアチームを横断的にマネジメントする役割です。全チームとの接点を持ち、情報のハブとして機能します。',
  '宇宙プロジェクトマネジメントの専門スキル、多様なステークホルダーとの調整力、宇宙品質基準に基づくリスク管理手法、契約交渉力が身につきます。',
  '[]'::jsonb,
  '["プロジェクトマネジメント","宇宙","衛星開発","品質管理","リスク管理","PMP"]'::jsonb,
  'プロジェクトマネジメント経験5年以上。ハードウェア開発または製造業でのPM経験。複数ステークホルダーとの調整経験。',
  '宇宙・航空・防衛産業でのPM経験。PMP等のPM資格。英語でのビジネスコミュニケーション力。品質管理（QMS）に関する知識。',
  '福岡県福岡市博多区',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  '9:00〜18:00（実働8時間）',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇',
  600, 950,
  '月給50万円〜79万円（固定残業代30時間分を含む）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙（喫煙専用室あり）',
  E'出張手当\nカンファレンス参加費補助\n書籍購入費補助\n副業OK',
  '原則出社',
  '書類選考 → 面接（2回） → 最終面接 → 内定',
  now()
) ON CONFLICT DO NOTHING;

-- ============================================================
-- 18. パウズコネクト（ペット / 横浜市）
-- ============================================================

-- 18-1. 獣医師サポート企画
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
  required_qualifications, preferred_qualifications,
  work_location, work_location_change_scope, job_description_change_scope,
  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd0180000-0000-0000-0000-000000000001',
  'b0000000-0000-0000-0000-000000000018',
  'c0018000-0000-0000-0000-000000000001',
  'b1000000-0000-0000-0000-000000000018',
  'open',
  'メディカルコンテンツ企画｜獣医療×テクノロジーでペットの健康を守るサービスを設計',
  '企画',
  '正社員',
  '1名',
  '獣医師向けの診療支援プラットフォームのコンテンツ企画・開発を担当していただきます。AIによる画像診断支援機能の企画、症例データベースの構築・キュレーション、獣医師向けオンラインセミナーの企画・運営、最新の獣医療論文の要約コンテンツの制作ディレクションが主な業務です。獣医師のヒアリングを通じて現場の課題を深く理解し、テクノロジーで解決できるポイントを見極め、プロダクトの機能要件に落とし込みます。ペットオーナー向けの健康管理アプリのコンテンツ企画にも携わります。',
  'ペット業界は国内で2兆円を超える市場規模があり、その中でもペットヘルスケアは特に成長が見込まれる領域です。獣医療のDXはまだ黎明期であり、業界のスタンダードを作る側に回れる大きなチャンスがあります。獣医師との距離が近く、現場のリアルな声をダイレクトに反映したプロダクトづくりができます。動物好きな方にとって、仕事を通じてペットの健康に貢献できるやりがいのある環境です。',
  '獣医療は専門性が高く、正確な情報発信が求められるため、コンテンツの品質管理に細心の注意が必要です。獣医師は多忙なため、ヒアリングや協力依頼のタイミングと方法に工夫が求められます。また、AIによる診断支援は誤診リスクに対する慎重な設計が必要であり、テクノロジーの可能性と限界を正しく伝えるバランス感覚が問われます。ペットの命に関わる領域だからこそ、責任感を持って取り組めるポジションです。',
  '獣医サポートチーム3名で、コンテンツ企画・獣医師リレーション・データ管理の各役割を担当。獣医師の顧問3名と定期的なアドバイザリーミーティングを実施しています。',
  '獣医療ドメインの専門知識、メディカルコンテンツの企画・制作ディレクションスキル、専門家とのリレーション構築力、ヘルステック領域の知見が身につきます。',
  '[]'::jsonb,
  '["コンテンツ企画","獣医療","ペットヘルスケア","AI","メディカル","ヘルステック"]'::jsonb,
  'コンテンツ企画または編集の実務経験2年以上。ヘルスケアまたは医療分野に関する知識や経験（獣医・看護・薬学・医療系メディア等）。',
  '獣医師免許または動物看護師資格。医療系コンテンツの制作経験。SaaS企業でのプロダクト企画経験。',
  '神奈川県横浜市西区（週2日リモート可）',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  '9:30〜18:30（実働8時間）',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇、ペット忌引休暇',
  400, 600,
  '月給33万円〜50万円（固定残業代30時間分を含む）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙（喫煙専用室あり）',
  E'ペット同伴出勤可（週1日）\nペット関連サービス割引\n書籍購入費補助\n副業OK',
  '週2日リモート可',
  '書類選考 → 面接（2回） → 最終面接 → 内定',
  now()
) ON CONFLICT DO NOTHING;

-- 18-2. フロントエンドエンジニア
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
  required_qualifications, preferred_qualifications,
  work_location, work_location_change_scope, job_description_change_scope,
  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd0180000-0000-0000-0000-000000000002',
  'b0000000-0000-0000-0000-000000000018',
  'c0018000-0000-0000-0000-000000000002',
  'b1000000-0000-0000-0000-000000000018',
  'open',
  'フロントエンドエンジニア｜ペットオーナーと獣医師をつなぐプラットフォームのUI開発',
  'エンジニア',
  '正社員',
  '1〜2名',
  'ペットの健康管理アプリと獣医師向け診療支援プラットフォームのフロントエンド開発を担当していただきます。React NativeによるモバイルアプリのUI実装、Next.jsによる獣医師向けWebダッシュボードの開発、ペットの健康データのビジュアライゼーション、オンライン診療のビデオ通話UIの実装が主な業務です。ペットオーナーにとって直感的で温かみのあるUI設計と、獣医師にとって効率的な情報表示の両立を目指します。カメラを使ったペットの皮膚症状撮影UIなど、独自の技術的チャレンジも豊富です。',
  'ペット好きにはたまらない環境で、自分が開発したアプリがペットの健康を守ることに直接つながる実感があります。モバイルアプリとWebアプリの両方の開発経験を積めるため、フロントエンドエンジニアとしてのスキルの幅が大きく広がります。ペット同伴出勤日があり、実際にペットを飼っている社員も多いため、ユーザー視点での開発がしやすい環境です。',
  'ペットの健康データは飼い主にとって非常にセンシティブな情報であり、UIの見せ方一つで不安を煽ったり安心を与えたりします。情報の正確性と心理的な配慮を両立するデザインの実装が求められます。また、オンライン診療のビデオ通話はネットワーク環境が不安定なケースへの対応が必要で、WebRTCの知識と実装力が問われます。多様なデバイスでの動作検証も重要な課題です。',
  'プロダクト開発チーム3名で、フロントエンド・バックエンド・インフラの各領域をカバー。デザイナーとペアで週次のUI改善スプリントを回しています。',
  'React Native / Next.jsでのクロスプラットフォーム開発スキル、WebRTCを用いたリアルタイム通信の実装力、ヘルスケアデータのビジュアライゼーション力が身につきます。',
  '[]'::jsonb,
  '["React","React Native","Next.js","TypeScript","WebRTC","モバイルアプリ"]'::jsonb,
  'フロントエンド開発経験3年以上。React / TypeScriptでの実務経験。モバイルアプリ開発経験（React Native, Flutter等いずれか）。',
  'Next.jsでのSSR/SSG開発経験。WebRTCの実装経験。アクセシビリティ対応の知見。ペット業界への関心。',
  '神奈川県横浜市西区（フルリモート勤務可）',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  'フレックスタイム制（コアタイムなし）標準労働時間8時間',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇、ペット忌引休暇',
  450, 750,
  '月給38万円〜63万円（固定残業代45時間分を含む）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙（喫煙専用室あり）',
  E'リモートワーク手当月2万円\nペット同伴出勤可（週1日）\n書籍購入費補助\n副業OK',
  'フルリモート',
  '書類選考 → 技術面接（コーディングテスト含む） → 最終面接 → 内定',
  now()
) ON CONFLICT DO NOTHING;

-- 18-3. カスタマーサクセス
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
  required_qualifications, preferred_qualifications,
  work_location, work_location_change_scope, job_description_change_scope,
  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd0180000-0000-0000-0000-000000000003',
  'b0000000-0000-0000-0000-000000000018',
  'c0018000-0000-0000-0000-000000000003',
  'b1000000-0000-0000-0000-000000000018',
  'open',
  'カスタマーサクセス｜ペットオーナーの不安に寄り添い健康管理の継続利用を支援',
  'カスタマーサクセス',
  '正社員',
  '1名',
  'ペットオーナー向け健康管理アプリのカスタマーサクセス業務全般を担当していただきます。新規ユーザーのオンボーディング支援、利用データ分析に基づくアクティブユーザー維持施策の企画・実行、ペットオーナーコミュニティの運営・活性化、問い合わせ対応の仕組み化と品質向上が主な業務です。ペットの健康に関する不安を抱えるオーナーに寄り添いながら、アプリの活用方法を提案し、獣医師へのオンライン相談や定期検診の受診につなげるサポートも行います。顧客の声をプロダクトチームにフィードバックし、機能改善に反映する役割も担います。',
  'ペットオーナーの「大切な家族を守りたい」という気持ちに直接寄り添える、やりがいの大きなポジションです。アプリの利用がペットの早期発見・早期治療につながった事例を日常的に目にすることができ、仕事の社会的意義を実感できます。カスタマーサクセスの仕組み自体をゼロから構築するフェーズに参画できるため、CS組織の立ち上げ経験を積める貴重な機会です。',
  'ペットオーナーは感情的な判断になりやすく、アプリの数値だけでは安心を提供できないケースがあります。獣医学的に正確な情報提供と、飼い主の心理的サポートのバランスが求められます。また、ペットの種類（犬・猫・その他）や年齢によって適切なアドバイスが異なるため、幅広いペットケアの知識の習得が必要です。チャーン率の改善に向けた定量的な分析力と、一人一人に寄り添う共感力の両方が問われるポジションです。',
  'カスタマーサクセスチーム3名で、オンボーディング・コミュニティ運営・データ分析の各役割を担当。毎週の顧客の声レビュー会でプロダクト改善につなげています。',
  'BtoCカスタマーサクセスの企画・実行スキル、コミュニティマネジメント力、顧客データ分析に基づく施策立案力、ペットヘルスケア領域の知見が身につきます。',
  '[]'::jsonb,
  '["カスタマーサクセス","ペット","コミュニティ運営","BtoC","ヘルスケア","CRM"]'::jsonb,
  'カスタマーサクセスまたはカスタマーサポートの実務経験2年以上。顧客データの分析と施策立案の経験。',
  'BtoCアプリのカスタマーサクセス経験。コミュニティマネジメントの経験。ペット関連の知識や経験（ペットショップ、動物病院等での就業経験含む）。',
  '神奈川県横浜市西区（週2日リモート可）',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  '9:30〜18:30（実働8時間）',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇、ペット忌引休暇',
  350, 550,
  '月給29万円〜46万円（固定残業代30時間分を含む）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙（喫煙専用室あり）',
  E'ペット同伴出勤可（週1日）\nペット関連サービス割引\n書籍購入費補助\n副業OK',
  '週2日リモート可',
  '書類選考 → 面接（2回） → 最終面接 → 内定',
  now()
) ON CONFLICT DO NOTHING;

-- 18-4. マーケティング
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
  required_qualifications, preferred_qualifications,
  work_location, work_location_change_scope, job_description_change_scope,
