-- 1d. まちしるべ（地方創生 / 金沢市）
-- ============================================================

-- 1d-1. まちづくりプランナー
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
  required_qualifications, preferred_qualifications,
  work_location, work_location_change_scope, job_description_change_scope,
  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd01d0000-0000-0000-0000-000000000001',
  'b0000000-0000-0000-0000-00000000001d',
  'c001d000-0000-0000-0000-000000000001',
  'b1000000-0000-0000-0000-00000000001d',
  'open',
  'まちづくりプランナー｜データ×現場の声で地域の未来をデザインする',
  '企画',
  '正社員',
  '1名',
  '地方自治体と連携した地域活性化プロジェクトの企画・推進を担当していただきます。人口動態データ、経済指標、観光統計などのオープンデータ分析に基づく地域課題の可視化、住民ワークショップの企画・ファシリテーション、官民連携プロジェクトの立案・マネジメントが主な業務です。空き家リノベーション、関係人口の創出、地場産業のブランディング、ワーケーション拠点の整備など、多様なまちづくりプロジェクトを並行して進めます。内閣府の地方創生交付金や各種補助金の申請支援も重要な業務の一つです。',
  '金沢は伝統文化と現代的なまちづくりが共存する、地方創生のモデル都市です。この街を拠点に北陸地方の多様な地域課題に取り組むことで、地方創生の最前線を体感できます。一つのプロジェクトの中で、データ分析から住民との対話、行政との交渉、事業の立ち上げまで幅広い経験ができるのが大きな魅力です。地域に根ざしながらも全国の先進事例を参照し、独自のまちづくり手法を生み出す創造的な仕事です。',
  '地方創生は成果が出るまでに時間がかかり、短期的なKPIの設定が難しい分野です。住民、行政、地元企業など多様なステークホルダーの合意形成が必要で、それぞれの立場や利害を理解した上での調整力が問われます。また、人口減少という構造的な課題に対して、テクノロジーだけでは解決できない社会的・文化的な要因にも向き合う必要があります。粘り強く地域と向き合い続ける情熱と覚悟が求められるポジションです。',
  'まちづくりプランナーチーム3名で、地域分析・プロジェクト企画・住民エンゲージメントの各役割を担当。地域のNPOや大学とも密に連携しています。',
  '地方創生プロジェクトの企画・推進スキル、データ分析に基づく地域課題の可視化力、住民参加型ワークショップのファシリテーション力、補助金申請のノウハウが身につきます。',
  '[]'::jsonb,
  '["地方創生","まちづくり","企画","ファシリテーション","データ分析","官民連携"]'::jsonb,
  '企画職またはコンサルティングの実務経験2年以上。プロジェクトマネジメントの経験。提案書・企画書の作成スキル。',
  '地方自治体との協業経験。都市計画・まちづくりに関する知識。ワークショップのファシリテーション経験。補助金申請の実務経験。',
  '石川県金沢市（地方出張あり）',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  '9:00〜18:00（実働8時間）',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇',
  380, 600,
  '月給32万円〜50万円（固定残業代30時間分を含む）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙（喫煙専用室あり）',
  E'地方出張手当\n書籍購入費補助\nワーケーション制度\n副業OK',
  '週1日リモート可',
  '書類選考 → 面接（2回） → 最終面接 → 内定',
  now()
) ON CONFLICT DO NOTHING;

-- 1d-2. フルスタックエンジニア
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
  required_qualifications, preferred_qualifications,
  work_location, work_location_change_scope, job_description_change_scope,
  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd01d0000-0000-0000-0000-000000000002',
  'b0000000-0000-0000-0000-00000000001d',
  'c001d000-0000-0000-0000-000000000002',
  'b1000000-0000-0000-0000-00000000001d',
  'open',
  'フルスタックエンジニア｜地域の課題をテクノロジーで解決するシビックテック開発',
  'エンジニア',
  '正社員',
  '1〜2名',
  '地方創生に特化したWebプラットフォームの設計・開発を担当していただきます。地域のオープンデータを統合・可視化するダッシュボード、関係人口マッチングプラットフォーム、空き家バンクシステム、地域通貨・ポイントシステムなど、多様な地方創生プロダクトの開発が主な業務です。Go言語でのバックエンドAPI開発、React/TypeScriptでのフロントエンド実装、GIS（地理情報システム）を活用した地図ベースUIの開発に携わります。自治体のデータ連携基盤の構築や、LINEミニアプリなどの住民向けインターフェースの開発にも取り組みます。',
  '地方創生×テクノロジーという社会性の高い分野で、幅広い技術スタックを使ったフルスタック開発を経験できます。一つのプロダクトの成功が他の自治体への横展開につながるスケーラビリティがあり、社会実装の手応えを感じられるポジションです。金沢はIT企業の集積も進んでおり、地方でのエンジニアコミュニティも活発です。フルリモート可能なので、金沢以外からの参画も歓迎しています。',
  '自治体ごとにデータフォーマットやシステム環境が異なるため、汎用的なプロダクトを構築しつつ個別の要件にも対応する柔軟な設計が必要です。自治体のセキュリティ要件やアクセシビリティ基準への準拠も求められます。住民向けアプリは高齢者にも使いやすいUI設計が重要で、デジタルデバイドへの配慮が欠かせません。技術的な課題解決だけでなく、地域の文脈を理解した上でのプロダクト設計が問われるポジションです。',
  'エンジニアチーム3名で、バックエンド・フロントエンド・インフラの各領域をカバー。まちづくりプランナーチームと密に連携し、現場のニーズを即座にプロダクトに反映しています。',
  'Go/React/TypeScriptでのフルスタック開発スキル、GISを活用した地図ベースアプリの開発力、シビックテックのプロダクト設計力、自治体向けシステムの開発知見が身につきます。',
  '[]'::jsonb,
  '["Go","React","TypeScript","GIS","シビックテック","地方創生","LINEミニアプリ"]'::jsonb,
  'Webアプリケーション開発経験3年以上。Go, TypeScript のいずれかでの実務経験。フロントエンドとバックエンドの両方の開発経験。',
  'GIS（PostGIS, Leaflet, Mapbox等）の使用経験。自治体向けシステムの開発経験。LINEミニアプリの開発経験。アクセシビリティ対応の知見。',
  '石川県金沢市（フルリモート勤務可）',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  'フレックスタイム制（コアタイムなし）標準労働時間8時間',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇',
  450, 750,
  '月給38万円〜63万円（固定残業代45時間分を含む）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙（喫煙専用室あり）',
  E'リモートワーク手当月2万円\n書籍購入費補助\nカンファレンス参加費補助\nワーケーション制度\n副業OK',
  'フルリモート',
  '書類選考 → 技術面接（コーディングテスト含む） → 最終面接 → 内定',
  now()
) ON CONFLICT DO NOTHING;

-- 1d-3. コミュニティマネージャー
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
  required_qualifications, preferred_qualifications,
  work_location, work_location_change_scope, job_description_change_scope,
  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd01d0000-0000-0000-0000-000000000003',
  'b0000000-0000-0000-0000-00000000001d',
  'c001d000-0000-0000-0000-000000000003',
  'b1000000-0000-0000-0000-00000000001d',
  'open',
  'コミュニティマネージャー｜地域内外の人をつなぎ関係人口を育てる',
  'その他',
  '正社員',
  '1名',
  '地域と都市部をつなぐ関係人口コミュニティの運営・拡大を担当していただきます。オンラインコミュニティプラットフォームの運営、地域体験プログラム（農業体験、伝統工芸体験、ワーケーション等）の企画・実施、移住検討者への情報提供と相談対応、地域事業者と関係人口のマッチング支援が主な業務です。SNS（Instagram、X、note）での地域の魅力発信、自治体の移住促進施策との連携、関係人口の定量的な活動分析とレポーティングにも取り組みます。コミュニティメンバー同士のつながりを深め、地域への愛着を育てるイベントの設計と実施が最も重要なミッションです。',
  '金沢は北陸新幹線の開通以降、移住先・ワーケーション先として注目度が上昇しており、関係人口の創出に大きなポテンシャルがある地域です。伝統文化、食文化、自然環境が豊かで、地域の魅力を発信するコンテンツに困ることがありません。コミュニティの成長が目に見える形で地域の活性化につながるため、自分の仕事の成果を実感しやすいポジションです。地域の人々との交流を通じて、人生が豊かになる働き方ができます。',
  'オンラインとオフラインのコミュニティ運営を両立させるバランス感覚が求められます。関係人口は定住人口と異なり、エンゲージメントの維持が難しく、継続的な接点づくりの工夫が必要です。また、地域住民の中にはよそ者に対する警戒感を持つ方もおり、地域の信頼を得ながらオープンなコミュニティを構築する対人スキルが重要です。定量的な成果が見えにくい仕事でもあるため、自分なりの指標設計と活動の振り返りを継続する自律性が求められます。',
  'コミュニティマネージャーチーム3名で、オンラインコミュニティ運営・イベント企画・移住相談の各役割を担当。まちづくりプランナーチームとの連携で、プロジェクト単位のコミュニティ活動も行います。',
  '関係人口コミュニティのマネジメントスキル、地域体験プログラムの企画・実行力、SNSを活用した地域ブランディング力、移住促進の知見が身につきます。',
  '[]'::jsonb,
  '["コミュニティマネジメント","地方創生","関係人口","イベント企画","SNS運用","移住促進"]'::jsonb,
  'コミュニティ運営またはイベント企画の実務経験2年以上。SNS運用の経験。対面・オンラインでのファシリテーション経験。',
  '地方創生・まちづくり分野での活動経験。移住支援の経験。Webメディアの編集・ライティング経験。地方での居住経験。',
  '石川県金沢市（地方出張あり）',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  '9:00〜18:00（実働8時間）',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇',
  330, 500,
  '月給28万円〜42万円（固定残業代30時間分を含む）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙（喫煙専用室あり）',
  E'地方出張手当\nワーケーション制度\n地域体験プログラム参加費補助\n副業OK',
  '週1日リモート可',
  '書類選考 → 面接（2回） → 最終面接 → 内定',
  now()
) ON CONFLICT DO NOTHING;

-- 1d-4. マーケティング
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
  required_qualifications, preferred_qualifications,
  work_location, work_location_change_scope, job_description_change_scope,
  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd01d0000-0000-0000-0000-000000000004',
  'b0000000-0000-0000-0000-00000000001d',
  'c001d000-0000-0000-0000-000000000003',
  'b1000000-0000-0000-0000-00000000001d',
  'open',
  'マーケティング｜地域の魅力をデータで発掘しストーリーで届けるローカルマーケター',
  'マーケティング',
  '正社員',
  '1名',
  '地方創生プロジェクトのマーケティング戦略全般を担当していただきます。自治体連携による地域ブランディングの企画・実行、ふるさと納税のプロモーション支援、移住促進キャンペーンの企画・運用、地場産品のEC販促支援が主な業務です。地域の魅力を伝えるコンテンツ（記事、動画、写真）の企画・制作ディレクション、SEO・SNS・広告を組み合わせたデジタルマーケティングの実行、効果測定とPDCAの推進も担います。各プロジェクトの地域住民や事業者と協力しながら、外部に向けた情報発信の質と量を高めていきます。',
  '地域の魅力を発掘し、それを全国に届けるマーケティングは、クリエイティブなやりがいに満ちたポジションです。金沢の伝統工芸、食文化、自然環境など、コンテンツの素材には事欠きません。自治体と連携したプロモーションは予算規模も大きく、インパクトのある施策を実行できます。地域に住み、地域を深く知ることで生まれる「本物のストーリー」を届けられるのが、都市部のマーケターにはない強みです。',
  '地域マーケティングは即効性のある施策が少なく、ブランディングやコミュニティ形成など中長期的な視点での取り組みが必要です。複数の自治体プロジェクトを並行して進めるため、各地域の特性を理解した上でのカスタマイズ対応が求められます。地域住民や事業者との信頼関係が施策の質に直結するため、対面でのコミュニケーションを大切にしながら、デジタルマーケティングの専門性を発揮するバランス力が問われます。',
  'コミュニティマネージャーチームの一員として、コミュニティ運営とマーケティングを一体的に推進します。まちづくりプランナーチームやエンジニアチームとも連携し、プロジェクト全体のブランディングを統括します。',
  '地域ブランディングの企画・実行スキル、自治体連携マーケティングの知見、コンテンツマーケティングの制作ディレクション力、地方創生領域のマーケティング力が身につきます。',
  '[]'::jsonb,
  '["マーケティング","地域ブランディング","コンテンツ制作","SNS運用","SEO","地方創生"]'::jsonb,
  'マーケティングの実務経験3年以上。コンテンツ企画・制作の経験。SNS運用またはWeb広告運用の経験。',
  '地域ブランディングやシティプロモーションの経験。動画・写真の撮影および編集スキル。ふるさと納税関連の業務経験。ライティングスキル。',
  '石川県金沢市（地方出張あり）',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  '9:00〜18:00（実働8時間）',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇',
  380, 580,
  '月給32万円〜48万円（固定残業代30時間分を含む）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙（喫煙専用室あり）',
  E'地方出張手当\nワーケーション制度\nクリエイティブツール利用費補助\n副業OK',
  '週1日リモート可',
  '書類選考 → 面接（2回） → 最終面接 → 内定',
  now()
) ON CONFLICT DO NOTHING;

-- サムネイル・content_blocks を新規求人に一括設定
UPDATE job_postings jp SET
  thumbnail_urls = '[{"url":"/api/uploads/job-images/seed_placeholder_1.svg","filename":"placeholder1.svg"},{"url":"/api/uploads/job-images/seed_placeholder_2.svg","filename":"placeholder2.svg"},{"url":"/api/uploads/job-images/seed_placeholder_3.svg","filename":"placeholder3.svg"}]'::jsonb,
  template = (CASE (random() * 2)::int WHEN 0 THEN 'standard' WHEN 1 THEN 'modern' ELSE 'minimal' END),
  content_blocks = jsonb_build_array(
    jsonb_build_object('id', gen_random_uuid()::text, 'type', 'preset', 'key', 'description', 'title', '仕事内容', 'body', jp.description, 'icon', 'BriefcaseBusiness', 'color', '#3D8B6E', 'width', '100%'),
    jsonb_build_object('id', gen_random_uuid()::text, 'type', 'preset', 'key', 'appeal_points', 'title', 'この仕事の魅力', 'body', jp.appeal_points, 'icon', 'Sparkles', 'color', '#3D8B6E', 'width', '60', 'group_id', g.g1),
    jsonb_build_object('id', gen_random_uuid()::text, 'type', 'preset', 'key', 'team_description', 'title', 'チームについて', 'body', jp.team_description, 'icon', 'Users', 'color', '#3D8B6E', 'width', '40', 'group_id', g.g1),
    jsonb_build_object('id', gen_random_uuid()::text, 'type', 'preset', 'key', 'challenges', 'title', 'チャレンジ', 'body', jp.challenges, 'icon', 'AlertTriangle', 'color', '#E0944A', 'width', '100%'),
    jsonb_build_object('id', gen_random_uuid()::text, 'type', 'preset', 'key', 'skills_gained', 'title', '身につくスキル', 'body', jp.skills_gained, 'icon', 'Star', 'color', '#3D8B6E', 'width', '100%'),
    jsonb_build_object('id', gen_random_uuid()::text, 'type', 'custom', 'key', '', 'title', '選考プロセス', 'body', jp.selection_process, 'icon', 'ClipboardList', 'color', '#9b59b6', 'width', '100%')
  )
FROM (SELECT gen_random_uuid()::text AS g1) g
WHERE jp.company_id != 'afd20f1c-b6a8-4809-bc8f-b3f41263b511'
  AND (jp.content_blocks = '[]'::jsonb OR jp.content_blocks IS NULL OR jp.template IS NULL OR jp.template = '');

COMMIT;
