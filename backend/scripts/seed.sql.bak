-- 0f-1: セキュリティエンジニア
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
  required_qualifications, preferred_qualifications,
  work_location, work_location_change_scope, job_description_change_scope,
  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd00f0000-0000-0000-0000-000000000001',
  'b0000000-0000-0000-0000-00000000000f',
  'c000f000-0000-0000-0000-000000000001',
  'b1000000-0000-0000-0000-00000000000f',
  'open',
  'セキュリティエンジニア｜脆弱性診断とペネトレーションテストで企業を守る',
  'エンジニア',
  '正社員',
  '2名',
  'クライアント企業のWebアプリケーション・ネットワーク・クラウド環境に対する脆弱性診断およびペネトレーションテストを実施していただきます。診断計画の策定から実施、報告書の作成、改善提案まで一貫して担当します。OWASP Top 10に基づくWebアプリケーション診断、AWS / Azure / GCPのクラウドセキュリティ評価、社内ネットワークへの侵入テスト、ソーシャルエンジニアリング評価など、幅広い診断メニューに対応します。最新の攻撃手法の調査・研究も業務の一環であり、CTFや技術カンファレンスへの参加を積極的に推奨しています。',
  '国内大手企業を中心に年間200件以上の診断実績を持つプロフェッショナルチームの一員として、多様な技術環境でのセキュリティ評価経験を積めます。最新の攻撃手法と防御技術を常にキャッチアップする文化があり、CTF参加やセキュリティカンファレンスでの発表も業務時間内で支援しています。診断ツールの自社開発も行っており、攻撃側と防御側の両方の視点を深められる環境です。セキュリティ資格の取得費用は全額会社負担で、OSCP / GPEN等の高難度資格にも挑戦できます。',
  'クライアントごとに技術スタックが異なるため、幅広い技術知識が求められます。限られた診断期間の中で効率的にクリティカルな脆弱性を発見する集中力と、経営層にも伝わるレポートを作成する文章力の両方が必要です。また、セキュリティ業界は攻撃手法の進化が速いため、常に学び続ける姿勢が不可欠です。ゼロデイ脆弱性の発見と責任ある開示のプロセスも経験できます。',
  'セキュリティ診断チーム10名で、Web / ネットワーク / クラウドの専門領域ごとにチームを分けながらも、案件に応じて横断的に対応する柔軟な体制です。全員がCTFプレイヤーです。',
  'ペネトレーションテストの実践スキル、脆弱性診断の方法論、セキュリティレポートの作成力、最新の攻撃技術の知識が身につきます。',
  '[]'::jsonb,
  '["セキュリティ","ペネトレーションテスト","脆弱性診断","OWASP","CTF","クラウドセキュリティ"]'::jsonb,
  'セキュリティ診断またはペネトレーションテストの実務経験2年以上。Webアプリケーションのセキュリティに関する知識。',
  'OSCP / GPEN / CEH等のセキュリティ資格。CTFでの入賞実績。バグバウンティプログラムでの報告実績。プログラミング（Python / Go等）のスキル。',
  '東京都千代田区（リモート併用可）',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  'フレックスタイム制（コアタイムなし）標準労働時間8時間',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇',
  550, 1000,
  '月給46万円〜83万円（固定残業代45時間分を含む）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙（喫煙専用室あり）',
  E'セキュリティ資格取得費全額補助\nCTF・カンファレンス参加費補助\n書籍購入費全額補助\n副業OK',
  'リモート併用（週1〜2日出社）',
  '書類選考 → 技術面接（CTF形式の課題含む） → 最終面接 → 内定',
  now()
) ON CONFLICT DO NOTHING;

-- 0f-2: セキュリティコンサルタント
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
  required_qualifications, preferred_qualifications,
  work_location, work_location_change_scope, job_description_change_scope,
  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd00f0000-0000-0000-0000-000000000002',
  'b0000000-0000-0000-0000-00000000000f',
  'c000f000-0000-0000-0000-000000000002',
  'b1000000-0000-0000-0000-00000000000f',
  'open',
  'セキュリティコンサルタント｜企業のセキュリティ戦略を設計・実行',
  'その他',
  '正社員',
  '1名',
  'クライアント企業のセキュリティ戦略策定から実装支援までを担当するコンサルティングポジションです。情報セキュリティマネジメントシステム（ISMS）の構築支援、セキュリティポリシーの策定、インシデントレスポンス計画の設計、セキュリティ教育プログラムの開発、コンプライアンス対応（GDPR / 個人情報保護法 / PCI DSS等）の支援など、組織のセキュリティ体制全体をコンサルティングします。経営層へのセキュリティリスク報告やセキュリティ投資のROI算出など、ビジネス視点でのセキュリティ推進も重要な業務です。',
  '金融機関、医療機関、大手製造業など多様な業界のクライアントを担当するため、業界横断のセキュリティ知見を短期間で蓄積できます。技術的な診断チームと密に連携するため、技術とマネジメントの両面からセキュリティを理解できる稀有な環境です。クライアントの経営層と直接対話する機会が多く、ビジネスとセキュリティの橋渡し役として成長できます。セキュリティ業界のトップクラスの人材と日常的に知見を交換できるネットワークも魅力です。',
  'セキュリティの専門知識を非技術者にもわかりやすく伝えるコミュニケーション力が不可欠です。クライアントのビジネス目標とセキュリティ要件のバランスを取る提案力、規制環境の変化に素早く対応する情報収集力も求められます。複数のプロジェクトを同時に推進するマルチタスク能力と、クライアントの信頼を勝ち取る人間力も重要です。',
  'コンサルティングチーム6名で、各メンバーが専門領域を持ちつつ案件に応じて柔軟にチームを組成しています。診断チームとの定期的なナレッジ共有会を実施しています。',
  'セキュリティコンサルティングのスキル、ISMS構築の実践力、経営層へのリスクコミュニケーション力、コンプライアンス対応の知見が身につきます。',
  '[]'::jsonb,
  '["セキュリティコンサル","ISMS","GDPR","PCI DSS","リスクマネジメント","コンプライアンス"]'::jsonb,
  'セキュリティコンサルティングまたはIT監査の実務経験3年以上。ISMS / ISO27001の知識。',
  'CISSP / CISM等のセキュリティマネジメント資格。金融・医療等の規制業種でのコンサルティング経験。GDPR / PCI DSS対応の実績。プロジェクトマネジメントの経験。',
  '東京都千代田区（リモート併用可）',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  'フレックスタイム制（コアタイムなし）標準労働時間8時間',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇',
  600, 1100,
  '月給50万円〜92万円（固定残業代45時間分を含む）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙（喫煙専用室あり）',
  E'セキュリティ資格取得費全額補助\nカンファレンス参加費補助\n書籍購入費全額補助\n副業OK',
  'リモート併用（週1〜2日出社）',
  '書類選考 → ケース面接 → 最終面接 → 内定',
  now()
) ON CONFLICT DO NOTHING;

-- 0f-3: SOCアナリスト
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
  required_qualifications, preferred_qualifications,
  work_location, work_location_change_scope, job_description_change_scope,
  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd00f0000-0000-0000-0000-000000000003',
  'b0000000-0000-0000-0000-00000000000f',
  'c000f000-0000-0000-0000-000000000001',
  'b1000000-0000-0000-0000-00000000000f',
  'open',
  'SOCアナリスト｜24時間体制のセキュリティ監視でサイバー攻撃を検知・対処',
  'エンジニア',
  '正社員',
  '2名',
  'クライアント企業のネットワーク・エンドポイント・クラウド環境を24時間体制で監視し、サイバー攻撃の検知・分析・対応を行うSOC（Security Operations Center）アナリストのポジションです。SIEM / EDR / NDRからのアラートのトリアージ、インシデントの初動対応、マルウェア解析、脅威インテリジェンスに基づく先行的な防御策の提案などが主な業務です。また、検知ルールの作成・チューニング、SOC運用プロセスの改善、インシデント対応手順書の整備にも取り組みます。日勤帯と夜勤帯のローテーション体制で、チームで連携しながらクライアントの環境を守り続けます。',
  'リアルなサイバー攻撃と日常的に対峙するため、教科書では学べない実践的なスキルが身につくポジションです。国内大手企業の環境を監視するため、APTグループによる標的型攻撃からランサムウェア、フィッシングまで多様な脅威に対応する経験を積めます。脅威インテリジェンスチームとの連携により、最新の攻撃動向をいち早くキャッチアップできる環境です。SOCの自動化やAIを活用した検知精度向上にも取り組んでおり、先端技術の活用にも積極的です。',
  'アラートの大量発生時に優先順位を素早く判断するトリアージ能力が求められます。また、正常な通信と攻撃通信を区別する深い技術知識と、クライアントの業務環境を理解した上での分析力が不可欠です。シフト勤務のため生活リズムの管理も重要なテーマです。緊張感のある環境で冷静に対処する判断力と、チーム内での正確な引き継ぎコミュニケーションも求められます。',
  'SOCチーム15名で、日勤・夜勤のローテーションを組んでいます。Tier 1（アラート対応）からTier 3（高度分析）まで段階的にスキルアップできる育成体制があります。',
  'セキュリティ監視の実践スキル、インシデントレスポンスの対応力、SIEM / EDRの運用スキル、マルウェア解析の基礎知識が身につきます。',
  '[]'::jsonb,
  '["SOC","SIEM","EDR","インシデント対応","脅威インテリジェンス","マルウェア解析"]'::jsonb,
  'ITインフラまたはセキュリティの実務経験2年以上。ネットワークの基礎知識（TCP/IP, DNS, HTTP等）。',
  'SOC / CSIRTでの勤務経験。SIEM（Splunk / QRadar等）の運用経験。セキュリティ関連資格（CompTIA Security+ / CEH等）。ログ分析の経験。',
  '東京都千代田区',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  'シフト制（日勤9:00〜18:00 / 夜勤21:00〜6:00）実働8時間',
  '60分',
  '4週8休（シフトによる）、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇',
  450, 800,
  '月給38万円〜67万円（深夜手当別途支給）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙（喫煙専用室あり）',
  E'セキュリティ資格取得費全額補助\nカンファレンス参加費補助\n書籍購入費全額補助\n深夜勤務手当',
  '原則出社（SOC勤務）',
  '書類選考 → 技術面接 → 最終面接 → 内定',
  now()
) ON CONFLICT DO NOTHING;

-- 0f-4: セールス
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
  required_qualifications, preferred_qualifications,
  work_location, work_location_change_scope, job_description_change_scope,
  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd00f0000-0000-0000-0000-000000000004',
  'b0000000-0000-0000-0000-00000000000f',
  'c000f000-0000-0000-0000-000000000003',
  'b1000000-0000-0000-0000-00000000000f',
  'open',
  'セキュリティセールス｜企業の経営課題としてのセキュリティを提案',
  'セールス',
  '正社員',
  '1名',
  'サイバーフォートレスのセキュリティサービス（脆弱性診断、SOC監視、コンサルティング、インシデント対応支援）の法人営業を担当していただきます。新規クライアントの開拓から既存クライアントのアカウントマネジメントまでを一貫して行います。クライアントのIT部門・経営層に対して、セキュリティリスクを経営課題として可視化し、最適なサービスの組み合わせを提案するコンサルティング営業です。技術チームと連携して提案書を作成し、PoC（概念実証）の調整、契約交渉、導入後のフォローアップまで幅広く担当します。',
  'セキュリティ市場は年率10%以上で成長しており、営業としてのキャリアパスが非常に広いポジションです。技術力の高いエンジニアチームをバックに、自信を持って提案できる環境があります。クライアントの経営層と直接対話する機会が多く、ビジネスパーソンとして大きく成長できます。セキュリティの専門知識は入社後に身につけられる研修制度が整っており、IT営業の経験があれば業界未経験でも活躍できます。',
  'セキュリティサービスは「事故が起きなければ価値が見えにくい」という特性があり、ROIを明確に示す提案力が求められます。また、クライアントの技術環境を理解した上で最適なサービスを提案するために、技術的な基礎知識の習得が不可欠です。競合も多い市場のため、サイバーフォートレスの技術力と実績を差別化要因として効果的に訴求する営業戦略の立案も重要です。',
  'セールスチーム5名で、アカウント規模別に担当を分けています。技術チームとの連携が密で、提案段階からエンジニアが同席する体制です。',
  'セキュリティ業界のセールスノウハウ、経営層へのコンサルティング営業スキル、IT業界のビジネス知識が身につきます。',
  '[]'::jsonb,
  '["法人営業","セキュリティ","コンサルティング営業","SaaS","IT業界","アカウントマネジメント"]'::jsonb,
  'IT業界での法人営業経験3年以上。新規開拓とアカウントマネジメントの両方の経験。',
  'セキュリティ業界での営業経験。大手企業への提案営業経験。技術的なバックグラウンド。CRM（Salesforce等）の活用経験。',
  '東京都千代田区（リモート併用可）',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  'フレックスタイム制（コアタイムなし）標準労働時間8時間',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇',
  500, 900,
  '月給42万円〜75万円（固定残業代45時間分を含む）。インセンティブ制度あり。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙（喫煙専用室あり）',
  E'セキュリティ資格取得費補助\n書籍購入費全額補助\n交通費全額支給\n副業OK',
  'リモート併用（週2日出社）',
  '書類選考 → 一次面接 → 最終面接 → 内定',
  now()
) ON CONFLICT DO NOTHING;

