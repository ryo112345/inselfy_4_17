  '書類選考 → 一次面接 → 最終面接 → 内定',
  now()
) ON CONFLICT DO NOTHING;

-- サムネイル・content_blocks を全求人に設定（カスタムモード）
UPDATE job_postings jp SET
  thumbnail_urls = '[{"url":"/api/uploads/job-images/seed_placeholder_1.svg","filename":"placeholder1.svg"},{"url":"/api/uploads/job-images/seed_placeholder_2.svg","filename":"placeholder2.svg"},{"url":"/api/uploads/job-images/seed_placeholder_3.svg","filename":"placeholder3.svg"}]'::jsonb,
  template = 'standard',
  content_blocks = jsonb_build_array(
    jsonb_build_object('id', gen_random_uuid()::text, 'type', 'preset', 'key', 'description', 'title', '仕事内容', 'body', jp.description, 'icon', 'BriefcaseBusiness', 'color', '#3D8B6E', 'width', '100%'),
    jsonb_build_object('id', gen_random_uuid()::text, 'type', 'preset', 'key', 'appeal_points', 'title', 'この仕事の魅力', 'body', jp.appeal_points, 'icon', 'Sparkles', 'color', '#3D8B6E', 'width', '60', 'group_id', g.g1),
    jsonb_build_object('id', gen_random_uuid()::text, 'type', 'preset', 'key', 'team_description', 'title', 'チームについて', 'body', jp.team_description, 'icon', 'Users', 'color', '#3D8B6E', 'width', '40', 'group_id', g.g1),
    jsonb_build_object('id', gen_random_uuid()::text, 'type', 'preset', 'key', 'challenges', 'title', 'チャレンジ', 'body', jp.challenges, 'icon', 'AlertTriangle', 'color', '#E0944A', 'width', '100%'),
    jsonb_build_object('id', gen_random_uuid()::text, 'type', 'custom', 'key', '', 'title', '開発環境・技術スタック', 'body', E'言語: Go, TypeScript\nDB: PostgreSQL + pgvector\nインフラ: AWS (ECS, RDS, CloudFront)\nCI/CD: GitHub Actions\nコミュニケーション: Slack, Linear, Notion\nデザイン: Figma', 'icon', 'Code', 'color', '#3498db', 'width', '50', 'group_id', g.g2),
    jsonb_build_object('id', gen_random_uuid()::text, 'type', 'preset', 'key', 'skills_gained', 'title', '身につくスキル', 'body', jp.skills_gained, 'icon', 'Star', 'color', '#3D8B6E', 'width', '50', 'group_id', g.g2),
    jsonb_build_object('id', gen_random_uuid()::text, 'type', 'custom', 'key', '', 'title', '選考プロセス', 'body', E'カジュアル面談（任意） → 書類選考 → 一次面接（技術 or ポートフォリオ） → 最終面接（代表） → 内定\n\n選考期間は通常2〜3週間です。オンライン完結も可能です。ご希望に応じてオフィス見学も実施しています。', 'icon', 'ClipboardList', 'color', '#9b59b6', 'width', '100%')
  )
FROM (SELECT gen_random_uuid()::text AS g1, gen_random_uuid()::text AS g2) g
WHERE jp.company_id = 'afd20f1c-b6a8-4809-bc8f-b3f41263b511'
  AND (jp.content_blocks = '[]'::jsonb OR jp.content_blocks IS NULL OR jp.template IS NULL OR jp.template = '');

