  work_location, work_location_change_scope, job_description_change_scope,
  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd0020000-0000-0000-0000-000000000003',
  'b0000000-0000-0000-0000-000000000002',
  'c0002000-0000-0000-0000-000000000001',
  'b1000000-0000-0000-0000-000000000002',
  'open',
  'プロダクト企画｜農家の声を起点にスマート農業の未来を描く',
  '企画',
  '正社員',
  '1名',
  'グリーンフィールドのスマート農業プラットフォームのプロダクト企画を担当します。農家へのヒアリングやフィールド観察を通じて課題を発見し、新機能やサービスの企画立案を行います。収集した農業データの分析から新たな価値提案を創出し、ロードマップの策定とプライオリティ付けを主導します。農業の現場とテクノロジーチームの橋渡し役として、ユーザーストーリーの作成や仕様策定も担当します。',
  '農業という日本の基幹産業の課題をテクノロジーで解決する企画に携われます。実際に農場を訪問し、農家と直接対話しながらプロダクトを作り上げていく体験は、オフィスワークだけでは得られない刺激があります。スタートアップならではのスピード感で、企画したものがすぐにプロダクトに反映される環境です。農林水産省のスマート農業実証プロジェクトにも参画しており、政策レベルの議論にも関われます。',
  '農業は季節や天候に大きく左右されるため、一般的なIT製品と異なるプロダクトサイクルへの対応が必要です。また、ITリテラシーが高くないユーザーにも使いやすいUXを設計する配慮が求められます。さらに、地域や作物によって異なるニーズを汎用的なプロダクトに落とし込むための抽象化能力が重要です。',
  'プロダクト企画担当は現在2名で、IoTエンジニアチームと密に連携しています。農学部出身者やJA出身者も在籍し、ドメイン知識が豊富な環境です。',
  '農業テックのプロダクト企画スキル、フィールドリサーチの手法、データ分析に基づく意思決定力が身につきます。',
  '[]'::jsonb,
  '["プロダクト企画","農業テック","ユーザーリサーチ","データ分析","UX設計","スマート農業"]'::jsonb,
  'IT製品やサービスの企画経験2年以上。ユーザーリサーチの実施経験。',
  'プロダクトマネジメントの経験。農業やフードテック領域への関心。データ分析の基礎スキル。',
  '北海道札幌市（リモート併用可、月2回程度の農場訪問あり）',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  'フレックスタイム制（コアタイムなし）標準労働時間8時間',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇',
  400, 700,
  '月給33万円〜58万円（固定残業代30時間分を含む）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙',
  E'リモートワーク手当月2万円\n農場訪問時の交通費・宿泊費全額支給\n書籍購入費補助\n農産物の社員割引購入制度\n副業OK',
  'リモート併用（月2回農場訪問）',
  '書類選考 → 一次面接 → 企画課題 → 最終面接 → 内定',
  now()
) ON CONFLICT DO NOTHING;

-- 02-4. フィールドオペレーション（農業テック特有）
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
  required_qualifications, preferred_qualifications,
  work_location, work_location_change_scope, job_description_change_scope,
  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd0020000-0000-0000-0000-000000000004',
  'b0000000-0000-0000-0000-000000000002',
  'c0002000-0000-0000-0000-000000000002',
  'b1000000-0000-0000-0000-000000000002',
  'open',
  'フィールドオペレーション｜農場とテクノロジーをつなぐ現場の司令塔',
  'その他',
  '正社員',
  '1名',
  '農場でのIoTセンサーの設置・メンテナンス、農家へのシステム導入支援、運用トレーニングを担当します。新規導入農場では現地調査を行い、センサーの最適な設置場所を選定し、通信環境の構築からデータ収集の動作確認までを一貫して担当します。また、収集データの初期分析を行い、農家に対して栽培改善のアドバイスを提供します。トラブル発生時には一次対応として現場駆けつけや遠隔サポートを行い、必要に応じてエンジニアチームにエスカレーションします。',
  'テクノロジーと農業の最前線で働くユニークなポジションです。農家から直接感謝の声をいただける仕事であり、自分の活動が食の安全や農業の効率化に直結する実感を得られます。北海道の雄大な自然の中で働く機会が多く、オフィスワークとフィールドワークのバランスが取れた働き方ができます。農業IoTの実践的な知見は今後の成長市場で大きな強みになります。',
  '北海道の農場は広大で、センサー設置やメンテナンスには体力と忍耐が必要です。冬季は厳しい寒さの中での作業もあります。また、農家によってITリテラシーが異なるため、わかりやすい説明と丁寧なサポートが求められます。トラブル対応では、ハードウェアとソフトウェアの両方の知識が必要になる場面もあります。',
  'フィールドオペレーションチーム4名で、2名が北海道内、2名が本州を担当しています。全員が農業への強い関心を持ち、農家との信頼関係を大切にしているメンバーです。',
  '農業IoTの現場運用スキル、農家との信頼関係構築力、IoTハードウェアのトラブルシューティング能力が身につきます。',
  '[]'::jsonb,
  '["フィールドオペレーション","IoT","農業テック","センサー","テクニカルサポート","導入支援"]'::jsonb,
  'IT製品の導入支援またはテクニカルサポート経験2年以上。普通自動車免許。出張・屋外作業に対応できる方。',
  '農業関連の業務経験。IoTデバイスの設置・メンテナンス経験。電気工事士等の資格。北海道在住の方歓迎。',
  '北海道札幌市（フィールドワーク中心：週3〜4日は農場訪問）',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  'フレックスタイム制（コアタイムなし）標準労働時間8時間',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇',
  350, 550,
  '月給29万円〜46万円（固定残業代20時間分を含む）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙',
  E'社用車貸与\n農場訪問時の交通費・宿泊費全額支給\n防寒具・作業着支給\n農産物の社員割引購入制度\n副業OK',
  '出社・フィールドワーク中心',
  '書類選考 → 一次面接 → 農場同行体験（半日） → 最終面接 → 内定',
  now()
) ON CONFLICT DO NOTHING;

-- ============================================================
-- 企業03: メディカルブリッジ（ヘルステック）
-- teams: データサイエンス=c0003..1, 医療連携=c0003..2, プロダクトマネジメント=c0003..3
-- ============================================================

-- 03-1. エンジニア
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
  required_qualifications, preferred_qualifications,
  work_location, work_location_change_scope, job_description_change_scope,
  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd0030000-0000-0000-0000-000000000001',
  'b0000000-0000-0000-0000-000000000003',
  'c0003000-0000-0000-0000-000000000001',
  'b1000000-0000-0000-0000-000000000003',
  'open',
  'データサイエンティスト｜医療データ×AIで予防医療の未来を切り拓く',
  'エンジニア',
  '正社員',
  '1〜2名',
  '健康診断データ、電子カルテデータ、ウェアラブルデバイスデータを組み合わせた予測モデルの構築を担当します。生活習慣病の発症リスク予測、最適な健康介入プログラムの推薦、治療効果の分析など、医療領域のデータサイエンス全般に携わります。臨床医や疫学研究者と協力しながらモデルの設計・検証を行い、エビデンスに基づいた予防医療サービスの実現を目指します。分析結果はプロダクトのレコメンデーション機能に組み込まれ、数十万人のユーザーの健康管理に活用されます。',
  '医療という社会的意義の高い領域で、データサイエンスの最先端を実践できるポジションです。大学病院や研究機関との共同研究プロジェクトにも参画でき、学術的な成果を出す機会もあります。自分が構築したモデルが数十万人の健康管理に活用されるスケール感と、医療の質向上に貢献できるやりがいがあります。',
  '医療データは個人情報保護の規制が厳しく、データの取り扱いには細心の注意が必要です。また、モデルの予測精度だけでなく、解釈可能性や公平性も重要な評価指標となります。臨床的な妥当性を担保するため、医療専門家とのコミュニケーション能力も求められます。',
  'データサイエンスチーム6名で、統計学・機械学習・バイオインフォマティクスの専門家が揃っています。週次のジャーナルクラブで最新論文を共有する学術的な雰囲気のチームです。',
  '医療データ分析のスキル、予測モデル構築力、医療ドメインの知識、研究開発の実践経験が身につきます。',
  '[]'::jsonb,
  '["Python","機械学習","医療データ","統計分析","予防医療","TensorFlow"]'::jsonb,
  'データサイエンスまたは機械学習の実務経験3年以上。Python、R等の分析言語での開発経験。統計学の基礎知識。',
  '医療データの分析経験。バイオインフォマティクスの知識。修士号以上（統計、情報科学、疫学等）。論文執筆・発表の経験。',
  '東京都千代田区（リモート併用可）',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  'フレックスタイム制（コアタイム10:00-15:00）標準労働時間8時間',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇',
  600, 1000,
  '月給50万円〜83万円（固定残業代30時間分を含む）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙（喫煙専用室あり）',
  E'学会・カンファレンス参加費全額補助\n論文投稿費用補助\n書籍購入費月2万円補助\n健康診断フルコース無料\nリモートワーク手当月3万円',
  'リモート併用（週2出社推奨）',
  '書類選考 → 技術面接（ケーススタディ含む） → 論文・ポートフォリオレビュー → 最終面接 → 内定',
  now()
) ON CONFLICT DO NOTHING;

-- 03-2. セールス
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
