  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd0030000-0000-0000-0000-000000000003',
  'b0000000-0000-0000-0000-000000000003',
  'c0003000-0000-0000-0000-000000000003',
  'b1000000-0000-0000-0000-000000000003',
  'open',
  'プロダクトマネージャー｜医療×テクノロジーで予防医療の体験を再設計する',
  'PM',
  '正社員',
  '1名',
  'メディカルブリッジの予防医療プラットフォームのプロダクト戦略立案から実行までを統括します。ユーザー（個人・医療従事者・健保組合担当者）それぞれの体験を設計し、プロダクトロードマップを策定します。医療データの活用方針やAI機能の企画をデータサイエンスチームと共に推進し、医療規制への対応方針も決定します。ステークホルダーが多い医療領域で、ビジネス・テクノロジー・医療の3つの視点を統合するポジションです。',
  '予防医療という社会的意義の高い領域で、プロダクトの方向性を自ら決定できるポジションです。大学病院の医師や疫学研究者と直接議論しながらプロダクトを作る経験は、他のIT企業では得られません。数十万人のユーザーの健康行動を変えるプロダクトを設計するスケール感と責任感は大きなやりがいです。',
  '医療は人の命に関わる領域のため、プロダクトの品質基準が非常に高く設定されています。医療機器規制やプライバシー保護の観点から、リリースまでのプロセスが一般的なIT製品より複雑です。また、医療従事者・一般ユーザー・保険者という異なるペルソナの要望を整合させる調整力が必要です。',
  'PM3名で、BtoCプロダクト担当とBtoBプロダクト担当に分かれています。医師資格を持つメンバーが1名在籍し、臨床的な観点からのアドバイスを受けられます。',
  'ヘルステックのプロダクトマネジメント力、医療規制の知見、マルチステークホルダー調整力が身につきます。',
  '[]'::jsonb,
  '["プロダクトマネジメント","ヘルステック","予防医療","医療データ","ロードマップ策定","規制対応"]'::jsonb,
  'プロダクトマネジメント経験3年以上。BtoB SaaSまたはBtoCサービスでの企画・開発経験。',
  '医療・ヘルスケア領域のプロダクト経験。データ分析やAIプロダクトの企画経験。医療系資格や医療業界での業務経験。',
  '東京都千代田区（リモート併用可）',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  'フレックスタイム制（コアタイム10:00-15:00）標準労働時間8時間',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇',
  650, 1050,
  '月給54万円〜88万円（固定残業代30時間分を含む）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙（喫煙専用室あり）',
  E'学会・カンファレンス参加費全額補助\n書籍購入費月2万円補助\n健康診断フルコース無料\nリモートワーク手当月3万円\n副業OK（届出制）',
  'リモート併用（週2出社推奨）',
  '書類選考 → 一次面接 → ケース面接 → 最終面接 → 内定',
  now()
) ON CONFLICT DO NOTHING;

-- 03-4. 医療情報管理（ヘルステック特有）
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
