  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd00b0000-0000-0000-0000-000000000002',
  'b0000000-0000-0000-0000-00000000000b',
  'c000b000-0000-0000-0000-000000000002',
  'b1000000-0000-0000-0000-00000000000b',
  'open',
  'データアナリスト｜購買データ分析でEC売上を最大化',
  'その他',
  '正社員',
  '1名',
  '数百万件の購買データ・行動ログを分析し、マーチャント向けの売上改善提案やプラットフォーム全体の成長施策を立案していただきます。ABテストの設計・実行、レコメンデーションアルゴリズムの効果検証、離脱率分析によるUX改善提案など、データを起点としたビジネス意思決定を支えるポジションです。BIダッシュボードの構築・運用も担当し、経営陣やマーチャントがリアルタイムにデータを活用できる環境を整備します。分析結果をわかりやすく可視化し、非エンジニアのステークホルダーにも伝わるレポーティングスキルが求められます。',
  'EC領域ならではの膨大な購買データを扱えるポジションです。分析結果がマーチャントの売上やプラットフォームのKPIに直結するため、ビジネスインパクトを実感しやすい環境です。データ基盤の設計段階から関与でき、分析しやすいデータパイプラインを自ら構築できる裁量があります。エンジニアチームとの距離が近く、分析結果をすぐにプロダクト改善に反映できるスピード感も魅力です。',
  'マルチテナント型のデータ分析では、テナント横断の傾向分析と個別テナントへのカスタマイズされた分析の両方が求められます。データの品質管理やプライバシーへの配慮も重要なテーマです。リアルタイムデータとバッチデータの使い分け、大規模データセットのクエリパフォーマンス最適化など、技術的なチャレンジも豊富にあります。',
  'ビジネス企画チーム3名の中でデータ分析を専任で担当していただきます。エンジニアチームと密に連携しながら、データドリブンな意思決定文化を社内に根付かせる役割です。',
  'EC領域のデータ分析スキル、BIダッシュボードの構築・運用力、ABテストの設計・統計解析スキル、ビジネスインテリジェンスの知見が身につきます。',
  '[]'::jsonb,
  '["データ分析","SQL","Python","BigQuery","Looker","EC","ABテスト"]'::jsonb,
  'データ分析の実務経験3年以上。SQLを用いたデータ抽出・加工の経験。BIツールを用いたダッシュボード構築の経験。',
  'EC・小売業界でのデータ分析経験。Python / Rを用いた統計分析の経験。BigQuery等のクラウドDWHの利用経験。機械学習モデルの構築経験。',
  '神奈川県横浜市（リモート併用可）',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  'フレックスタイム制（コアタイム11:00〜15:00）標準労働時間8時間',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇',
  500, 850,
  '月給42万円〜71万円（固定残業代40時間分を含む）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙（喫煙専用室あり）',
  E'リモートワーク手当月2万円\n書籍購入費補助（年5万円）\n社員割引制度\n副業OK',
  'リモート併用（週2日出社）',
  '書類選考 → 分析課題 → 面接（2回） → 内定',
  now()
) ON CONFLICT DO NOTHING;

-- 0b-3: プロダクトマネージャー
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
