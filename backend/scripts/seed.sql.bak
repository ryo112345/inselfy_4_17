-- 1a-2. アーティストリレーション
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
  required_qualifications, preferred_qualifications,
  work_location, work_location_change_scope, job_description_change_scope,
  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd01a0000-0000-0000-0000-000000000002',
  'b0000000-0000-0000-0000-00000000001a',
  'c001a000-0000-0000-0000-000000000002',
  'b1000000-0000-0000-0000-00000000001a',
  'open',
  'アーティストリレーション｜音楽クリエイターとAI技術をつなぐコミュニティ育成',
  'カスタマーサクセス',
  '正社員',
  '1名',
  'アーティストやクリエイターとの関係構築・コミュニティ運営を担当していただきます。プロのミュージシャンやプロデューサーへの当社AI音楽ツールの導入支援、ユーザーコミュニティの運営、アーティストからのフィードバック収集とプロダクトチームへの橋渡し、共同制作プロジェクトの企画・ディレクションが主な業務です。音楽フェスティバルやクリエイターイベントへの出展企画、ワークショップの開催を通じたユーザー拡大にも取り組みます。AI音楽ツールの活用事例を取材・発信するコンテンツ制作も重要な役割です。',
  '音楽業界の第一線で活躍するアーティストと直接やり取りしながら、AI技術が音楽制作をどう変えるかの最前線に立てるポジションです。京都には伝統音楽からインディーまで多彩な音楽シーンがあり、地域のアーティストとの連携機会も豊富です。音楽×テクノロジーのコミュニティはグローバルにつながっており、海外のカンファレンスやフェスへの参加を通じて国際的なネットワークも構築できます。',
  'AIによる音楽生成には著作権や創造性に関する議論がつきまとい、アーティストの中にはAI技術に懐疑的な方もいます。テクノロジーの価値を押し付けるのではなく、アーティストの創造性を拡張するツールとしての可能性を丁寧に伝えるコミュニケーション力が求められます。また、音楽制作の現場を理解した上での提案が必要であり、音楽と技術の両方への深い理解が問われるポジションです。',
  'アーティストリレーションチーム3名で、プロアーティスト担当・コミュニティ運営・コンテンツ制作の各役割を担当。チーム全員が楽器演奏やDTMの経験を持つ音楽好きなメンバーです。',
  'アーティストリレーションの構築・維持スキル、音楽テックコミュニティの運営力、イベント企画・実行力、音楽業界のネットワーク構築力が身につきます。',
  '[]'::jsonb,
  '["アーティストリレーション","コミュニティ運営","音楽業界","イベント企画","コンテンツ制作","音楽テック"]'::jsonb,
  '音楽業界（レーベル、ディストリビューター、音楽メディア、イベント企画等）での実務経験2年以上。アーティストやクリエイターとのリレーション構築経験。',
  '自身での音楽制作経験（DTM含む）。コミュニティマネジメントの経験。音楽テックスタートアップでの経験。SNS運用・コンテンツマーケティングの経験。',
  '京都府京都市中京区（出張あり）',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  'フレックスタイム制（コアタイム11:00-15:00）標準労働時間8時間',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇',
  380, 580,
  '月給32万円〜48万円（固定残業代30時間分を含む）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙（喫煙専用室あり）',
  E'楽器・音楽機材購入補助\nイベント参加費補助\nライブ鑑賞チケット補助\n副業OK',
  '週1日リモート可',
  '書類選考 → 面接（2回） → 最終面接 → 内定',
  now()
) ON CONFLICT DO NOTHING;

-- 1a-3. フルスタックエンジニア
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
  required_qualifications, preferred_qualifications,
  work_location, work_location_change_scope, job_description_change_scope,
  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd01a0000-0000-0000-0000-000000000003',
  'b0000000-0000-0000-0000-00000000001a',
  'c001a000-0000-0000-0000-000000000003',
  'b1000000-0000-0000-0000-00000000001a',
  'open',
  'フルスタックエンジニア｜ブラウザで動くAI音楽制作ツールを開発',
  'エンジニア',
  '正社員',
  '1〜2名',
  'ブラウザベースのAI音楽制作プラットフォームの開発を担当していただきます。Web Audio APIとWebAssemblyを活用したブラウザ上でのリアルタイム音声処理、React/TypeScriptでのDAW風UIの実装、Go言語でのバックエンドAPI開発、AIモデルのサービング基盤の構築が主な業務です。ユーザーが直感的に音楽を制作できるインタラクティブなUIと、低レイテンシの音声処理を両立するアーキテクチャ設計が求められます。また、クラウド上でのコラボレーション機能や、楽曲の共有・公開プラットフォームの開発にも携わります。',
  '音楽制作ツールのWebアプリケーション開発は、一般的なSPAとは異なるリアルタイム性と音声処理の専門性が求められる領域です。Web Audio API、WebAssembly、WebRTCなどの先端Web技術を実践的に使いこなせるようになります。音楽好きなエンジニアにとって、自分が作ったツールでアーティストが楽曲を制作する光景を見られるのは最高の体験です。',
  'ブラウザ上でのリアルタイム音声処理は、デバイスごとのオーディオレイテンシの違いやブラウザ間の互換性問題など、一般的なWebアプリとは異なる技術的課題があります。DAW風のUIは高度な状態管理とパフォーマンス最適化が必要で、数百トラックの同時再生を滑らかに表示する技術力が求められます。また、AIモデルの推論結果を音楽的に自然な形で反映するための信号処理パイプラインの設計も重要な課題です。',
  'プロダクト開発チーム3名で、フロントエンド・バックエンド・インフラの各領域をカバー。サウンドエンジニアチームとの連携が密で、AI機能の統合を日常的に行っています。',
  'Web Audio / WebAssemblyを活用したリアルタイム音声処理スキル、高度なReact/TypeScript開発力、Go言語でのバックエンド設計力が身につきます。',
  '[]'::jsonb,
  '["TypeScript","React","Go","Web Audio API","WebAssembly","音楽テック"]'::jsonb,
  'Webアプリケーション開発経験3年以上。TypeScript / Reactでの実務経験。バックエンド開発の経験。',
  'Web Audio APIの使用経験。WebAssemblyの開発経験。音楽制作（DTM）の経験。Rust/C++での低レイヤ開発経験。',
  '京都府京都市中京区（フルリモート勤務可）',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  'フレックスタイム制（コアタイムなし）標準労働時間8時間',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇',
  500, 800,
  '月給42万円〜67万円（固定残業代45時間分を含む）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙（喫煙専用室あり）',
  E'リモートワーク手当月2万円\n楽器・音楽機材購入補助\n書籍購入費補助\n副業OK',
  'フルリモート',
  '書類選考 → 技術面接（コーディングテスト含む） → 最終面接 → 内定',
  now()
) ON CONFLICT DO NOTHING;

-- 1a-4. UIデザイナー
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
  required_qualifications, preferred_qualifications,
  work_location, work_location_change_scope, job_description_change_scope,
  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd01a0000-0000-0000-0000-000000000004',
  'b0000000-0000-0000-0000-00000000001a',
  'c001a000-0000-0000-0000-000000000003',
  'b1000000-0000-0000-0000-00000000001a',
  'open',
  'UI/UXデザイナー｜直感的に音楽が生まれるクリエイティブツールのデザイン',
  'デザイナー',
  '正社員',
  '1名',
  'AI音楽制作プラットフォームのUI/UXデザインを担当していただきます。DAW風のタイムラインUI、ピアノロールエディタ、ミキサー画面、エフェクトコントロール等の楽曲制作に関わる全画面のデザインを行います。音楽初心者でも直感的に使えるインターフェースと、プロが求める高度な操作性の両立が最大のテーマです。ユーザーリサーチに基づくペルソナ設計、プロトタイピング、ユーザビリティテストの実施も担当します。Figmaでのデザインシステムの構築・運用と、エンジニアとの密な連携によるデザインの実装品質の担保も重要な業務です。',
  '音楽制作ツールのUIデザインは、一般的なWebアプリとは異なる専門性が求められる領域です。DAWや音楽制作ソフトのUIは独自の進化を遂げてきた歴史があり、その知見を活かしつつもAI時代の新しいインタラクションを模索するクリエイティブなポジションです。京都のアートシーンに触れながら、音楽とテクノロジーの交差点で革新的なUXを生み出す挑戦に参加できます。',
  '音楽制作UIは情報量が多く、限られた画面スペースに多数のコントロールを配置する必要があります。楽曲のタイムライン表示、パラメータ調整、エフェクトの可視化など、リアルタイムに変化する情報を分かりやすく表示するデザイン力が問われます。また、AIの自動生成機能とユーザーの手動操作をシームレスにつなぐインタラクション設計は、既存のデザインパターンでは解決できない新しい課題です。',
  'プロダクト開発チームに所属し、エンジニアと日々連携しながらデザインを進めます。サウンドエンジニアチームからの音楽的な要件をUIに落とし込む橋渡し役も担います。',
  '音楽制作ツールのUIデザインスキル、リアルタイムデータのビジュアライゼーション力、Figmaでのデザインシステム構築力、ユーザーリサーチの実践力が身につきます。',
  '[]'::jsonb,
  '["UI/UXデザイン","Figma","プロトタイピング","音楽テック","デザインシステム","ユーザーリサーチ"]'::jsonb,
  'UI/UXデザインの実務経験3年以上。Figmaでの実務デザイン経験。ユーザーリサーチの実施経験。',
  '音楽制作ソフト（DAW）のUIデザイン経験。音楽制作の経験。インタラクションデザインの知見。フロントエンド実装（HTML/CSS/JavaScript）の知識。',
  '京都府京都市中京区（週2日リモート可）',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  'フレックスタイム制（コアタイム11:00-15:00）標準労働時間8時間',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇',
  400, 650,
  '月給33万円〜54万円（固定残業代30時間分を含む）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙（喫煙専用室あり）',
  E'楽器・音楽機材購入補助\n書籍購入費補助\nデザインカンファレンス参加費補助\n副業OK',
  '週2日リモート可',
  '書類選考（ポートフォリオ必須） → デザイン課題 → 面接（2回） → 内定',
  now()
) ON CONFLICT DO NOTHING;

