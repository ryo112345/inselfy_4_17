  'd0100000-0000-0000-0000-000000000003',
  'b0000000-0000-0000-0000-000000000010',
  'c0010000-0000-0000-0000-000000000003',
  'b1000000-0000-0000-0000-000000000010',
  'open',
  'フィールドセールス｜食品流通の課題をテクノロジーで解決する提案営業',
  'セールス',
  '正社員',
  '2名',
  '食品卸売業者、飲食チェーン、食品メーカーに対して、食品サプライチェーン管理プラットフォームの提案営業を行います。食品流通の現場を深く理解し、在庫管理の効率化、受発注のデジタル化、食品ロス削減、トレーサビリティの確保など、クライアントの課題に合わせたソリューションを提案します。初回商談からクロージング、導入支援までを一貫して担当し、導入後のアップセル・クロスセルも推進します。九州エリアを中心に、食品流通のDXを推進するエバンジェリスト的な役割も期待しています。',
  'フードテック市場は急拡大しており、食品流通のDXは業界全体の喫緊の課題です。自分の提案がクライアントの食品ロス削減やコスト改善に直結するため、社会的意義の大きな営業活動ができます。福岡は農業・漁業の生産地と消費地が近接しており、食品流通のサプライチェーンを短距離で体感できる恵まれた環境です。プロダクトの初期フェーズのため、セールスの仕組みづくりからトップラインの成長を牽引できるポジションです。',
  '食品業界はデジタル化が遅れている領域が多く、既存の紙やFAXベースのオペレーションからの切り替えを提案する際には、丁寧な説明と段階的な導入プランが求められます。クライアントの業種（生産者、卸、飲食、小売）ごとに課題が異なるため、幅広い業界知識が必要です。また、食品特有の規制（HACCP等）への理解も重要です。',
  'ビジネスチーム4名で、セールスとカスタマーサクセスを兼務しながら活動しています。全員が「食」への強い関心を持ち、週末には食べ歩きリサーチを楽しむメンバーが揃っています。',
  '食品業界のセールスノウハウ、BtoB SaaSの営業力、サプライチェーンの業務知識、DX提案のコンサルティングスキルが身につきます。',
  '[]'::jsonb,
  '["法人営業","フードテック","SaaS","サプライチェーン","食品流通","新規開拓"]'::jsonb,
  '法人向け営業経験2年以上。新規開拓営業の経験。',
  '食品・飲食業界での営業経験。SaaSプロダクトの営業経験。物流・サプライチェーン関連の知識。コンサルティング営業の経験。',
  '福岡県福岡市（外勤あり）',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  'フレックスタイム制（コアタイム10:00〜15:00）標準労働時間8時間',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇',
  400, 700,
  '月給33万円〜58万円（固定残業代40時間分を含む）。インセンティブ制度あり。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙（喫煙専用室あり）',
  E'リモートワーク手当月2万円\n食事補助（提携飲食店で社割）\n交通費全額支給\n副業OK',
  'リモート併用（外勤中心）',
  '書類選考 → 一次面接 → 最終面接 → 内定',
  now()
) ON CONFLICT DO NOTHING;

-- 10-4: 企画
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
  required_qualifications, preferred_qualifications,
  work_location, work_location_change_scope, job_description_change_scope,
  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd0100000-0000-0000-0000-000000000004',
  'b0000000-0000-0000-0000-000000000010',
  'c0010000-0000-0000-0000-000000000002',
  'b1000000-0000-0000-0000-000000000010',
  'open',
  '事業企画｜フードテックの新規事業開発とアライアンス推進',
  '企画',
  '正社員',
  '1名',
  'フードクラフトの事業拡大に向けた新規事業企画とアライアンス戦略の策定・実行を担当していただきます。食品サプライチェーン領域での新たなサービス企画（需要予測AI、フードシェアリング、農業テックとの連携など）の市場調査・事業計画策定、食品メーカーや物流企業とのアライアンス交渉、自治体や農協との連携による地域展開の推進などが主な業務です。経営陣と連携して中長期の事業戦略を策定し、プロダクトチームと協力して新機能のビジネス要件を定義する役割も担います。食品業界のトレンドリサーチと競合分析を通じて、次の成長機会を常に探索するポジションです。',
  'フードテック市場は急成長中で、新規事業の機会が豊富にある環境です。経営陣との距離が近く、事業の方向性に関する意思決定に直接関与できます。食品業界のさまざまなプレイヤー（生産者、メーカー、物流、小売、飲食）と関わるため、業界全体のエコシステムを俯瞰する視座が得られます。福岡は食品関連のスタートアップが集積しており、コラボレーションの機会が多い環境です。行政との連携プロジェクトも複数進行中で、社会的インパクトの大きな仕事に携われます。',
  '新規事業企画は不確実性が高く、仮説検証を素早く繰り返す機動力が求められます。食品業界は多くの規制があるため、法規制を理解した上での事業設計が不可欠です。また、異業種のパートナーとのアライアンス交渉では、双方にとってのメリットを明確に提示する交渉力が試されます。限られた経営リソースの中で優先順位を判断する力も重要です。',
  '経営企画室2名で、CEOと直接連携しながら活動しています。必要に応じてプロダクトチーム・ビジネスチームとプロジェクトを組成する柔軟な体制です。',
  '新規事業企画のスキル、アライアンス交渉力、食品業界のビジネス知識、事業計画策定の実践力が身につきます。',
  '[]'::jsonb,
  '["事業企画","新規事業","アライアンス","フードテック","市場調査","事業計画"]'::jsonb,
  '事業企画または経営企画の実務経験3年以上。市場調査・事業計画策定の経験。',
  '食品業界での業務経験。スタートアップでの事業開発経験。アライアンス交渉の経験。コンサルティングファームでの勤務経験。',
  '福岡県福岡市（リモート併用可）',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  'フレックスタイム制（コアタイム10:00〜15:00）標準労働時間8時間',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇',
  500, 850,
  '月給42万円〜71万円（固定残業代40時間分を含む）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙（喫煙専用室あり）',
  E'リモートワーク手当月2万円\n食事補助（提携飲食店で社割）\n書籍購入費補助\n副業OK',
  'リモート併用（週2日出社）',
  '書類選考 → 一次面接 → ケース面接 → 最終面接 → 内定',
  now()
) ON CONFLICT DO NOTHING;

