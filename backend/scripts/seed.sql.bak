  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd0070000-0000-0000-0000-000000000001',
  'b0000000-0000-0000-0000-000000000007',
  'c0007000-0000-0000-0000-000000000002',
  'b1000000-0000-0000-0000-000000000007',
  'open',
  'フロントエンドエンジニア｜学習体験を革新するインタラクティブUI開発',
  'エンジニア',
  '正社員',
  '1〜2名',
  'マナビコネクトのオンライン学習プラットフォームのフロントエンド開発を担当します。動画講義のプレイヤーUI、インタラクティブなクイズ・演習機能、学習進捗ダッシュボード、ライブ授業のリアルタイムインタラクション機能の実装が主な業務です。React/TypeScriptをメインの技術スタックとし、WebRTCを用いたリアルタイム通信やCanvas APIを活用したホワイトボード機能の開発にも取り組みます。アダプティブラーニングのフロントエンド実装として、学習者の理解度に応じてコンテンツを動的に変更する仕組みも構築します。',
  '教育という社会的意義の高い領域で、テクノロジーを活用して学習体験を根本から変えるプロダクト開発に携われます。動画プレイヤー、リアルタイム通信、Canvas描画など多様な技術領域に触れられるため、フロントエンドエンジニアとしてのスキルが幅広く向上します。京都という歴史と文化の街で、大学や教育機関との連携プロジェクトにも参加できます。',
  'リアルタイム通信やアダプティブラーニングの実装は、一般的なSPAの開発とは異なる技術的課題があります。数百人が同時参加するライブ授業のパフォーマンス最適化や、多様なデバイス・ブラウザでの安定動作の担保が求められます。教育現場のフィードバックを素早くプロダクトに反映するアジリティも重要です。',
  'フロントエンドチーム5名で、学習者向けUIとインストラクター向けUIを担当するメンバーに分かれています。教育への情熱を持つメンバーが揃っています。',
  'リアルタイム通信技術、アダプティブUI設計、動画プレイヤーの実装スキル、EdTechのドメイン知識が身につきます。',
  '[]'::jsonb,
  '["React","TypeScript","WebRTC","Canvas API","EdTech","リアルタイム通信"]'::jsonb,
  'フロントエンド開発経験3年以上。React/TypeScriptでの開発経験。',
  'WebRTCを用いたリアルタイム通信の実装経験。動画プレイヤーの開発経験。Canvas APIやWebGLの使用経験。教育業界での開発経験。',
  '京都府京都市（リモート併用可）',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  'フレックスタイム制（コアタイム10:00-15:00）標準労働時間8時間',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇',
  450, 750,
  '月給38万円〜63万円（固定残業代30時間分を含む）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙',
  E'リモートワーク手当月2万円\n書籍・オンライン学習費用月1万円補助\n自社プラットフォームの全コース無料受講\nカンファレンス参加費補助\n副業OK',
  'リモート併用（週2出社推奨）',
  '書類選考 → 技術面接（ポートフォリオレビュー含む） → コーディングテスト → 最終面接 → 内定',
  now()
) ON CONFLICT DO NOTHING;

-- 07-2. マーケティング
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
  required_qualifications, preferred_qualifications,
  work_location, work_location_change_scope, job_description_change_scope,
  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd0070000-0000-0000-0000-000000000002',
  'b0000000-0000-0000-0000-000000000007',
  'c0007000-0000-0000-0000-000000000003',
  'b1000000-0000-0000-0000-000000000007',
  'open',
  'マーケティング｜教育の未来を届けるグロースマーケティング',
  'マーケティング',
  '正社員',
  '1名',
  'マナビコネクトの学習プラットフォームのユーザー獲得とエンゲージメント向上を担当します。SEO/SEM、SNSマーケティング、コンテンツマーケティング、メールマーケティングを組み合わせた統合的な集客戦略を策定・実行します。学習者のファネル分析に基づくコンバージョン最適化、LTV向上施策の企画、パートナー教育機関との共同プロモーションも重要なミッションです。GA4やMixpanelを用いたデータ分析に基づく意思決定を重視しています。',
  '教育プラットフォームのマーケティングは、ユーザーの学習意欲や成長実感に寄り添う独特のアプローチが求められるため、一般的なSaaSマーケティングとは異なる面白さがあります。「学びたい」という純粋な動機を持つユーザーに価値を届ける仕事は、やりがいに溢れています。京都の大学や専門学校との連携プロモーションなど、地域に根ざしたマーケティング活動も経験できます。',
  'BtoCとBtoB（法人研修）の両方のマーケティングを並行して進める必要があります。教育サービスは受講開始までのリードタイムが長く、コンテンツの品質がリテンションに直結するため、短期的なグロースハックだけでは成果が出ません。学習者の成功体験をマーケティングコンテンツに変換する力が求められます。',
  'マーケティングチーム4名で、デジタルマーケティングとコンテンツ制作を担当しています。元教育系メディアの編集者が在籍し、教育コンテンツの企画力に強みがあります。',
  'EdTechのグロースマーケティングスキル、データドリブンマーケティング力、教育コンテンツマーケティングの知見が身につきます。',
  '[]'::jsonb,
  '["マーケティング","SEO","コンテンツマーケティング","グロースハック","GA4","EdTech"]'::jsonb,
  'デジタルマーケティング経験3年以上。SEO/SEMの実務経験。GA4等のアナリティクスツールの使用経験。',
  'EdTechまたはBtoCサービスのマーケティング経験。コンテンツマーケティングの企画・実施経験。SNSマーケティングの成功実績。',
  '京都府京都市（リモート併用可）',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  'フレックスタイム制（コアタイム10:00-15:00）標準労働時間8時間',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇',
  400, 700,
  '月給33万円〜58万円（固定残業代30時間分を含む）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙',
  E'リモートワーク手当月2万円\n書籍・オンライン学習費用月1万円補助\n自社プラットフォームの全コース無料受講\nカンファレンス参加費補助\n副業OK',
  'リモート併用（週2出社推奨）',
  '書類選考 → 一次面接 → マーケティング課題 → 最終面接 → 内定',
  now()
) ON CONFLICT DO NOTHING;

-- 07-3. 企画
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
  required_qualifications, preferred_qualifications,
  work_location, work_location_change_scope, job_description_change_scope,
  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd0070000-0000-0000-0000-000000000003',
  'b0000000-0000-0000-0000-000000000007',
  'c0007000-0000-0000-0000-000000000001',
  'b1000000-0000-0000-0000-000000000007',
  'open',
  '学習設計ディレクター｜テクノロジーと教育学の融合で最高の学びを創る',
  '企画',
  '正社員',
  '1名',
  'オンライン学習コースのカリキュラム設計とコンテンツディレクションを担当します。学習科学やインストラクショナルデザインの知見に基づき、効果的な学習体験を設計します。講師陣との協力による教材コンテンツの企画・制作進行、アダプティブラーニングの問題設計、学習効果の測定・分析も重要なミッションです。プログラミング、データサイエンス、ビジネススキルなど多様なカテゴリのコースを担当し、学習者の目標達成率向上を追求します。',
  '教育学の知見をテクノロジーと融合させて、従来の教育では実現できなかった学習体験を創り出す仕事です。大学教授や業界のトップランナーと直接協力してコンテンツを制作するため、幅広い分野の最先端の知見に触れられます。京都の大学や研究機関と連携した共同プロジェクトにも参画でき、教育の未来を形作る実感があります。',
  '専門性の異なる講師陣のコンテンツを、統一的な品質基準と学習設計フレームワークに沿って仕上げるディレクション力が必要です。オンライン学習特有の離脱率の高さに対処するため、エンゲージメントを維持する工夫を常に考えなければなりません。テクノロジーの制約の中で最適な学習体験を設計するバランス感覚も重要です。',
  'カリキュラム開発チーム6名で、プログラミング・ビジネス・クリエイティブのカテゴリ別に担当しています。元教員や教育学研究者が在籍しています。',
  'インストラクショナルデザインのスキル、教育コンテンツのディレクション力、学習効果測定の手法が身につきます。',
  '[]'::jsonb,
