UPDATE company_accounts SET
  headline = '災害から命と暮らしを守る、次世代の防災インフラを構築する',
  description = 'IoTセンサーネットワークとAI予測技術を組み合わせた防災プラットフォーム「ResiliOS」を開発・提供しています。河川水位、土壌水分量、建物振動などのリアルタイムデータを統合分析し、洪水や土砂災害の発生リスクを最大6時間前に予測。自治体向けの避難判断支援システムと住民向けの防災アプリを展開し、全国80以上の自治体に導入されています。阪神・淡路大震災の教訓を原点に、神戸から防災テクノロジーを発信しています。',
