-- 12-1: フロントエンドエンジニア
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
  required_qualifications, preferred_qualifications,
  work_location, work_location_change_scope, job_description_change_scope,
  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd0120000-0000-0000-0000-000000000001',
  'b0000000-0000-0000-0000-000000000012',
  'c0012000-0000-0000-0000-000000000001',
  'b1000000-0000-0000-0000-000000000012',
  'open',
  'フロントエンドエンジニア｜月間1000万PVのメディアを支えるWeb開発',
  'エンジニア',
  '正社員',
  '1〜2名',
  'メディアブリッジが運営する複数のWebメディア（ニュース、ライフスタイル、テクノロジー）のフロントエンド開発を担当していただきます。Next.jsを用いたSSR / ISRの最適化、Core Web Vitalsの改善、記事ページのリッチなレイアウトシステムの構築、広告表示の最適化、ABテスト基盤の開発などが主な業務です。月間1000万PV規模のトラフィックに耐えうるパフォーマンスと、読者の滞在時間を延ばすUXの両立を追求します。SEOとパフォーマンスの観点からの技術的な最適化にも取り組み、記事コンテンツの到達範囲を最大化するための技術基盤を構築します。',
  'メディア領域のフロントエンド開発は、パフォーマンス最適化とUX改善の効果が数字で明確に見えるため、技術的な改善のインパクトを実感しやすいポジションです。Next.jsのSSR / ISRを大規模に運用する経験は市場価値が高く、Web技術の深い理解を身につけられます。大阪のクリエイティブな文化の中で、編集チームやデザインチームと密に連携しながらメディアの体験を磨き上げる仕事です。複数メディアを横断するため、さまざまなジャンルのコンテンツに触れられる知的好奇心を刺激される環境です。',
  'メディアサイトではCore Web VitalsのスコアがSEOに直結するため、ミリ秒単位のパフォーマンス改善が求められます。広告配信スクリプトとページパフォーマンスのトレードオフの管理も重要な技術課題です。また、記事のリッチなレイアウト（埋め込み、インタラクティブチャート、動画等）を執筆者が自由に構成できるCMSの設計は複雑なエンジニアリングが必要です。',
  'エンジニアチーム6名で、フロントエンド3名・バックエンド2名・インフラ1名の構成です。週次の技術勉強会とコードレビューを重視するカルチャーです。',
  'Next.jsの大規模運用スキル、Webパフォーマンス最適化の深い知見、SEO技術の理解、メディアシステムの設計力が身につきます。',
  '[]'::jsonb,
  '["Next.js","TypeScript","React","Core Web Vitals","SEO","パフォーマンス","メディア"]'::jsonb,
  'React / Next.jsでのフロントエンド開発経験3年以上。Webパフォーマンス最適化の経験。',
  'SSR / ISRの実装経験。Core Web Vitalsの改善実績。SEOの技術的な知識。CMS開発の経験。大規模トラフィックサイトでの開発経験。',
  '大阪府大阪市（リモート併用可）',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  'フレックスタイム制（コアタイム11:00〜16:00）標準労働時間8時間',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇',
  500, 850,
  '月給42万円〜71万円（固定残業代40時間分を含む）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙（喫煙専用室あり）',
  E'リモートワーク手当月2万円\n書籍購入費全額補助\nカンファレンス参加費補助\n副業OK',
  'リモート併用（週2日出社）',
  '書類選考 → 技術面接（コーディング課題含む） → 最終面接 → 内定',
  now()
) ON CONFLICT DO NOTHING;

-- 12-2: 編集者
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
  required_qualifications, preferred_qualifications,
  work_location, work_location_change_scope, job_description_change_scope,
  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd0120000-0000-0000-0000-000000000002',
  'b0000000-0000-0000-0000-000000000012',
  'c0012000-0000-0000-0000-000000000002',
  'b1000000-0000-0000-0000-000000000012',
  'open',
  '編集者｜テクノロジーメディアの編集長候補として企画力を発揮',
  'その他',
  '正社員',
  '1名',
  'メディアブリッジが運営するテクノロジーメディアの編集業務全般を担当していただきます。記事企画の立案、ライターへの発注・ディレクション、原稿の編集・校正、取材記事のインタビュー実施、特集企画の設計、SNSでの拡散施策の企画などが主な業務です。月間300万PVのテクノロジーメディアで、AI、Web3、SaaS、スタートアップ、開発者カルチャーなど幅広いテーマを扱います。将来的には編集長として、メディア全体の編集方針策定とチームマネジメントを担っていただくことを期待しています。',
  'テクノロジー業界の第一線で活躍する人々への取材機会が豊富にあり、最先端のトレンドに常に触れられるポジションです。企画から公開までの全プロセスに関われるため、コンテンツ制作の全体像を把握できます。記事のPVやSNSでの反響を通じて、自分の企画力の成果を数字で実感できます。大阪を拠点にしつつ全国のテクノロジーコミュニティとの繋がりを構築でき、編集者としてのネットワークが大きく広がります。',
  'テクノロジー領域は専門性が高く、技術的な正確性を保ちながら一般読者にもわかりやすい記事を制作するバランス感覚が求められます。SNSでバズる記事とSEOで長期的にトラフィックを稼ぐ記事では企画のアプローチが異なり、メディアの成長戦略に合わせた使い分けが必要です。複数のライターを同時にマネジメントしながら品質を担保する能力も重要です。',
  '編集チーム5名（編集者3名、ライター2名）で、外部ライター30名と連携しています。全員がテクノロジーに対する強い関心を持ち、記事の品質にこだわるカルチャーです。',
  'テクノロジーメディアの編集スキル、取材・インタビュースキル、SEOライティングの知見、コンテンツマーケティングの実践力が身につきます。',
  '[]'::jsonb,
  '["編集","メディア","コンテンツ企画","取材","SEO","テクノロジー","ライティング"]'::jsonb,
  'Webメディアの編集経験3年以上。記事の企画・編集・校正の実務経験。テクノロジー分野への強い関心。',
  'テクノロジーメディアでの編集経験。取材・インタビュー記事の制作経験。SEOの知識。SNS運用の経験。編集チームのマネジメント経験。',
  '大阪府大阪市（リモート併用可）',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  'フレックスタイム制（コアタイム11:00〜16:00）標準労働時間8時間',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇',
  400, 700,
  '月給33万円〜58万円（固定残業代40時間分を含む）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙（喫煙専用室あり）',
  E'リモートワーク手当月2万円\n書籍購入費全額補助\nカンファレンス・イベント参加費補助\n副業OK',
  'リモート併用（週2日出社）',
  '書類選考 → 編集課題 → 面接（2回） → 内定',
  now()
) ON CONFLICT DO NOTHING;

-- 12-3: セールス（広告営業）
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
  required_qualifications, preferred_qualifications,
  work_location, work_location_change_scope, job_description_change_scope,
  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd0120000-0000-0000-0000-000000000003',
  'b0000000-0000-0000-0000-000000000012',
  'c0012000-0000-0000-0000-000000000003',
  'b1000000-0000-0000-0000-000000000012',
  'open',
  '広告営業｜メディアの収益エンジンとしてスポンサーシップを提案',
  'セールス',
  '正社員',
  '1名',
  'メディアブリッジが運営する複数のWebメディアの広告営業を担当していただきます。純広告、タイアップ記事、スポンサードコンテンツ、イベント協賛など多彩な広告商品の提案営業を行います。広告主の課題ヒアリングから企画立案、社内の編集チームやデザインチームとの連携による広告コンテンツの制作ディレクション、効果測定レポートの作成まで一貫して担当します。新規広告主の開拓と既存クライアントのリピート促進の両方を推進し、メディアの収益基盤を強化するポジションです。プログラマティック広告の運用最適化にも携わります。',
  'テクノロジー、ライフスタイル、ニュースという3つのメディアを横断した広告提案ができるため、広告主の多様なニーズに応えられる幅広い商材を持っています。タイアップ記事の企画では編集チームと協力して質の高いコンテンツを制作でき、単なる広告枠売りではないクリエイティブな営業が可能です。大阪の広告業界は東京に比べてコミュニティが密で、業界内のネットワーク構築がしやすい環境です。',
  'デジタル広告市場は競争が激しく、ディスプレイ広告の単価は下落傾向にあります。そのため、記事広告やイベント協賛などの高付加価値商品の企画・提案力が重要です。広告主のROI期待値と編集部のコンテンツ品質基準の両方を満たすバランス感覚が求められます。また、個人情報保護の強化に伴う広告配信環境の変化にも対応する必要があります。',
  'セールスチーム4名で、業種別に担当を分けています。編集チーム・デザインチームとの連携が密で、広告コンテンツの企画会議には全チームが参加します。',
  'メディア広告営業のスキル、タイアップ記事の企画力、広告効果測定の知見、クライアントリレーションシップの構築力が身につきます。',
  '[]'::jsonb,
  '["広告営業","メディア","タイアップ","スポンサーシップ","デジタル広告","企画営業"]'::jsonb,
  '広告営業またはメディア営業の実務経験3年以上。法人向け提案営業の経験。',
  'Webメディアの広告営業経験。タイアップ記事の企画・ディレクション経験。デジタルマーケティングの知識。テクノロジー業界の知見。',
  '大阪府大阪市（外勤あり）',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  'フレックスタイム制（コアタイム11:00〜16:00）標準労働時間8時間',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇',
  400, 750,
  '月給33万円〜63万円（固定残業代40時間分を含む）。インセンティブ制度あり。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
