  'd01b0000-0000-0000-0000-000000000002',
  'b0000000-0000-0000-0000-00000000001b',
  'c001b000-0000-0000-0000-000000000002',
  'b1000000-0000-0000-0000-00000000001b',
  'open',
  'フィールドエンジニア｜農業現場でIoTセンサーとロボットの導入・運用を支援',
  'その他',
  '正社員',
  '1名',
  '農業用IoTセンサーと自律型ロボットの現場への導入・設置・運用支援を担当していただきます。土壌センサー、気象観測装置、カメラシステムの設置と校正、データ通信環境（LoRaWAN、LTE）の構築、農業ロボットの初期セットアップとオペレーター向けトレーニング、定期メンテナンスが主な業務です。圃場でのトラブルシューティングや、センサーデータの品質確認・分析も担当します。農家の方々と信頼関係を築きながら、テクノロジーの価値を現場に浸透させる重要な役割です。',
  '最先端のアグリテック技術を農業現場に届ける最前線のポジションです。オフィスワークとフィールドワークのバランスが取れた働き方で、四季折々の農村風景の中で仕事ができます。農家の方々から直接「助かっている」という声をいただけるやりがいのある仕事です。フィールドエンジニアとしてのスキルはロボティクスやIoTの分野で幅広く活かせ、将来のキャリアの幅が広がります。',
  '農業現場は通信環境が不安定なことが多く、IoTデバイスの安定運用には創意工夫が必要です。雨天、降雪、強風などの厳しい気象条件の中での作業も発生します。農家の方々はITに不慣れなケースが多く、専門用語を使わずに分かりやすく説明するコミュニケーション力が求められます。また、農繁期は問い合わせが集中するため、迅速な対応と優先順位づけが重要になります。',
  'フィールドエンジニアチーム3名で、東北6県を分担してカバー。農機開発チームと密に連携し、現場で発見した課題を開発にフィードバックしています。',
  'IoTセンサーの設置・運用保守スキル、農業ドメインの知識、通信環境（LoRaWAN, LTE）の構築力、現場でのトラブルシューティング力が身につきます。',
  '[]'::jsonb,
  '["IoT","センサー","フィールドエンジニア","LoRaWAN","農業","メンテナンス"]'::jsonb,
  'フィールドエンジニアまたはカスタマーエンジニアの実務経験2年以上。ハードウェアの設置・メンテナンスの経験。普通自動車免許。',
  '農業機械の操作経験。IoTセンサーの運用経験。ネットワーク（LAN/WAN）の構築経験。電子工作の経験。',
  '宮城県仙台市青葉区（東北地方への出張が週2〜3日）',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  '9:00〜18:00（実働8時間）',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇',
  380, 550,
  '月給32万円〜46万円（固定残業代30時間分を含む）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙（喫煙専用室あり）',
  E'出張手当\n社用車貸与\n工具・機材購入補助\n副業OK',
  '原則出社（出張中心）',
  '書類選考 → 面接（2回） → 最終面接 → 内定',
  now()
) ON CONFLICT DO NOTHING;

-- 1b-3. 営業
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
  required_qualifications, preferred_qualifications,
  work_location, work_location_change_scope, job_description_change_scope,
  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd01b0000-0000-0000-0000-000000000003',
  'b0000000-0000-0000-0000-00000000001b',
  'c001b000-0000-0000-0000-000000000003',
  'b1000000-0000-0000-0000-00000000001b',
  'open',
  '法人営業｜アグリテックで農業の高収益化を支援するソリューション提案',
  'セールス',
  '正社員',
  '1〜2名',
  '農業法人、JA（農業協同組合）、自治体の農業振興部門に対する当社アグリテックソリューションの提案営業を担当していただきます。IoTセンサーによる精密農業ソリューション、自律型農業ロボットの導入提案、収穫データ分析による経営支援サービスの営業が主な業務です。農業展示会やスマート農業のセミナーでのリード獲得、補助金（スマート農業実証プロジェクト等）の申請支援、導入事例の取材・コンテンツ化にも携わります。農業現場を訪問し、生産者の課題をヒアリングした上で最適なソリューションを提案する、コンサルティング要素の強い営業です。',
  'スマート農業は国策として推進されており、補助金制度も充実している追い風の市場です。農業法人の大規模化が進む中、テクノロジーによる生産性向上へのニーズは年々高まっています。仙台を拠点に東北の農業大県（秋田、山形、岩手等）をカバーするため、日本の食料生産の中心地で農業の未来を変える実感を得られるポジションです。農家の方々との信頼関係から生まれる長期的な取引が多く、やりがいのある営業活動ができます。',
  '農業は地域性が強く、作物や農法が地域によって大きく異なるため、各地域の農業特性を理解した提案が求められます。初期投資が大きいIoT/ロボット機器の導入は、農家にとってリスクのある意思決定であり、ROIを明確に示す説得力のある提案が必要です。補助金の申請期限や農繁期のスケジュールに合わせた営業活動のタイミング管理も重要で、年間を通じた計画的なアプローチが求められます。',
  '営業チーム3名で、農業法人・JA・自治体の各チャネルを分担。フィールドエンジニアチームと連携し、導入後のサポートまで一貫した顧客体験を提供しています。',
  'アグリテック領域の法人営業スキル、農業ドメインの専門知識、補助金申請支援のノウハウ、コンサルティング営業力が身につきます。',
  '[]'::jsonb,
  '["法人営業","アグリテック","スマート農業","IoT","BtoB","BtoG"]'::jsonb,
  '法人営業経験2年以上。顧客への提案営業の経験。普通自動車免許。',
  '農業関連（JA、農機メーカー、種苗会社等）での営業経験。IT/IoT関連の営業経験。自治体向け営業の経験。補助金申請の経験。',
  '宮城県仙台市青葉区（東北地方への出張が多い）',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  '9:00〜18:00（実働8時間）',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇',
  380, 600,
  '月給32万円〜50万円（固定残業代30時間分を含む、別途インセンティブあり）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙（喫煙専用室あり）',
  E'営業インセンティブ制度\n社用車貸与\n出張手当\n副業OK',
  '週1日リモート可',
  '書類選考 → 面接（2回） → 最終面接 → 内定',
  now()
) ON CONFLICT DO NOTHING;

-- 1b-4. データサイエンティスト
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
  required_qualifications, preferred_qualifications,
  work_location, work_location_change_scope, job_description_change_scope,
  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd01b0000-0000-0000-0000-000000000004',
  'b0000000-0000-0000-0000-00000000001b',
  'c001b000-0000-0000-0000-000000000001',
  'b1000000-0000-0000-0000-00000000001b',
  'open',
  'データサイエンティスト｜衛星画像×IoTデータで農業の収量予測モデルを構築',
  'エンジニア',
  '正社員',
  '1名',
  '農業データの分析・予測モデルの構築を担当していただきます。IoTセンサーから収集される土壌データ、気象データ、衛星画像データを組み合わせた作物の生育予測モデルの開発が中心的な業務です。収量予測、病害虫発生予測、最適な施肥タイミングの推定など、農業経営の意思決定を支援するデータ分析を行います。また、農業ロボットの画像認識モデル（作物の検出・分類・成熟度判定）の開発にも携わります。分析結果をダッシュボードで可視化し、農家が直感的に理解できる形で提供する仕組みづくりも重要なミッションです。',
  '農業データサイエンスは、理論と実践が直結する非常にやりがいのある分野です。自分が構築したモデルが実際の農業経営を改善し、食料生産に貢献する実感を得られます。東北の多様な作物データにアクセスでき、稲作、果樹、野菜など幅広い農業領域のデータ分析経験を積めます。東北大学との共同研究も進行中で、学術的な知見も取り入れながら実用的なモデル開発ができる環境です。',
  '農業データはノイズが多く、センサーの故障や通信エラーによる欠損データの処理が必要です。また、農業は年に1〜2回しか収穫がないため、学習データの蓄積に時間がかかり、少ないデータで精度の高いモデルを構築する工夫が求められます。衛星画像の解像度やタイミングの制約、気象の不確実性など、農業特有の変数の多さも技術的なチャレンジです。',
  '農機開発チームに所属し、ロボティクスエンジニアと連携して画像認識モデルの開発を行います。東北大学の研究者とも定期的にディスカッションしています。',
  '農業データサイエンスの専門知識、衛星画像解析スキル、時系列予測モデルの構築力、IoTデータパイプラインの設計力が身につきます。',
  '[]'::jsonb,
  '["Python","機械学習","データサイエンス","衛星画像","IoT","農業","深層学習"]'::jsonb,
  'データサイエンスまたは機械学習の実務経験2年以上。Python での分析・モデル構築経験。統計学の基礎知識。',
  '画像認識モデルの開発経験。時系列データの分析経験。衛星画像（リモートセンシング）の解析経験。農学に関する知識。',
  '宮城県仙台市青葉区（フルリモート勤務可）',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  'フレックスタイム制（コアタイムなし）標準労働時間8時間',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇',
  500, 800,
  '月給42万円〜67万円（固定残業代30時間分を含む）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙（喫煙専用室あり）',
  E'リモートワーク手当月2万円\n学会参加費補助\n論文発表奨励金\n副業OK',
  'フルリモート',
  '書類選考 → 技術面接（分析課題含む） → 最終面接 → 内定',
  now()
) ON CONFLICT DO NOTHING;

-- ============================================================
-- 1c. レジリア（防災テック / 神戸市）
-- ============================================================

-- 1c-1. AIエンジニア（防災AI）
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
  required_qualifications, preferred_qualifications,
  work_location, work_location_change_scope, job_description_change_scope,
  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd01c0000-0000-0000-0000-000000000001',
  'b0000000-0000-0000-0000-00000000001c',
  'c001c000-0000-0000-0000-000000000001',
  'b1000000-0000-0000-0000-00000000001c',
  'open',
  'AIエンジニア｜災害予測AIで命を守る防災テクノロジーの最前線',
  'エンジニア',
  '正社員',
  '1〜2名',
  '災害予測・被害推定AIモデルの研究開発を担当していただきます。気象データ、河川水位データ、地形データ、SNSの災害関連投稿などの多種多様なデータを統合し、洪水浸水予測、土砂災害リスク評価、地震被害推定のAIモデルを構築します。リアルタイム推論パイプラインの設計・実装、モデルの精度検証、新しいデータソースの活用検討も重要な業務です。防災科学技術研究所や気象庁のデータとの連携、自治体の防災計画への活用を見据えたモデル設計が求められます。神戸は阪神・淡路大震災の経験から防災意識が高く、防災テックの拠点として最適な環境です。',
  '防災AIは人命に直結するテクノロジーであり、社会的インパクトの大きさは他の分野と比較しても群を抜いています。神戸は防災分野の研究機関や企業が集積しており、最先端の知見にアクセスしやすい環境です。気象庁や防災科研のオープンデータが充実しており、大規模なデータセットを用いた実践的な機械学習の経験を積めます。自治体との連携プロジェクトが多く、自分が開発したAIが実際の防災計画に組み込まれる達成感があります。',
  '災害はまれにしか発生しないため、学習データの不足が最大の技術課題です。シミュレーションデータの活用やデータ拡張など、少ないデータで高精度のモデルを構築する工夫が求められます。また、防災AIの予測は避難勧告の根拠にもなり得るため、偽陽性と偽陰性のバランスに対する慎重な判断が必要です。モデルの説明可能性（XAI）への要求も高く、ブラックボックスではない透明性のあるAI設計が求められます。',
  '防災AIチーム3名で、水害予測・土砂災害予測・地震被害推定の各モデルを担当。防災科研や大学の研究者との共同研究も複数進行中です。',
  '防災AI/災害予測モデルの開発スキル、時空間データの分析力、リアルタイム推論パイプラインの構築力、防災分野のドメイン知識が身につきます。',
  '[]'::jsonb,
  '["Python","機械学習","深層学習","防災","AI","GIS","時系列予測"]'::jsonb,
  '機械学習の実務経験または研究経験3年以上。Python での機械学習モデル構築経験。時系列データまたは空間データの分析経験。',
  '気象データ・河川データの分析経験。GIS（地理情報システム）の知識。防災・気象に関するドメイン知識。学会発表または論文執筆の経験。',
  '兵庫県神戸市中央区（週2日リモート可）',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  'フレックスタイム制（コアタイム10:00-15:00）標準労働時間8時間',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇',
  550, 900,
  '月給46万円〜75万円（固定残業代30時間分を含む）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙（喫煙専用室あり）',
  E'学会参加費補助\n論文発表奨励金\n書籍購入費全額補助\n副業OK',
  '週2日リモート可',
  '書類選考 → 技術面接（分析課題含む） → 最終面接 → 内定',
  now()
) ON CONFLICT DO NOTHING;

-- 1c-2. 組み込みエンジニア（防災IoT）
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
  required_qualifications, preferred_qualifications,
  work_location, work_location_change_scope, job_description_change_scope,
  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd01c0000-0000-0000-0000-000000000002',
  'b0000000-0000-0000-0000-00000000001c',
  'c001c000-0000-0000-0000-000000000002',
  'b1000000-0000-0000-0000-00000000001c',
  'open',
  '組み込みエンジニア｜過酷な環境で確実に動く防災IoTセンサーを開発',
  'エンジニア',
  '正社員',
  '1名',
  '防災用IoTセンサーのハードウェア・ファームウェア開発を担当していただきます。河川水位センサー、傾斜計（土砂災害検知）、地震計などの防災センサーの回路設計、ファームウェア開発、省電力設計、耐環境設計が主な業務です。LPWA（LoRaWAN, LTE-M）を用いた低消費電力通信の実装、太陽光パネルとバッテリーによる自立電源の設計、防水・防塵筐体の設計にも携わります。災害時にも確実にデータを送信し続けるための冗長設計と、コスト制約の中での最適設計が求められるポジションです。',
  '自分が設計したセンサーが実際の災害現場で命を守るための情報を送り続けるという、エンジニアとして最も誇りを持てる仕事の一つです。防災IoTは屋外の過酷な環境で長期間安定動作させる必要があり、民生品とは異なる高い設計スキルが身につきます。神戸の防災テックエコシステムの中で、大学・研究機関・自治体との連携から得られる知見も豊富です。',
  '河川敷や山間部など、メンテナンスが容易でない場所に設置されるため、数年間無人で安定動作する設計が求められます。電源確保が困難な場所でのバッテリー駆動設計、通信が不安定な環境でのデータ送信保証、大雨・洪水・落雷などの極端な環境条件への耐性確保が技術的な課題です。また、自治体への納品時には各種規格認証（技適、CE等）の取得が必要で、設計段階からの規格適合性の考慮が求められます。',
  'ハードウェア開発チーム3名で、電子回路設計・ファームウェア開発・筐体設計の各領域を担当。防災AIチームとの連携でセンサーとAIを一体的に開発しています。',
  '防災IoTセンサーの設計・開発スキル、省電力設計の専門知識、LPWA通信の実装力、耐環境設計の知見が身につきます。',
  '[]'::jsonb,
  '["組み込み","C","ファームウェア","IoT","LoRaWAN","回路設計","防災"]'::jsonb,
  '組み込みシステムまたは電子回路の設計経験3年以上。C言語でのファームウェア開発経験。回路設計（アナログ・デジタル）の経験。',
  'LPWA（LoRaWAN, LTE-M等）の通信モジュール実装経験。省電力設計の経験。防水・防塵規格（IP67等）に準拠した筐体設計経験。技適・CE等の規格認証取得経験。',
  '兵庫県神戸市中央区（フィールドテスト時は出張あり）',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  '9:00〜18:00（実働8時間）',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇',
  500, 800,
  '月給42万円〜67万円（固定残業代30時間分を含む）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙（喫煙専用室あり）',
  E'学会参加費補助\n工具・計測機器購入補助\n引越し手当（入社時）\n副業OK',
  '原則出社（一部リモート相談可）',
  '書類選考 → 技術面接 → 最終面接 → 内定',
  now()
) ON CONFLICT DO NOTHING;

-- 1c-3. 自治体連携営業
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
  required_qualifications, preferred_qualifications,
  work_location, work_location_change_scope, job_description_change_scope,
  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd01c0000-0000-0000-0000-000000000003',
  'b0000000-0000-0000-0000-00000000001c',
  'c001c000-0000-0000-0000-000000000003',
  'b1000000-0000-0000-0000-00000000001c',
  'open',
  '自治体営業｜防災テクノロジーで地域の安全を守るパブリックセールス',
  'セールス',
  '正社員',
  '1名',
  '全国の自治体に対する防災テクノロジーソリューションの提案営業を担当していただきます。市区町村の防災担当部署へのアプローチ、防災計画の策定支援、IoTセンサー・AIシステムの導入提案、プロポーザル（公募型提案競技）への参加が主な業務です。防災に関する国や県の補助金情報の収集と活用提案、防災訓練やシンポジウムでのデモンストレーション、導入自治体の成功事例の横展開にも取り組みます。内閣府や国土交通省の防災関連政策の動向をウォッチし、自社の事業戦略に反映する情報収集活動も重要な役割です。',
  '自治体向けの営業は、受注額が大きく社会的なインパクトも大きい仕事です。自分の提案が自治体の防災計画に組み込まれ、地域住民の安全を守ることに直結するという大きなやりがいがあります。神戸は阪神・淡路大震災の経験から防災先進都市として知られ、防災テック企業のハブとなっており、業界のネットワーク構築に有利な立地です。全国の自治体を担当するため、各地域の防災課題に触れられる幅広い経験ができます。',
  '自治体の調達プロセスは民間企業とは大きく異なり、予算サイクル、議会承認、プロポーザルなど独特の商慣習を理解する必要があります。防災部門の担当者はITに不慣れなケースもあり、技術的な内容を分かりやすく伝えるスキルが求められます。また、災害は地域によって種類やリスクが異なるため、各自治体の地域特性に合わせたカスタマイズ提案が必要です。長い営業サイクルに対する忍耐力と戦略的なアプローチが問われます。',
  '自治体連携チーム3名で、近畿圏・中部圏・関東圏の各エリアを分担。防災AIチーム・ハードウェアチームと連携し、技術的なバックアップを受けながら提案活動を行います。',
  '自治体向け営業（BtoG）の専門スキル、防災分野のドメイン知識、プロポーザル提案書の作成力、公共政策の理解力が身につきます。',
  '[]'::jsonb,
  '["BtoG","自治体営業","防災","公共政策","プロポーザル","IoT"]'::jsonb,
  '法人営業または官公庁向け営業の経験3年以上。提案書・企画書の作成スキル。全国出張が可能な方。',
  '自治体向けの営業経験。防災・災害対策に関する知識。ITソリューションの提案営業経験。防災士資格。',
  '兵庫県神戸市中央区（全国出張あり）',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  '9:00〜18:00（実働8時間）',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇',
  450, 700,
  '月給38万円〜58万円（固定残業代30時間分を含む）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙（喫煙専用室あり）',
  E'出張手当\n防災士資格取得支援\n書籍購入費補助\n副業OK',
  '週1日リモート可',
  '書類選考 → 面接（2回） → 最終面接 → 内定',
  now()
) ON CONFLICT DO NOTHING;

-- 1c-4. プロダクトマネージャー
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
  required_qualifications, preferred_qualifications,
  work_location, work_location_change_scope, job_description_change_scope,
  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd01c0000-0000-0000-0000-000000000004',
  'b0000000-0000-0000-0000-00000000001c',
  'c001c000-0000-0000-0000-000000000003',
  'b1000000-0000-0000-0000-00000000001c',
  'open',
  'プロダクトマネージャー｜防災DXプラットフォームの成長を牽引するPdM',
  'PM',
  '正社員',
  '1名',
  '防災DXプラットフォームのプロダクトマネジメント全般を担当していただきます。自治体の防災担当者向けダッシュボード、住民向け防災アプリ、IoTセンサー管理システムの3つのプロダクトのロードマップ策定、機能要件定義、優先順位づけ、リリース管理が主な業務です。自治体や住民へのユーザーリサーチを通じた課題発見、競合分析と市場調査、KPIの設定とモニタリングも重要な役割です。エンジニアチーム・AIチーム・営業チームの間に立ち、技術的な実現可能性と市場ニーズのバランスを取りながらプロダクトの方向性を決定します。',
  '防災テックのプロダクトマネジメントは、人命に関わるシステムを設計するという責任とやりがいの両方を兼ね備えたポジションです。AI、IoT、モバイルアプリという複数の技術領域にまたがるプロダクトを横断的にマネジメントする経験は、PdMとしてのスキルを大きく広げます。自治体という特殊なユーザーセグメントに対するプロダクト設計の知見は、GovTech領域全般で活かせるキャリア資産になります。',
  '自治体の防災ニーズは災害の種類や地域特性によって多様であり、汎用的なプロダクトとカスタマイズのバランスが難しい課題です。また、防災システムは災害発生時に確実に動作する必要があり、通常のSaaSとは異なる可用性要件への対応が求められます。さらに、自治体の予算サイクルに合わせた機能リリースの計画や、防災関連法規の改正への対応など、公共セクター特有の制約の中でのプロダクト開発が必要です。',
  '自治体連携チームに所属しつつ、防災AIチーム・ハードウェア開発チームを横断的にマネジメント。全チームのリソース配分とロードマップの整合を取る役割です。',
  '防災テックのプロダクトマネジメントスキル、GovTech領域のプロダクト設計力、複数プロダクトの統合的ロードマップ管理力、ユーザーリサーチの実践力が身につきます。',
  '[]'::jsonb,
  '["プロダクトマネジメント","防災","GovTech","SaaS","IoT","AI","UXリサーチ"]'::jsonb,
  'プロダクトマネジメントの実務経験3年以上。エンジニアチームとの協業によるプロダクト開発経験。ユーザーリサーチの実施経験。',
  'BtoG（自治体向け）プロダクトの企画・開発経験。AI/IoT関連プロダクトのPM経験。防災・災害対策に関する知識。技術バックグラウンド（ソフトウェア開発経験）。',
  '兵庫県神戸市中央区（週2日リモート可）',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  'フレックスタイム制（コアタイム10:00-15:00）標準労働時間8時間',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇',
  550, 850,
  '月給46万円〜71万円（固定残業代30時間分を含む）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙（喫煙専用室あり）',
  E'防災士資格取得支援\n書籍購入費補助\nカンファレンス参加費補助\n副業OK',
  '週2日リモート可',
  '書類選考 → 面接（2回） → 最終面接 → 内定',
  now()
) ON CONFLICT DO NOTHING;

