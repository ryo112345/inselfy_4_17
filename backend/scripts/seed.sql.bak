  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd0160000-0000-0000-0000-000000000002',
  'b0000000-0000-0000-0000-000000000016',
  'c0016000-0000-0000-0000-000000000002',
  'b1000000-0000-0000-0000-000000000016',
  'open',
  '法人営業｜InsurTech保険商品で企業の福利厚生を革新するセールス',
  'セールス',
  '正社員',
  '2名',
  '当社のInsurTech保険商品を法人顧客に提案する営業活動全般をお任せします。テレマティクスやウェアラブルデータを活用した健康経営型の団体保険、従業員向けカスタマイズ保険プランなど、従来にはない保険商品の価値を企業の人事部門や経営層に伝え、導入を推進します。新規顧客の開拓からニーズヒアリング、提案書作成、契約締結、導入後のフォローアップまでを一貫して担当。マーケティングチームと連携した展示会やセミナーでのリード獲得活動にも参加していただきます。業界の慣習にとらわれないソリューション営業が求められるポジションです。',
  'InsurTechという成長領域で、従来の保険営業とは一線を画すソリューション営業を経験できます。商品の説明だけでなく、データに基づく健康経営の提案や、従業員エンゲージメント向上の観点からの保険活用など、コンサルティング要素の強い営業スタイルが身につきます。スタートアップならではの営業戦略の立案にも関われ、組織の成長とともに自身のキャリアも大きく広がるポジションです。',
  'InsurTech保険商品はまだ市場認知が低いため、顧客の理解を得るまでのハードルがあります。従来の保険と何が違うのかを分かりやすく伝え、導入のメリットを数値で示す論理的なプレゼン力が求められます。また、保険業界の規制を踏まえた適切な営業活動が必要であり、コンプライアンス意識も重要です。新しい市場を自らの手で切り拓いていく開拓者精神が問われるポジションです。',
  '営業企画チーム3名で、関西圏の法人顧客を中心に活動。顧客ごとの課題に合わせたカスタム提案を重視しています。チーム内での情報共有を密に行い、成功事例のナレッジを蓄積しています。',
  'InsurTech領域のソリューション営業スキル、法人向けコンサルティング営業力、保険業界の専門知識、データドリブンな提案力が身につきます。',
  '[]'::jsonb,
  '["法人営業","保険","InsurTech","ソリューション営業","健康経営","BtoB"]'::jsonb,
  '法人営業経験3年以上。顧客課題のヒアリングから提案・クロージングまでの一連の営業プロセスの経験。',
  '保険業界での営業経験。SaaS・テック企業での法人営業経験。保険募集人資格。コンサルティングファームでの実務経験。',
  '大阪府大阪市中央区（直行直帰あり）',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  '9:00〜18:00（実働8時間）',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇',
  450, 750,
  '月給38万円〜63万円（固定残業代30時間分を含む、別途インセンティブあり）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙（喫煙専用室あり）',
  E'営業インセンティブ制度\n保険資格取得支援\n書籍購入費補助\n副業OK',
  '週1日リモート可',
  '書類選考 → 面接（2回） → 最終面接 → 内定',
  now()
) ON CONFLICT DO NOTHING;

-- 16-3. システムエンジニア
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
  required_qualifications, preferred_qualifications,
  work_location, work_location_change_scope, job_description_change_scope,
  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd0160000-0000-0000-0000-000000000003',
  'b0000000-0000-0000-0000-000000000016',
  'c0016000-0000-0000-0000-000000000003',
  'b1000000-0000-0000-0000-000000000016',
  'open',
  'バックエンドエンジニア｜保険基幹システムをモダン技術で刷新するInsurTech開発',
  'エンジニア',
  '正社員',
  '1〜2名',
  '保険契約管理・保険料計算・保険金支払いの基幹システムをマイクロサービスアーキテクチャで再構築するプロジェクトのバックエンド開発を担当していただきます。Go言語を中心に、gRPCによるサービス間通信、PostgreSQLでのデータ管理、Kubernetesでのコンテナオーケストレーションなど、モダンな技術スタックで保険業界のレガシーシステムを刷新します。テレマティクスデータのリアルタイム処理パイプラインの構築や、動的プライシングAPIの開発にも携わっていただきます。金融業界特有のセキュリティ要件やコンプライアンス対応も重要な業務です。',
  '保険業界のDXを技術面から推進する最前線に立てます。レガシーシステムのモダナイゼーションという実践的な経験に加え、InsurTech特有のリアルタイムデータ処理やMLモデルのサービング基盤の構築など、先端的なエンジニアリングに取り組めます。金融業界のセキュリティ基準を満たすシステム設計のノウハウも得られ、エンジニアとしての市場価値を大きく高められる環境です。',
  '金融システムに求められる高い信頼性と可用性を担保しつつ、スタートアップとしてのスピード感を保つバランスが最大の課題です。保険計算ロジックの正確性は収益に直結するため、テストカバレッジと品質保証に高い基準が求められます。また、既存の保険業界のデータフォーマットやプロトコルとの互換性を保ちながらモダンなアーキテクチャに移行する技術的な判断力も必要です。',
  'システム開発チーム3名で、基幹システム・データパイプライン・フロントエンドの各領域をカバー。コードレビューとペアプログラミングを重視する文化です。',
  'Go言語でのマイクロサービス設計スキル、金融システムのセキュリティ設計知識、Kubernetesでのコンテナ運用力、リアルタイムデータ処理の実装力が身につきます。',
  '[]'::jsonb,
  '["Go","Kubernetes","gRPC","PostgreSQL","マイクロサービス","金融システム","InsurTech"]'::jsonb,
  'バックエンド開発経験3年以上。Go, Java, Kotlin のいずれかでの実務経験。RDBMSを用いたシステム開発経験。',
  'マイクロサービスアーキテクチャの設計・運用経験。Kubernetes環境での開発経験。金融業界のシステム開発経験。セキュリティに関する知見。',
  '大阪府大阪市中央区（フルリモート勤務可）',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  'フレックスタイム制（コアタイムなし）標準労働時間8時間',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇',
  550, 900,
  '月給46万円〜75万円（固定残業代45時間分を含む）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙（喫煙専用室あり）',
  E'リモートワーク手当月2万円\n書籍購入費全額補助\nカンファレンス参加費補助\n資格取得支援制度\n副業OK',
  'フルリモート',
  '書類選考 → 技術面接（コーディングテスト含む） → 最終面接 → 内定',
  now()
) ON CONFLICT DO NOTHING;

