  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd0040000-0000-0000-0000-000000000002',
  'b0000000-0000-0000-0000-000000000004',
  'c0004000-0000-0000-0000-000000000003',
  'b1000000-0000-0000-0000-000000000004',
  'open',
  'アカウントディレクター｜デザインの力でクライアントの課題を解決する提案営業',
  'セールス',
  '正社員',
  '1名',
  'クライアント企業に対して、デザインの力で事業課題を解決する提案を行います。ブランディング、UI/UXデザイン、Webサイト制作、デザインシステム構築など、ノヴァクリエイティブが持つ幅広いサービスを組み合わせた提案を策定します。新規クライアントの開拓からリピート案件の獲得まで、クライアントとの長期的な信頼関係構築を通じて売上を拡大していきます。プロジェクト開始後はクリエイティブチームとの橋渡し役として、クライアントの要望と制作物の品質を両立させるディレクションも担当します。',
  'デザインという無形のサービスの価値を企業経営の文脈で説明し、受注につなげるコンサルティング型の営業を経験できます。大手企業のブランド刷新や新規サービスのUI設計など、ビジネスインパクトの大きいプロジェクトに関われます。デザインの知見が自然と身につくため、将来的にはクリエイティブディレクターへのキャリアパスも開けています。',
  'デザインの価値をROIで示すことが求められるため、単なる「見た目の改善」ではなくビジネス成果につながる提案ストーリーを構築する力が必要です。クリエイティブチームの制作プロセスを理解し、適切な納期とコストを設定するプロジェクトマネジメント能力も不可欠です。',
  'クリエイティブディレクションチーム3名がアカウント担当として、それぞれ5〜10社のクライアントを持っています。デザイナーとの距離が近く、提案段階からクリエイティブチームと協力して動きます。',
  'デザインコンサルティング営業のスキル、クリエイティブディレクション力、クライアントリレーション構築力が身につきます。',
  '[]'::jsonb,
  '["アカウント営業","デザインコンサルティング","クリエイティブディレクション","ブランディング","提案営業","プロジェクトマネジメント"]'::jsonb,
  '法人向け営業経験3年以上。デザイン、広告、Web制作いずれかの業界での営業またはディレクション経験。',
  'クリエイティブエージェンシーでの営業経験。ブランディングプロジェクトの提案・進行経験。デザインの基礎知識。',
  '大阪府大阪市',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  'フレックスタイム制（コアタイム11:00-16:00）標準労働時間8時間',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇',
  450, 800,
  '月給38万円〜67万円（固定残業代30時間分を含む）。インセンティブ制度あり。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙',
  E'デザインツール・ソフトウェア費用全額負担\nカンファレンス参加費補助\n書籍購入費月1万円補助\n副業OK\n交通費全額支給',
  '出社（クライアント訪問あり）',
  '書類選考 → 一次面接 → 提案課題 → 最終面接 → 内定',
  now()
) ON CONFLICT DO NOTHING;

-- 04-3. デザイナー
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
