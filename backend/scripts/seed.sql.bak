  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd0090000-0000-0000-0000-000000000002',
  'b0000000-0000-0000-0000-000000000009',
  'c0009000-0000-0000-0000-000000000003',
  'b1000000-0000-0000-0000-000000000009',
  'open',
  '法人営業｜再エネ × テクノロジーで企業の脱炭素を加速する',
  'セールス',
  '正社員',
  '1〜2名',
  '製造業、商業施設、自治体に対して、グリーンフラックスの再生可能エネルギーマネジメントサービスの導入提案を行います。顧客の電力使用状況を分析し、太陽光発電の導入効果シミュレーション、電力コスト削減プランの策定、CO2排出量削減のロードマップ作成を通じて、脱炭素経営を支援します。PPA（電力購入契約）やオンサイト太陽光の提案、RE100対応のコンサルティングも重要な業務です。',
  '脱炭素は企業経営のトップアジェンダとなっており、経営層との商談機会が多いポジションです。「電力コストを年間20%削減しました」「CO2排出量を30%カットしました」など、環境と経済の両面で成果を出せるソリューション営業です。エネルギー政策や環境規制の最新動向に詳しくなれるため、サステナビリティ領域の専門家として市場価値が高まります。福岡から九州・中国・四国エリアを担当します。',
  'エネルギー業界は規制が複雑で、電力市場の仕組みや各種補助金制度の理解が不可欠です。顧客の意思決定には設備投資の回収期間やROIの明確な提示が必要で、技術とファイナンスの両面の提案力が求められます。自治体案件では入札プロセスへの対応も必要です。',
  '法人営業チーム5名で、九州を拠点に西日本エリアを担当しています。元電力会社出身者や環境コンサルタント出身者が在籍しています。',
  'エネルギー業界の法人営業スキル、脱炭素コンサルティング力、PPA等の電力契約の知識が身につきます。',
  '[]'::jsonb,
  '["法人営業","再生可能エネルギー","脱炭素","PPA","サステナビリティ","エネルギーマネジメント"]'::jsonb,
  '法人向けBtoB営業経験3年以上。提案営業の経験。普通自動車免許。',
  'エネルギー業界での営業経験。環境・サステナビリティ領域の知識。自治体との取引経験。設備投資の提案営業経験。',
  '福岡県福岡市（顧客訪問あり：九州全域、出張あり）',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  'フレックスタイム制（コアタイム10:00-16:00）標準労働時間8時間',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇',
  400, 700,
  '月給33万円〜58万円（固定残業代30時間分を含む）。インセンティブ制度あり。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙',
  E'社用車貸与\n交通費全額支給\n資格取得支援\n書籍購入費補助\n副業OK（届出制）',
  '出社（顧客訪問中心）',
  '書類選考 → 一次面接 → 提案プレゼンテーション → 最終面接 → 内定',
  now()
) ON CONFLICT DO NOTHING;

-- 09-3. 企画
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
  required_qualifications, preferred_qualifications,
  work_location, work_location_change_scope, job_description_change_scope,
  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd0090000-0000-0000-0000-000000000003',
  'b0000000-0000-0000-0000-000000000009',
  'c0009000-0000-0000-0000-000000000002',
  'b1000000-0000-0000-0000-000000000009',
  'open',
  'サステナビリティ推進｜企業のESG経営とカーボンニュートラル戦略を支援',
  '企画',
  '正社員',
  '1名',
  '企業のESG経営推進とカーボンニュートラル戦略の策定支援を担当します。GHGプロトコルに基づくScope1/2/3の排出量算定、TCFD/TNFDに基づく情報開示支援、SBT（Science Based Targets）の設定支援が主な業務です。顧客企業の脱炭素ロードマップを策定し、具体的な施策（再エネ導入、省エネ、オフセット等）の実行計画まで伴走します。また、自社のサステナビリティレポートの作成や、環境関連の政策提言活動にも参画します。',
  'ESGやサステナビリティは今後のビジネスにおいて不可避のテーマであり、この領域の専門家は引く手あまたです。グリーンフラックスは実際の再エネ事業を運営しているため、机上の戦略だけでなく実効性のある脱炭素支援ができる点が他のコンサルとの違いです。企業のCFOやCSO（最高サステナビリティ責任者）と直接対話する機会が多く、経営層との折衝経験が積めます。',
  'サステナビリティの規制環境は国際的な動向と日本独自の制度が交錯しており、常に最新情報をキャッチアップする必要があります。排出量算定は膨大なデータ収集が必要で、クライアントの社内データ整備の支援から始めるケースも多いです。また、脱炭素を経営にとってコストではなく価値として位置づける提案ストーリーの構築力も重要です。',
  'サステナビリティ推進チーム3名で、コンサルティングとレポーティングを担当しています。元環境省出身者や元Big4コンサルタントが在籍しています。',
  'ESG/サステナビリティの専門知識、GHG算定スキル、TCFD/TNFD開示支援の実務経験が身につきます。',
  '[]'::jsonb,
  '["ESG","サステナビリティ","GHG算定","TCFD","カーボンニュートラル","脱炭素経営"]'::jsonb,
  '環境コンサルティング、サステナビリティ推進、またはESG関連業務の経験2年以上。',
  'GHGプロトコルに基づく排出量算定の実務経験。TCFD/TNFD開示支援の経験。SBT設定支援の経験。環境関連の資格（環境計量士等）。',
  '福岡県福岡市（リモート併用可、出張あり）',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  'フレックスタイム制（コアタイムなし）標準労働時間8時間',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇',
  450, 750,
  '月給38万円〜63万円（固定残業代30時間分を含む）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙',
  E'リモートワーク手当月2万円\n学会・セミナー参加費補助\n資格取得支援\n書籍購入費補助\n副業OK',
  'リモート併用（出張あり）',
  '書類選考 → 一次面接 → ケーススタディ → 最終面接 → 内定',
  now()
) ON CONFLICT DO NOTHING;

-- 09-4. 発電設備管理（エネルギー業界特有）
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
  required_qualifications, preferred_qualifications,
  work_location, work_location_change_scope, job_description_change_scope,
  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd0090000-0000-0000-0000-000000000004',
  'b0000000-0000-0000-0000-000000000009',
  'c0009000-0000-0000-0000-000000000001',
  'b1000000-0000-0000-0000-000000000009',
  'open',
  '発電設備管理エンジニア｜太陽光発電所のO&Mをテクノロジーで高度化',
  'その他',
  '正社員',
  '1名',
  '九州エリアに展開するグリーンフラックスの太陽光発電所群のO&M（運転保守管理）を担当します。遠隔監視システムによる発電量モニタリング、異常検知時の原因分析と対応指示、定期点検の計画策定・実施を主導します。パネルの経年劣化分析やPCS（パワーコンディショナー）の効率最適化など、発電効率の最大化に向けた技術的な改善活動も行います。また、ドローンを活用したパネル点検の導入や、AI画像解析による異常検知システムの運用改善にも取り組んでいます。',
  '再生可能エネルギーの実設備を管理する現場力と、IoTやAIを活用した先進的な保守管理手法の両方を経験できるポジションです。九州は日照条件に恵まれ、日本有数の太陽光発電の集積地であるため、多様な発電所を管理する経験が積めます。テクノロジーを活用したO&Mの効率化は業界全体のトレンドであり、先駆的な取り組みに参画できます。',
  '太陽光発電所は自然環境の中に設置されているため、気象条件や周辺環境の変化に対応する柔軟性が必要です。数十ヶ所の発電所を効率的に管理するため、遠隔監視と現地対応のバランスが重要です。電気設備に関する法定点検の確実な実施と、安全管理の徹底も欠かせません。',
  '電力システムエンジニアチームに所属し、O&M専任として活動します。電気工事士の資格を持つメンバーが2名在籍しています。',
  '太陽光発電所のO&Mスキル、遠隔監視システムの運用力、発電効率最適化の知見が身につきます。',
  '[]'::jsonb,
  '["太陽光発電","O&M","IoT","発電設備管理","遠隔監視","再生可能エネルギー"]'::jsonb,
  '電気設備の保守管理経験2年以上、または太陽光発電所の運用管理経験。第二種電気工事士以上。普通自動車免許。',
  '太陽光発電所のO&M経験。第三種電気主任技術者。IoTシステムの運用経験。ドローン操縦の資格。',
  '福岡県福岡市（現場訪問あり：九州全域の発電所を巡回）',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  '9:00〜18:00（標準労働時間8時間）',
  '60分',
