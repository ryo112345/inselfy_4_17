  work_location, work_location_change_scope, job_description_change_scope,
  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd00d0000-0000-0000-0000-000000000003',
  'b0000000-0000-0000-0000-00000000000d',
  'c000d000-0000-0000-0000-000000000001',
  'b1000000-0000-0000-0000-00000000000d',
  'open',
  '社内SE｜基幹システム刷新で製造業のDXを推進',
  'エンジニア',
  '正社員',
  '1名',
  '東和精機ソリューションズの基幹システム（ERP / MES / PLM）の運用・保守および次期基幹システムの刷新プロジェクトを担当していただきます。現行のオンプレミスシステムからクラウドへの移行計画の策定、業務要件の整理と外部ベンダーへの発注管理、社内各部門からの要望のヒアリングと優先順位付けなどが主な業務です。全社的なIT戦略の立案にも参画し、セキュリティポリシーの整備やネットワークインフラの管理も行います。製造業の現場を深く理解した上でIT活用の最適解を提案する、社内のITパートナー的な存在です。',
  '創業50年の安定した経営基盤の上で、基幹システムの刷新という大規模プロジェクトを主導できるチャンスです。製造業のバリューチェーン全体をITの観点で俯瞰できるため、業務知識とIT知識の両方を深められます。経営陣のIT投資への理解が高く、最新のクラウドサービスやSaaSの導入に積極的です。社内SE1人目の採用であり、IT部門の立ち上げを自ら主導できるやりがいがあります。',
  '製造・営業・経理など各部門のシステムが個別最適化されており、データの統合と業務プロセスの標準化が大きなテーマです。レガシーシステムからの移行では、業務を止めずに段階的に進める計画力が求められます。また、ITリテラシーの異なる社員への丁寧なサポートとトレーニングも重要な業務です。',
  '現在は総務部がIT関連業務を兼任しており、専任の社内SE第一号として採用します。経営企画室と連携しながら、全社のIT戦略を推進するポジションです。',
  '基幹システムの導入・運用スキル、製造業の業務プロセス知識、プロジェクトマネジメント力、ベンダーマネジメントのスキルが身につきます。',
  '[]'::jsonb,
  '["社内SE","ERP","クラウド移行","製造業DX","プロジェクトマネジメント","セキュリティ"]'::jsonb,
  '社内SEまたはSIerでのシステム開発・運用経験3年以上。基幹システム（ERP / MES等）の導入または運用経験。',
  '製造業でのIT部門経験。クラウドサービス（AWS / Azure / GCP）の利用経験。プロジェクトマネジメントの実務経験。情報セキュリティの知識。',
  '静岡県浜松市',
  '当面なし',
  '当面なし',
  '無期',
  '入社後6ヶ月（条件変更なし）',
  '8:30〜17:30（実働8時間）',
  '60分',
  '完全週休2日制（土日）、祝日、GW、夏季休暇、年末年始休暇、有給休暇、慶弔休暇',
  450, 750,
  '月給32万円〜53万円。賞与年2回（計4.5ヶ月分）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙（喫煙専用室あり）',
  E'社宅制度（転居を伴う場合）\n退職金制度\n財形貯蓄\n社員食堂あり\n資格取得支援制度',
  '原則出社（週1日在宅勤務可）',
  '書類選考 → 適性検査 → 面接（2回） → 内定',
  now()
) ON CONFLICT DO NOTHING;

-- 0d-4: 人事
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
  required_qualifications, preferred_qualifications,
  work_location, work_location_change_scope, job_description_change_scope,
  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd00d0000-0000-0000-0000-000000000004',
  'b0000000-0000-0000-0000-00000000000d',
  'c000d000-0000-0000-0000-000000000003',
  'b1000000-0000-0000-0000-00000000000d',
  'open',
  '人事｜エンジニア採用強化とタレントマネジメントの仕組み構築',
  '人事',
  '正社員',
  '1名',
  '東和精機ソリューションズの人事部門で、中途採用の企画・運用を中心に、人事制度の設計・運用、研修体系の構築、タレントマネジメントの推進を担当していただきます。特に組込みエンジニアやIoT人材の採用が急務であり、技術者採用のチャネル開拓から選考プロセスの最適化、候補者体験の向上まで一貫して取り組みます。製造業の堅実なブランドイメージを活かしつつ、テクノロジー企業としての新しい採用ブランディングも推進するポジションです。人事データの分析による課題特定や、従業員エンゲージメント施策の企画も担当範囲に含まれます。',
  '製造業のDXを支える人材戦略を立案・実行できるポジションです。エンジニア採用の強化は経営課題であり、経営陣と直接議論しながら採用戦略を練る機会があります。創業50年の安定した事業基盤がありながらも、スマートファクトリー化に伴い組織が大きく変革するフェーズにあり、人事として組織づくりの醍醐味を味わえます。社員200名規模のため一人ひとりの顔が見え、施策の効果を実感しやすい環境です。',
  'エンジニア採用市場は競争が激しく、製造業の人事として技術者にとっての魅力をどう発信するかが大きなチャレンジです。既存の年功序列的な人事制度と成果主義のバランスをどう取るかも重要なテーマです。また、浜松という地方都市での人材確保にはリモートワーク制度の整備や移住支援の仕組みづくりなど、地域特性を踏まえた施策が必要です。',
  '人事総務部6名のうち、採用担当2名・労務担当2名・総務担当2名の構成です。今回は採用担当として参画いただきます。',
  'エンジニア採用のノウハウ、人事制度設計のスキル、製造業の組織開発経験、タレントマネジメントの知見が身につきます。',
  '[]'::jsonb,
  '["人事","採用","エンジニア採用","タレントマネジメント","人事制度","研修"]'::jsonb,
  '人事業務の実務経験3年以上。中途採用の企画・運用の経験。',
  'エンジニア採用の経験。人事制度の設計・運用経験。製造業での人事経験。タレントマネジメントシステムの導入経験。',
  '静岡県浜松市',
  '当面なし',
  '当面なし',
  '無期',
  '入社後6ヶ月（条件変更なし）',
  '8:30〜17:30（実働8時間）',
  '60分',
  '完全週休2日制（土日）、祝日、GW、夏季休暇、年末年始休暇、有給休暇、慶弔休暇',
  400, 650,
  '月給28万円〜46万円。賞与年2回（計4.5ヶ月分）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙（喫煙専用室あり）',
  E'社宅制度（転居を伴う場合）\n退職金制度\n財形貯蓄\n社員食堂あり\n資格取得支援制度',
  '原則出社（週1日在宅勤務可）',
  '書類選考 → 面接（2回） → 内定',
  now()
) ON CONFLICT DO NOTHING;

-- ============================================================
-- トラベルネクスト（旅行・観光 / 京都市）
-- ============================================================

-- 0e-1: フルスタックエンジニア
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
  required_qualifications, preferred_qualifications,
  work_location, work_location_change_scope, job_description_change_scope,
  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd00e0000-0000-0000-0000-000000000001',
  'b0000000-0000-0000-0000-00000000000e',
  'c000e000-0000-0000-0000-000000000001',
  'b1000000-0000-0000-0000-00000000000e',
  'open',
  'フルスタックエンジニア｜旅行者と地域をつなぐプラットフォームを開発',
  'エンジニア',
  '正社員',
  '2名',
  'トラベルネクストが開発する体験型観光プラットフォームのフルスタック開発を担当していただきます。旅行者向けの体験検索・予約フロー、地域の事業者向けの管理画面、AIを活用した旅程提案機能、口コミ・レビューシステム、多言語対応など、プラットフォームの幅広い機能を横断的に開発します。Next.js / TypeScript でのフロントエンド開発と Go / PostgreSQL でのバックエンドAPI開発の両方を担当し、新機能の設計から実装、リリースまで一貫して手がけます。外部API（宿泊施設、交通機関、決済など）との連携開発も重要な業務です。',
  '京都という日本有数の観光地を拠点に、テクノロジーで観光体験を変革するプロダクトに関われます。インバウンド需要の回復により市場が急成長しており、自分たちの開発したプロダクトが外国人旅行者の体験を豊かにする瞬間を間近で感じられます。少人数チームのため技術選定からアーキテクチャ設計まで裁量が大きく、フルスタックに成長できる環境です。京都の町家をリノベーションしたオフィスで働く体験も魅力の一つです。',
  '多言語・多通貨対応や、季節によって大きく変動するトラフィックへの対応が技術的なチャレンジです。また、宿泊施設や交通機関など外部システムとの連携では、各社のAPIの仕様差を吸収する設計力が求められます。旅行ドメインならではの複雑な料金体系（早割、グループ割、シーズン料金など）のモデリングも重要なテーマです。',
  'エンジニアチーム5名で、全員がフルスタック志向を持っています。リモートと出社のハイブリッドワークで、週2回のペアプログラミングセッションを実施しています。',
  'フルスタック開発スキル、多言語・多通貨対応の設計力、外部API連携の実装経験、旅行ドメインの業務知識が身につきます。',
  '[]'::jsonb,
  '["TypeScript","Next.js","Go","PostgreSQL","多言語対応","API連携","旅行テック"]'::jsonb,
  'Webアプリケーション開発経験3年以上。フロントエンド・バックエンドの両方の開発経験。',
  '多言語サイトの開発経験。決済システムの連携開発経験。Go / TypeScriptでの開発経験。旅行・観光業界での開発経験。',
  '京都府京都市（リモート併用可）',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  'フレックスタイム制（コアタイム10:00〜15:00）標準労働時間8時間',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇',
  500, 850,
  '月給42万円〜71万円（固定残業代40時間分を含む）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙（喫煙専用室あり）',
  E'リモートワーク手当月2万円\n旅行体験手当（年10万円）\n書籍購入費補助\n副業OK',
  'リモート併用（週2日出社）',
  '書類選考 → 技術面接 → 最終面接 → 内定',
  now()
) ON CONFLICT DO NOTHING;

-- 0e-2: デザイナー
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
  required_qualifications, preferred_qualifications,
  work_location, work_location_change_scope, job_description_change_scope,
  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd00e0000-0000-0000-0000-000000000002',
  'b0000000-0000-0000-0000-00000000000e',
  'c000e000-0000-0000-0000-000000000002',
  'b1000000-0000-0000-0000-00000000000e',
  'open',
  'プロダクトデザイナー｜旅行体験をデザインの力で最高の思い出に',
  'デザイナー',
  '正社員',
  '1名',
  '体験型観光プラットフォームのUI/UXデザインを担当していただきます。旅行者が体験を検索・比較・予約するまでのフロー設計、AI旅程提案のインタラクションデザイン、口コミ投稿・閲覧のUX改善、多言語対応のデザイン最適化など、プロダクト全体のユーザー体験を設計します。京都の文化や美意識をデジタルプロダクトに落とし込むビジュアルデザインも重要な業務です。ユーザーリサーチの企画・実施からプロトタイピング、UIデザイン、エンジニアとの実装連携まで一貫して担当します。旅行者の感動体験を起点としたデザインアプローチを大切にしています。',
  '旅行という感情的な体験をテクノロジーで拡張するデザインに取り組めるポジションです。京都の美意識や伝統文化をプロダクトデザインに活かすユニークなチャレンジがあります。実際に京都の観光体験に参加してユーザーリサーチを行う機会が豊富にあり、現場でのインサイトをデザインに反映できる環境です。海外旅行者のユーザーテストも定期的に実施しており、グローバルなデザイン経験を積めます。',
  '多言語対応では、日本語・英語・中国語・韓国語で文字数やレイアウトが大きく異なるため、柔軟なUI設計が求められます。また、旅行中のユーザーはスマートフォンでの利用が大半であり、モバイルファーストのデザインが前提です。地域の事業者は必ずしもITリテラシーが高くないため、管理画面のUXにも特別な配慮が必要です。',
  'デザインチーム3名で、プロダクトデザイン・ブランドデザイン・リサーチを分担しています。エンジニアチームとの週次デザインレビューで品質を担保しています。',
  '多言語対応のUIデザインスキル、旅行ドメインのUXデザイン力、ユーザーリサーチの企画・実施スキル、モバイルファーストのデザイン力が身につきます。',
  '[]'::jsonb,
  '["UIデザイン","UXリサーチ","Figma","多言語デザイン","モバイルファースト","旅行テック"]'::jsonb,
  'WebサービスのUI/UXデザイン経験3年以上。Figmaでのデザイン実務経験。ユーザーリサーチの経験。',
  '多言語サイトのデザイン経験。旅行・観光業界でのデザイン経験。モーションデザインの経験。フロントエンドの基礎知識。',
  '京都府京都市（リモート併用可）',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  'フレックスタイム制（コアタイム10:00〜15:00）標準労働時間8時間',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇',
  450, 750,
  '月給38万円〜63万円（固定残業代40時間分を含む）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙（喫煙専用室あり）',
  E'リモートワーク手当月2万円\n旅行体験手当（年10万円）\n書籍購入費補助\n副業OK',
  'リモート併用（週2日出社）',
  '書類選考 → ポートフォリオレビュー → デザイン課題 → 最終面接 → 内定',
  now()
) ON CONFLICT DO NOTHING;

-- 0e-3: セールス
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
  required_qualifications, preferred_qualifications,
  work_location, work_location_change_scope, job_description_change_scope,
  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd00e0000-0000-0000-0000-000000000003',
  'b0000000-0000-0000-0000-00000000000e',
  'c000e000-0000-0000-0000-000000000003',
  'b1000000-0000-0000-0000-00000000000e',
  'open',
  '法人セールス｜地域の観光事業者とプラットフォームをつなぐ架け橋',
  'セールス',
  '正社員',
  '2名',
  '体験型観光プラットフォームへの掲載事業者の新規開拓と既存事業者のフォローアップを担当していただきます。旅館・ホテル、体験アクティビティ事業者、地域の飲食店、交通事業者など多様な観光関連事業者に対して、プラットフォームの価値提案と導入支援を行います。地域の観光協会や自治体との連携による地域全体での導入推進も重要な業務です。事業者のデジタル化支援として、写真撮影のアドバイスや掲載コンテンツの改善提案、予約管理のサポートまで幅広く伴走します。京都を中心に関西エリアのエリア拡大を推進するポジションです。',
  '京都という世界有数の観光地でのセールス活動は、歴史ある事業者との出会いに満ちています。テクノロジーの力で地域の魅力を世界に届ける仕事は社会的意義が大きく、やりがいを感じやすいポジションです。事業者の売上向上というわかりやすい成果指標があり、自分の提案がビジネスに直結する実感があります。観光業界のDX支援は成長市場であり、この分野でのキャリアは今後さらに価値が高まります。',
  '観光事業者にはITリテラシーに幅があるため、事業者ごとに提案のアプローチを変える柔軟性が求められます。特に老舗旅館などは伝統を大切にする文化があり、デジタルツールの導入には丁寧な説明と信頼構築が不可欠です。また、繁忙期と閑散期の差が大きい観光業界の特性を理解した上で、適切なタイミングでの提案が重要です。',
  'ビジネスチーム5名で、セールス3名・カスタマーサクセス2名の構成です。全員が旅行好きで、実際に事業者の体験プログラムに参加する文化があります。',
  '観光業界のセールスノウハウ、地域事業者との関係構築スキル、BtoB SaaSの営業力、地域経済に関する知見が身につきます。',
  '[]'::jsonb,
  '["法人営業","観光業界","SaaS","新規開拓","事業者支援","インバウンド"]'::jsonb,
  '法人向け営業経験2年以上。新規開拓営業の経験。',
  '旅行・観光業界での営業経験。SaaSプロダクトの営業経験。地域活性化に関わる業務経験。英語でのコミュニケーション力。',
  '京都府京都市（外勤あり）',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  'フレックスタイム制（コアタイム10:00〜15:00）標準労働時間8時間',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇',
  400, 700,
  '月給33万円〜58万円（固定残業代40時間分を含む）。インセンティブ制度あり。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙（喫煙専用室あり）',
  E'リモートワーク手当月2万円\n旅行体験手当（年10万円）\n交通費全額支給\n副業OK',
  'リモート併用（外勤中心）',
  '書類選考 → 一次面接 → 最終面接 → 内定',
  now()
) ON CONFLICT DO NOTHING;

-- 0e-4: マーケティング
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
