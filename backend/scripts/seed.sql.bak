-- 11-1: ソフトウェアエンジニア
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
  required_qualifications, preferred_qualifications,
  work_location, work_location_change_scope, job_description_change_scope,
  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd0110000-0000-0000-0000-000000000001',
  'b0000000-0000-0000-0000-000000000011',
  'c0011000-0000-0000-0000-000000000001',
  'b1000000-0000-0000-0000-000000000011',
  'open',
  'ソフトウェアエンジニア｜自動運転車両の経路計画アルゴリズムを開発',
  'エンジニア',
  '正社員',
  '2名',
  'モビリティワークスが開発する自動運転シャトルバスの経路計画・制御ソフトウェアの開発を担当していただきます。リアルタイムの交通状況に基づく動的経路計画アルゴリズムの実装、センサーフュージョンによる障害物検出・回避ロジックの改善、V2X（Vehicle-to-Everything）通信との連携、シミュレーション環境でのテスト自動化などが主な業務です。C++とPythonを中心に、ROS2フレームワーク上で開発を行います。実車両でのフィールドテストにも参加し、アルゴリズムの実環境での検証と改善を繰り返すサイクルで開発を進めます。',
  '自動運転技術の社会実装に直接貢献できるポジションです。名古屋市との協定に基づく公道での実証実験を定期的に行っており、自分が書いたコードで車両が動く体験は他では得難いものです。自動車産業の集積地である名古屋を拠点にしているため、OEMやTier1サプライヤーとの技術交流の機会も豊富です。学術機関との共同研究プロジェクトもあり、最先端の研究成果をプロダクトに活かせる環境です。',
  '自動運転の経路計画では安全性が最優先であり、あらゆるエッジケースに対応する堅牢なアルゴリズム設計が求められます。実環境は天候・時間帯・交通量によって大きく変化するため、シミュレーションと実車両テストのギャップを埋める技術的工夫が必要です。また、法規制の変化への対応や、保険・責任の観点からの安全性証明も重要なテーマです。',
  '自動運転ソフトウェアチーム8名で、経路計画・知覚・制御・シミュレーションの4領域を担当しています。自動車メーカー出身者とソフトウェア企業出身者がバランスよく在籍しています。',
  '自動運転ソフトウェアの開発スキル、ROS2の実践力、経路計画アルゴリズムの知識、安全性検証の手法が身につきます。',
  '[]'::jsonb,
  '["C++","Python","ROS2","自動運転","経路計画","センサーフュージョン","ADAS"]'::jsonb,
  'C++でのソフトウェア開発経験3年以上。ロボティクスまたは自動運転関連の開発経験。',
  'ROS / ROS2での開発経験。画像処理 / 点群処理の経験。数理最適化やアルゴリズム設計の知識。自動車業界での開発経験。修士以上の学位（ロボティクス / 情報工学 / 制御工学等）。',
  '愛知県名古屋市（フィールドテスト時は市内各所）',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  'フレックスタイム制（コアタイム10:00〜15:00）標準労働時間8時間',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇',
  600, 1000,
  '月給50万円〜83万円（固定残業代40時間分を含む）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙（喫煙専用室あり）',
  E'リモートワーク手当月2万円\nカンファレンス・学会参加費補助\n書籍購入費全額補助\n引越し支援金',
  'リモート併用（週3日出社・テスト日は出社必須）',
  '書類選考 → 技術面接（コーディング課題含む） → 最終面接 → 内定',
  now()
) ON CONFLICT DO NOTHING;

-- 11-2: PM
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
  required_qualifications, preferred_qualifications,
  work_location, work_location_change_scope, job_description_change_scope,
  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd0110000-0000-0000-0000-000000000002',
  'b0000000-0000-0000-0000-000000000011',
  'c0011000-0000-0000-0000-000000000002',
  'b1000000-0000-0000-0000-000000000011',
  'open',
  'プロジェクトマネージャー｜自治体連携の自動運転実証プロジェクトを推進',
  'PM',
  '正社員',
  '1名',
  '自動運転シャトルバスの社会実装に向けた実証プロジェクトのマネジメントを担当していただきます。名古屋市をはじめとする自治体との協議・交渉、プロジェクト計画の策定と進捗管理、エンジニアチーム・ハードウェアチーム・オペレーションチームの横断的な調整、実証実験の運営管理、安全審査対応、報告書の作成などが主な業務です。国土交通省の規制動向のモニタリングと対応策の立案、保険会社との連携による事故リスク管理も重要な業務です。複数のステークホルダーの利害を調整しながら、プロジェクトを成功に導くリーダーシップが求められます。',
  '自動運転の社会実装という、日本のモビリティの未来を切り拓くプロジェクトのPMを務められる稀有なポジションです。自治体の首長や国土交通省の担当者と直接やり取りする機会があり、政策形成にも影響を与えられます。名古屋市の中心部で実証実験を行うため、自分が関わったプロジェクトが街の風景を変える瞬間を間近で体験できます。モビリティ業界のキーパーソンとのネットワーク構築も大きな財産になります。',
  '自動運転のプロジェクトマネジメントでは、技術・法規制・安全性・社会受容性という多面的な課題を同時に扱う必要があります。自治体との協働では行政特有の意思決定プロセスへの理解が不可欠であり、民間のスピード感との両立が求められます。天候や交通状況に左右される実証実験のスケジュール管理には柔軟な対応力が必要です。',
  'プロジェクトマネジメント室3名で、各プロジェクトのPMを担当しています。経営陣・エンジニアチーム・オペレーションチームと横断的に連携する体制です。',
  '自動運転プロジェクトのマネジメントスキル、官公庁との折衝力、モビリティ業界のビジネス知識、安全管理の知見が身につきます。',
  '[]'::jsonb,
  '["PM","自動運転","自治体連携","プロジェクトマネジメント","モビリティ","実証実験"]'::jsonb,
  'プロジェクトマネジメントの実務経験5年以上。複数チームの横断的な調整経験。ステークホルダーマネジメントの経験。',
  '自動車・モビリティ業界での業務経験。官公庁・自治体との折衝経験。PMP等のPM資格。安全管理・リスクマネジメントの経験。',
  '愛知県名古屋市',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  'フレックスタイム制（コアタイム10:00〜15:00）標準労働時間8時間',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇',
  600, 1000,
  '月給50万円〜83万円（固定残業代40時間分を含む）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙（喫煙専用室あり）',
  E'リモートワーク手当月2万円\nカンファレンス参加費補助\n書籍購入費補助\n引越し支援金',
  'リモート併用（週3日出社）',
  '書類選考 → 一次面接 → ケース面接 → 最終面接 → 内定',
  now()
) ON CONFLICT DO NOTHING;

-- 11-3: マーケティング
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
  required_qualifications, preferred_qualifications,
  work_location, work_location_change_scope, job_description_change_scope,
  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd0110000-0000-0000-0000-000000000003',
  'b0000000-0000-0000-0000-000000000011',
  'c0011000-0000-0000-0000-000000000003',
  'b1000000-0000-0000-0000-000000000011',
  'open',
  'マーケティング・PR｜自動運転の社会実装を世の中に届ける広報戦略',
  'マーケティング',
  '正社員',
  '1名',
  '自動運転シャトルバスの社会実装に向けた広報・マーケティング戦略の立案と実行を担当していただきます。メディアリレーション（テレビ・新聞・Webメディア）の構築と運営、プレスリリースの作成・配信、実証実験時のメディア対応、SNS運用、コーポレートサイトのコンテンツ企画、投資家向けIR資料の作成支援、採用広報の企画など幅広い業務を統括します。自動運転技術への社会的な理解と信頼を醸成するためのコミュニケーション戦略が重要なミッションです。',
  '自動運転という社会的関注度の高いテーマで広報・マーケティングに携われるポジションです。テレビや全国紙からの取材依頼も多く、メディアリレーションの実践力を大きく伸ばせます。自治体連携の実証実験では市民向けの説明会やイベントの企画も行い、テクノロジーの社会実装における広報の役割を肌で学べます。スタートアップのため、マーケティングの仕組みをゼロから構築できる醍醐味があります。',
  '自動運転は安全性への懸念が社会的に根強いため、技術の安全性と利便性を正確かつわかりやすく伝えるコミュニケーション力が求められます。事故やインシデント発生時のクライシスコミュニケーション計画の策定も重要な業務です。また、BtoG（対行政）とBtoC（対市民）の異なるターゲットに向けた適切なメッセージングの使い分けも必要です。',
  '広報・マーケティング担当は現在1名で、今回2人目の採用です。経営陣直下で動くポジションで、会社の顔としての役割を担います。',
  'テクノロジー企業の広報スキル、メディアリレーションの実践力、クライシスコミュニケーションの知見、モビリティ業界の知識が身につきます。',
  '[]'::jsonb,
  '["PR","広報","メディアリレーション","マーケティング","モビリティ","自動運転"]'::jsonb,
  '広報またはPRの実務経験3年以上。プレスリリースの作成経験。メディア対応の経験。',
  'テクノロジー企業での広報経験。クライシスコミュニケーションの経験。SNS運用の経験。英語でのメディア対応力。',
  '愛知県名古屋市（リモート併用可）',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  'フレックスタイム制（コアタイム10:00〜15:00）標準労働時間8時間',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇',
  450, 750,
  '月給38万円〜63万円（固定残業代40時間分を含む）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙（喫煙専用室あり）',
  E'リモートワーク手当月2万円\nカンファレンス参加費補助\n書籍購入費補助\n引越し支援金',
  'リモート併用（週2日出社）',
  '書類選考 → 一次面接 → 最終面接 → 内定',
  now()
) ON CONFLICT DO NOTHING;

-- 11-4: カスタマーサクセス（MaaS）
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
