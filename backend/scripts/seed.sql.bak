) VALUES (
  'd00b0000-0000-0000-0000-000000000003',
  'b0000000-0000-0000-0000-00000000000b',
  'c000b000-0000-0000-0000-000000000002',
  'b1000000-0000-0000-0000-00000000000b',
  'open',
  'プロダクトマネージャー｜ECプラットフォームの成長戦略を牽引',
  'PM',
  '正社員',
  '1名',
  'コマースクラフトのECプラットフォーム全体のプロダクト戦略策定と実行をリードしていただきます。マーチャント向け管理画面、購入者向けストアフロント、物流連携機能など複数のプロダクトラインを横断的に管理し、ロードマップの策定、要件定義、開発チームとの連携、リリース後の効果測定まで一貫して担当します。マーチャントへのヒアリングや購買データの分析を通じて顧客課題を特定し、プロダクトの進化をデータドリブンに推進する役割です。',
  'ECプラットフォームのPMとして、マーチャントと購入者の両面からプロダクト価値を設計できるポジションです。年間流通額100億円規模のプラットフォームで、施策の効果が数字として見えやすい環境です。経営陣との距離が近く、プロダクトビジョンの議論に直接参加できます。技術的な知見を活かしてエンジニアと対等に議論できるPMを目指す方に最適です。',
  'マルチステークホルダー環境での優先順位付けが最大のチャレンジです。マーチャントの要望、購入者のUX向上、プラットフォームの収益性という三者の利害を調整しながら、限られたリソースで最大の価値を生み出す判断を求められます。EC市場の競争環境は激しく、競合分析と差別化戦略の立案も重要な業務です。',
  'プロダクトチーム3名で、PM1名・デザイナー1名・ビジネスアナリスト1名の構成です。エンジニアチームと同じフロアで密に連携しています。',
  'ECプラットフォームのプロダクトマネジメントスキル、データドリブンな意思決定力、マルチステークホルダー環境での合意形成スキルが身につきます。',
  '[]'::jsonb,
  '["PM","ECプラットフォーム","ロードマップ策定","データ分析","要件定義","マーチャント支援"]'::jsonb,
  'プロダクトマネジメントの実務経験3年以上。Webサービスの企画・要件定義の経験。データに基づく意思決定の経験。',
  'EC・マーケットプレイス領域でのPM経験。SQLを用いたデータ分析の経験。エンジニアとの協業経験。BtoB SaaSのPM経験。',
  '神奈川県横浜市（リモート併用可）',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  'フレックスタイム制（コアタイム11:00〜15:00）標準労働時間8時間',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇',
  600, 1000,
  '月給50万円〜83万円（固定残業代40時間分を含む）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙（喫煙専用室あり）',
  E'リモートワーク手当月2万円\n書籍購入費補助（年5万円）\n社員割引制度\n副業OK',
  'リモート併用（週2日出社）',
  '書類選考 → 一次面接 → ケース面接 → 最終面接 → 内定',
  now()
) ON CONFLICT DO NOTHING;

-- 0b-4: カスタマーサクセス
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
  required_qualifications, preferred_qualifications,
  work_location, work_location_change_scope, job_description_change_scope,
  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd00b0000-0000-0000-0000-000000000004',
  'b0000000-0000-0000-0000-00000000000b',
  'c000b000-0000-0000-0000-000000000003',
  'b1000000-0000-0000-0000-00000000000b',
  'open',
  'カスタマーサクセス｜マーチャントの売上成長を伴走支援',
  'カスタマーサクセス',
  '正社員',
  '2名',
  'ECプラットフォームに出店するマーチャントの売上成長を支援するカスタマーサクセスポジションです。オンボーディングから始まり、ストアデザインの最適化提案、商品ページの改善アドバイス、プロモーション施策の企画支援、売上データの定期レポーティングまで、マーチャントのEC事業成功に向けて包括的に伴走します。月次のビジネスレビューを通じてマーチャントの課題を継続的に把握し、プラットフォーム機能の活用度を最大化するのがミッションです。',
  'マーチャントの売上という明確な成果指標があり、自分の支援がビジネスに直結する実感を得やすいポジションです。EC運営のノウハウを幅広く身につけられるだけでなく、プロダクトチームへのフィードバックを通じてプラットフォーム自体の進化にも貢献できます。多様な業種のマーチャントと関わるため、各業界のビジネスモデルや課題を深く理解できる点も魅力です。',
  '多様な業種・規模のマーチャントに対して、それぞれの状況に合わせたカスタマイズされた支援を提供する必要があります。EC初心者のマーチャントにはプラットフォームの基本的な使い方から、上級者にはデータ活用やマーケティング戦略まで幅広い知見が求められます。チャーン予兆の早期発見と対策立案も重要な業務です。',
  'カスタマーサクセスチーム4名で、マーチャントの規模別に担当を分けています。セールスチームとの連携も密に行い、新規マーチャントの獲得から既存の活性化まで一体で取り組んでいます。',
  'EC運営の包括的な知識、カスタマーサクセスの設計・実行力、データ分析に基づく提案スキル、多業種の業務知識が身につきます。',
  '[]'::jsonb,
  '["カスタマーサクセス","EC","マーチャント支援","データ分析","オンボーディング","売上改善"]'::jsonb,
  'カスタマーサクセスまたはコンサルティングの実務経験2年以上。顧客折衝の経験。',
  'EC業界での業務経験。BIツールやExcelを用いたデータ分析の経験。SaaSプロダクトのカスタマーサクセス経験。マーケティングの基礎知識。',
  '神奈川県横浜市（リモート併用可）',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  'フレックスタイム制（コアタイム11:00〜15:00）標準労働時間8時間',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇',
  400, 700,
  '月給33万円〜58万円（固定残業代40時間分を含む）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙（喫煙専用室あり）',
  E'リモートワーク手当月2万円\n書籍購入費補助（年5万円）\n社員割引制度\n副業OK',
  'リモート併用（週2日出社）',
  '書類選考 → 一次面接 → 最終面接 → 内定',
