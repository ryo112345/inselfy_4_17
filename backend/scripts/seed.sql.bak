-- 0c-2: UIデザイナー
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
  required_qualifications, preferred_qualifications,
  work_location, work_location_change_scope, job_description_change_scope,
  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd00c0000-0000-0000-0000-000000000002',
  'b0000000-0000-0000-0000-00000000000c',
  'c000c000-0000-0000-0000-000000000002',
  'b1000000-0000-0000-0000-00000000000c',
  'open',
  'UIデザイナー｜ゲーム内UIからプロモーションまでビジュアル全般を担当',
  'デザイナー',
  '正社員',
  '1名',
  'ゲーム内UI（HUD、メニュー、ガチャ演出、リザルト画面など）のデザインとプロモーション素材（ストアページ、SNS素材、イベントバナー）の制作を担当していただきます。ゲームの世界観を損なわずに操作性を追求するUI設計と、プレイヤーの期待を高めるビジュアル表現の両方が求められるポジションです。UnityのUIフレームワークを用いた実装にも携わり、デザインから実装まで一貫して担当できます。アニメーション演出の設計やエフェクトのタイミング調整など、ゲームならではのインタラクションデザインに取り組めます。',
  'ゲームUIは「遊びの一部」であり、操作性だけでなくプレイヤーの感情に働きかけるデザインが求められます。自分がデザインしたUIを通じてプレイヤーが熱狂する瞬間を直接見られるのは、ゲーム業界ならではの醍醐味です。自社タイトルのため企画段階からUI設計に関与でき、プランナーやエンジニアとの協業が活発な環境です。仙台のオフィスはクリエイティブな空間づくりにこだわっており、集中とリラックスのバランスが取れた働き方ができます。',
  'ゲーム内UIではリアルタイムに変化する情報を限られた画面領域に整理して表示する必要があり、レスポンシブとはまた異なるデザインの制約があります。多言語対応やアクセシビリティへの配慮も求められます。また、ゲームの世界観を統一しつつ、各画面の機能性を両立させるバランス感覚が重要です。',
  'デザインチーム5名（UIデザイナー2名、コンセプトアーティスト2名、モーションデザイナー1名）で構成されています。チーム内でのレビュー文化が定着しており、お互いの作品をブラッシュアップする風土があります。',
  'ゲームUI設計のスキル、UnityでのUI実装力、アニメーション演出のデザインスキル、プロモーションクリエイティブの制作力が身につきます。',
  '[]'::jsonb,
  '["UIデザイン","Unity","ゲームUI","Figma","Photoshop","アニメーション","プロモーション"]'::jsonb,
  'UIデザインの実務経験3年以上。ゲームまたはエンターテインメント領域でのデザイン経験。Figma / Photoshopの実務スキル。',
  'Unity UIの実装経験。モーションデザイン / アニメーション制作の経験。コンシューマゲームまたはモバイルゲームのUI制作経験。',
  '宮城県仙台市（リモート併用可）',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  'フレックスタイム制（コアタイムなし）標準労働時間8時間',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇',
  400, 750,
  '月給33万円〜63万円（固定残業代45時間分を含む）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙（喫煙専用室あり）',
  E'フルリモート手当月3万円\nゲーム購入費補助（月5,000円）\nカンファレンス参加費補助\n副業OK',
  'リモート併用（週1日出社）',
  '書類選考 → ポートフォリオレビュー → デザイン課題 → 最終面接 → 内定',
  now()
) ON CONFLICT DO NOTHING;

-- 0c-3: マーケティング
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
  required_qualifications, preferred_qualifications,
  work_location, work_location_change_scope, job_description_change_scope,
  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd00c0000-0000-0000-0000-000000000003',
  'b0000000-0000-0000-0000-00000000000c',
  'c000c000-0000-0000-0000-000000000003',
  'b1000000-0000-0000-0000-00000000000c',
  'open',
  'マーケティングマネージャー｜自社ゲームタイトルのグロース戦略を設計',
  'マーケティング',
  '正社員',
  '1名',
  '自社開発のゲームタイトルに関するマーケティング戦略の立案・実行を統括していただきます。新規ユーザー獲得のためのデジタル広告運用、SNS・コミュニティマネジメント、ゲームメディアとのPR連携、ゲームイベントの企画・運営、インフルエンサーマーケティングなど多岐にわたる施策を横断的に推進します。KPI設計からクリエイティブ制作のディレクション、効果測定・改善まで一貫して担当し、タイトルの認知拡大とDAU最大化を実現するポジションです。',
  '自社タイトルのマーケティングを一気通貫で担当できるため、戦略の全体像を描いて実行する醍醐味があります。ゲーム開発チームとの距離が非常に近く、ゲームの魅力を最も深く理解した上でマーケティング施策を打てる環境です。グローバル展開も視野に入れており、海外市場向けのマーケティング経験を積む機会もあります。仙台のゲーム開発コミュニティとの繋がりも強く、地域のイベント企画にも関われます。',
  'ゲーム市場は競争が激しく、限られた予算で最大のインパクトを出すクリエイティブな施策立案が求められます。プレイヤーコミュニティのマネジメントでは、ポジティブな声もネガティブなフィードバックも含めて適切に対応するコミュニケーション力が必要です。また、ゲームのアップデートサイクルに合わせた施策のタイミング設計も重要なスキルです。',
  'マーケティングチーム3名で、デジタル広告・SNS・PRをそれぞれ専任で担当しています。全員がゲーム好きで、プレイヤー目線を大切にした施策立案を心がけています。',
  'ゲームマーケティングの戦略立案・実行スキル、コミュニティマネジメントの知見、デジタル広告の運用最適化スキル、インフルエンサーマーケティングの経験が身につきます。',
  '[]'::jsonb,
  '["ゲームマーケティング","SNS運用","デジタル広告","コミュニティ","PR","インフルエンサー"]'::jsonb,
  'マーケティングの実務経験3年以上。デジタル広告の運用経験。SNSアカウントの運用経験。',
  'ゲーム・エンタメ業界でのマーケティング経験。コミュニティマネジメントの経験。インフルエンサーマーケティングの経験。英語でのコミュニケーション力。',
  '宮城県仙台市（リモート併用可）',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  'フレックスタイム制（コアタイムなし）標準労働時間8時間',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇',
  450, 800,
  '月給38万円〜67万円（固定残業代45時間分を含む）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙（喫煙専用室あり）',
  E'フルリモート手当月3万円\nゲーム購入費補助（月5,000円）\nカンファレンス参加費補助\n副業OK',
  'リモート併用（週1日出社）',
  '書類選考 → 一次面接 → 最終面接 → 内定',
  now()
) ON CONFLICT DO NOTHING;

-- 0c-4: 企画（ゲームプランナー）
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
  required_qualifications, preferred_qualifications,
  work_location, work_location_change_scope, job_description_change_scope,
  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd00c0000-0000-0000-0000-000000000004',
  'b0000000-0000-0000-0000-00000000000c',
  'c000c000-0000-0000-0000-000000000002',
  'b1000000-0000-0000-0000-00000000000c',
  'open',
  'ゲームプランナー｜ライブ運営の企画でプレイヤーを熱狂させる',
  '企画',
  '正社員',
  '1名',
  'オンラインマルチプレイヤーゲームのライブ運営に関する企画業務全般を担当していただきます。シーズンイベントの企画・設計、ゲーム内経済のバランス調整、新キャラクター・新マップの仕様策定、チュートリアルやオンボーディングフローの改善、KPI分析に基づく施策立案など、ゲームの継続的な進化を支える中核ポジションです。プレイヤーの行動データを分析し、離脱要因の特定や課金ポイントの最適化にも取り組みます。企画書の作成からエンジニア・デザイナーへの仕様伝達、リリース後の効果検証まで一貫して担当します。',
  '自社タイトルのライブ運営を企画段階から手がけられるため、アイデアがダイレクトにプレイヤーの体験に反映されるやりがいがあります。データドリブンな企画文化が根付いており、勘ではなくデータに基づいた仮説検証サイクルで企画を磨けます。エンジニアやデザイナーとワンチームで動くため、実現可能性を踏まえた企画力が鍛えられます。月1回のゲームジャムでは、本業とは別にプロトタイプを自由に作れる時間もあります。',
  'ライブ運営では「鮮度」と「計画性」の両立が求められます。プレイヤーの期待を超えるイベントを定期的に届けながら、長期的なコンテンツロードマップとの整合性を保つバランス感覚が必要です。ゲーム内経済のバランス調整は慎重さが求められ、プレイヤーコミュニティの反応を常に注視しながら施策を打つ判断力も重要です。',
  '企画チーム4名で、レベルデザイン・ナラティブ・ライブ運営・システム企画の各領域を分担しています。全員がヘビーゲーマーで、自社タイトルを日常的にプレイしています。',
  'ゲーム企画のスキル全般、ライブ運営の設計・実行力、データ分析に基づく仮説検証スキル、ゲームバランス調整の知見が身につきます。',
  '[]'::jsonb,
  '["ゲーム企画","ライブ運営","レベルデザイン","データ分析","バランス調整","KPI"]'::jsonb,
  'ゲームプランナーとしての実務経験2年以上。企画書の作成とチームへの仕様伝達の経験。',
  'オンラインゲームのライブ運営経験。データ分析ツール（SQL / Excelなど）の活用経験。ゲーム内経済のバランス調整経験。コンシューマまたはモバイルゲームの開発経験。',
  '宮城県仙台市（リモート併用可）',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  'フレックスタイム制（コアタイムなし）標準労働時間8時間',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇',
  400, 700,
  '月給33万円〜58万円（固定残業代45時間分を含む）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙（喫煙専用室あり）',
  E'フルリモート手当月3万円\nゲーム購入費補助（月5,000円）\nカンファレンス参加費補助\n副業OK',
  'リモート併用（週1日出社）',
  '書類選考 → 企画課題 → 面接（2回） → 内定',
  now()
) ON CONFLICT DO NOTHING;

-- ============================================================
-- 東和精機ソリューションズ（製造業 / 浜松市）
