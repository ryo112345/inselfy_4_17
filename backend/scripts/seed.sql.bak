-- 10-1: バックエンドエンジニア
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
  required_qualifications, preferred_qualifications,
  work_location, work_location_change_scope, job_description_change_scope,
  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd0100000-0000-0000-0000-000000000001',
  'b0000000-0000-0000-0000-000000000010',
  'c0010000-0000-0000-0000-000000000001',
  'b1000000-0000-0000-0000-000000000010',
  'open',
  'バックエンドエンジニア｜食品流通をDXするサプライチェーンAPIを設計',
  'エンジニア',
  '正社員',
  '1〜2名',
  'フードクラフトが開発する食品サプライチェーン管理プラットフォームのバックエンドAPI開発を担当していただきます。生産者から飲食店・小売店までの食品流通をデジタル化するシステムで、在庫管理、受発注処理、配送ルート最適化、食品トレーサビリティ、賞味期限管理などの機能を開発します。IoTセンサーとの連携による温度・湿度の監視データ処理や、需要予測AIとの連携APIの設計も重要な業務です。食品ロス削減という社会課題の解決にテクノロジーで直接貢献できるポジションです。',
  'フードテック市場は急成長しており、特に食品サプライチェーンのDXは社会的な注目度が高い分野です。福岡は食の都としてのブランド力があり、地元の生産者や飲食店との距離が近いため、ユーザーの声を直接聞きながら開発できます。少人数チームのため技術選定からアーキテクチャ設計まで裁量が大きく、エンジニアとしての成長機会が豊富です。食品ロス削減という明確な社会的ミッションがあり、仕事の意義を実感しやすい環境です。',
  '食品流通は温度管理や賞味期限管理など、一般的な物流システムよりも厳格な制約条件があり、システムの信頼性が強く求められます。多数の取引先との受発注データの正確な同期処理、配送ルートのリアルタイム最適化、需要予測の精度向上など、技術的に奥深いチャレンジが多くあります。また、ITリテラシーの異なる事業者が利用するため、APIの堅牢さと使いやすさの両立も重要です。',
  'エンジニアチーム4名で、バックエンド2名・フロントエンド1名・インフラ1名の構成です。全員がフードテックへの情熱を持ち、プロダクトの成長に向けて日々議論しています。',
  'サプライチェーン管理システムの設計スキル、IoTデータ処理の実装力、食品業界のドメイン知識、需要予測との連携開発の経験が身につきます。',
  '[]'::jsonb,
  '["Go","PostgreSQL","AWS","IoT","サプライチェーン","フードテック","API設計"]'::jsonb,
  'バックエンド開発経験3年以上（Go / Python / Java等）。RDBMSを用いた開発の実務経験。',
  '物流・サプライチェーン関連のシステム開発経験。IoTシステムとの連携開発経験。AWSでのインフラ構築経験。食品業界のドメイン知識。',
  '福岡県福岡市（リモート併用可）',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  'フレックスタイム制（コアタイム10:00〜15:00）標準労働時間8時間',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇',
  500, 850,
  '月給42万円〜71万円（固定残業代40時間分を含む）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙（喫煙専用室あり）',
  E'リモートワーク手当月2万円\n食事補助（提携飲食店で社割）\n書籍購入費補助\n副業OK',
  'リモート併用（週2日出社）',
  '書類選考 → 技術面接 → 最終面接 → 内定',
  now()
) ON CONFLICT DO NOTHING;

-- 10-2: デザイナー
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
  required_qualifications, preferred_qualifications,
  work_location, work_location_change_scope, job_description_change_scope,
  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd0100000-0000-0000-0000-000000000002',
  'b0000000-0000-0000-0000-000000000010',
  'c0010000-0000-0000-0000-000000000002',
  'b1000000-0000-0000-0000-000000000010',
  'open',
  'プロダクトデザイナー｜食の流通を変えるUXをゼロから設計',
  'デザイナー',
  '正社員',
  '1名',
  '食品サプライチェーン管理プラットフォームのUI/UXデザインを担当していただきます。生産者が直感的に使える出荷管理画面、飲食店オーナーが効率的に発注できるモバイルUI、配送ステータスのリアルタイム可視化、食品トレーサビリティの消費者向け表示など、多様なユーザーに向けたインターフェースを設計します。ユーザーリサーチのために実際に農家や飲食店を訪問し、現場の課題を肌で感じながらデザインに落とし込む機会が豊富にあります。BtoBのプロダクトでありながら、最終的には消費者の食体験を豊かにするデザインを目指しています。',
  'フードテック領域でプロダクトデザインをゼロから手がけられる貴重なポジションです。デザインシステムの構築からユーザーリサーチ、プロトタイピングまで一貫して担当できます。実際に生産者の畑や飲食店の厨房を訪問してリサーチを行うなど、デスクワークだけでは得られないインサイトを得る機会が豊富です。福岡のフードシーンは全国屈指の多様性があり、食に関わるデザインのインスピレーションに溢れた環境です。',
  'ITリテラシーが大きく異なるユーザー（農家のベテラン、飲食店オーナー、配送ドライバーなど）全員が迷わず使えるUIを設計することが最大のチャレンジです。また、食品流通特有の複雑なデータ（ロット番号、温度履歴、賞味期限など）をわかりやすく可視化するスキルも求められます。限られたリソースの中でデザインの質と開発スピードを両立させる工夫も必要です。',
  '現在エンジニアチームにデザイン兼務のメンバーがいますが、専任デザイナー第一号として採用します。プロダクトの見た目と使い勝手を根本から変える影響力のあるポジションです。',
  'BtoB SaaSのプロダクトデザインスキル、フィールドリサーチの企画・実施力、デザインシステムの構築スキル、食品業界のUX知識が身につきます。',
  '[]'::jsonb,
  '["UIデザイン","UXリサーチ","Figma","デザインシステム","フードテック","BtoB"]'::jsonb,
  'WebサービスのUI/UXデザイン経験3年以上。Figmaでのデザイン実務経験。',
  'BtoB SaaSのデザイン経験。ユーザーリサーチの企画・実施経験。デザインシステムの構築経験。フロントエンドの基礎知識。',
  '福岡県福岡市（リモート併用可）',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  'フレックスタイム制（コアタイム10:00〜15:00）標準労働時間8時間',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇',
  400, 700,
  '月給33万円〜58万円（固定残業代40時間分を含む）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙（喫煙専用室あり）',
  E'リモートワーク手当月2万円\n食事補助（提携飲食店で社割）\n書籍購入費補助\n副業OK',
  'リモート併用（週2日出社）',
  '書類選考 → ポートフォリオレビュー → デザイン課題 → 最終面接 → 内定',
  now()
) ON CONFLICT DO NOTHING;

