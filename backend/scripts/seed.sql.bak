-- 14-1: バックエンドエンジニア
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
  required_qualifications, preferred_qualifications,
  work_location, work_location_change_scope, job_description_change_scope,
  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd0140000-0000-0000-0000-000000000001',
  'b0000000-0000-0000-0000-000000000014',
  'c0014000-0000-0000-0000-000000000001',
  'b1000000-0000-0000-0000-000000000014',
  'open',
  'バックエンドエンジニア｜AIで契約書レビューを自動化するエンジンを開発',
  'エンジニア',
  '正社員',
  '2名',
  'リーガルスクエアが開発するAI契約書レビューサービスのバックエンドAPI開発を担当していただきます。自然言語処理モデルを活用した契約書の条項分析エンジン、リスク判定アルゴリズム、契約書テンプレート管理システム、バージョン管理・差分比較機能、電子署名サービスとの連携など、リーガルテックの中核機能を開発します。大規模言語モデル（LLM）のプロンプト設計とAPIラッパーの開発、精度評価パイプラインの構築も重要な業務です。法律事務所や企業の法務部が日常的に使うツールとして、信頼性と速度の両立が求められるシステムを設計します。',
  'リーガルテックは日本ではまだ成長初期のブルーオーシャン市場であり、業界のスタンダードを作る側に立てるポジションです。AIと法律という異分野の交差点で、ユニークなキャリアを構築できます。仙台を拠点にフルリモートで全国から参加するエンジニアと協業する柔軟な働き方が可能です。LLMの実用化に関する実践的な経験を積めるため、AI時代のソフトウェアエンジニアとしてのスキルが磨かれます。弁護士や法務担当者との直接の対話から、法律ドメインの深い知識も身につきます。',
  'AI契約書レビューの品質は法的リスクに直結するため、誤検知・見逃しの許容度が極めて低いシステム設計が求められます。LLMのハルシネーション対策や、法改正への迅速な対応も重要なテーマです。契約書は機密情報の塊であるため、データセキュリティと顧客データの分離設計にも高い専門性が必要です。また、法律用語の正確な理解と、それをシステムのロジックに落とし込む翻訳力も鍛えられます。',
  'エンジニアチーム6名で、バックエンド3名・フロントエンド2名・MLエンジニア1名の構成です。弁護士資格を持つプロダクトマネージャーと密に連携しています。',
  'LLMを活用したプロダクト開発スキル、自然言語処理の実装力、セキュアなシステム設計の知見、リーガルドメインの知識が身につきます。',
  '[]'::jsonb,
  '["Go","Python","PostgreSQL","LLM","自然言語処理","リーガルテック","API設計"]'::jsonb,
  'バックエンド開発経験3年以上（Go / Python等）。RDBMSを用いた開発の実務経験。',
  'LLM / 自然言語処理を活用したプロダクト開発経験。セキュリティを重視したシステム設計の経験。法律業界向けのシステム開発経験。MLパイプラインの構築経験。',
  '宮城県仙台市（フルリモート勤務可）',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  'フレックスタイム制（コアタイムなし）標準労働時間8時間',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇',
  550, 950,
  '月給46万円〜79万円（固定残業代45時間分を含む）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙（喫煙専用室あり）',
  E'フルリモート手当月3万円\n書籍購入費全額補助\nカンファレンス参加費補助\n副業OK',
  'フルリモート',
  '書類選考 → 技術面接（システム設計課題含む） → 最終面接 → 内定',
  now()
) ON CONFLICT DO NOTHING;

-- 14-2: デザイナー
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
  required_qualifications, preferred_qualifications,
  work_location, work_location_change_scope, job_description_change_scope,
  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd0140000-0000-0000-0000-000000000002',
  'b0000000-0000-0000-0000-000000000014',
  'c0014000-0000-0000-0000-000000000002',
  'b1000000-0000-0000-0000-000000000014',
  'open',
  'プロダクトデザイナー｜法律の複雑さをシンプルなUIに変換する',
  'デザイナー',
  '正社員',
  '1名',
  'AI契約書レビューサービスのUI/UXデザインを担当していただきます。契約書のリスク箇所のハイライト表示、AIによる修正提案のインタラクション設計、契約書テンプレートのエディター画面、電子署名フローのUX設計、法務部向けのダッシュボードデザインなどが主な業務です。法律文書という複雑な情報を、弁護士から法務初心者まで幅広いユーザーが迷わず使えるUIに変換するデザインチャレンジです。ユーザーリサーチとして法律事務所や企業法務部への訪問も定期的に行い、現場の課題を深く理解した上でデザインに反映します。',
  'リーガルテックのデザインは「複雑な情報をシンプルに伝える」という情報デザインの本質的なスキルが問われる分野です。AI機能のUIデザインは業界的にもまだベストプラクティスが確立されておらず、自ら新しいパターンを生み出すクリエイティブな挑戦ができます。法律業界のDXに貢献するプロダクトのデザインを通じて、社会的なインパクトを感じられるポジションです。フルリモートで全国どこからでも参加できる働き方も魅力です。',
  '法律文書のUIデザインでは、一文字の違いが法的意味を変えることがあるため、情報の正確な表示が絶対条件です。AIの判定結果をユーザーが適切に理解し、判断できるUI（AIの信頼度表示、根拠の提示など）の設計は技術的にも UX的にも高いスキルが求められます。弁護士と法務初心者では求める情報の粒度が異なるため、ユーザーセグメントに応じた表示の最適化も重要です。',
  'デザイナー第一号の採用で、弁護士資格を持つPMとエンジニアチームと密に連携しながら、プロダクト全体のデザインを主導するポジションです。',
  '情報デザインのスキル、AIプロダクトのUXデザイン力、リーガルドメインの知識、ユーザーリサーチの企画・実施力が身につきます。',
  '[]'::jsonb,
  '["UIデザイン","UXリサーチ","Figma","情報設計","リーガルテック","AIプロダクト"]'::jsonb,
  'WebサービスのUI/UXデザイン経験3年以上。Figmaでのデザイン実務経験。複雑な情報を扱うUIのデザイン経験。',
  'BtoB SaaSのデザイン経験。AIプロダクトのUIデザイン経験。ユーザーリサーチの企画・実施経験。情報設計（IA）の知識。',
  '宮城県仙台市（フルリモート勤務可）',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  'フレックスタイム制（コアタイムなし）標準労働時間8時間',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇',
  450, 750,
  '月給38万円〜63万円（固定残業代45時間分を含む）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙（喫煙専用室あり）',
  E'フルリモート手当月3万円\n書籍購入費全額補助\nカンファレンス参加費補助\n副業OK',
  'フルリモート',
  '書類選考 → ポートフォリオレビュー → デザイン課題 → 最終面接 → 内定',
  now()
) ON CONFLICT DO NOTHING;

-- 14-3: カスタマーサクセス
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
  required_qualifications, preferred_qualifications,
  work_location, work_location_change_scope, job_description_change_scope,
  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd0140000-0000-0000-0000-000000000003',
  'b0000000-0000-0000-0000-000000000014',
  'c0014000-0000-0000-0000-000000000003',
  'b1000000-0000-0000-0000-000000000014',
  'open',
  'カスタマーサクセス｜法律事務所と企業法務のDXを伴走支援',
  'カスタマーサクセス',
  '正社員',
  '1名',
  'AI契約書レビューサービスの導入企業に対するカスタマーサクセスを担当していただきます。法律事務所や企業の法務部門へのオンボーディング支援、契約書テンプレートの初期設定サポート、AIレビュー精度のカスタマイズ提案、利用データに基づく活用促進施策の実行、月次のビジネスレビューの実施などが主な業務です。法律業界はデジタルツールの導入に慎重な傾向があるため、丁寧な説明と段階的な導入プランの提案が重要です。顧客の声をプロダクトチームにフィードバックし、サービスの改善に貢献する役割も担います。',
  'リーガルテック市場の成長とともに、カスタマーサクセスとしてのキャリアを築けるポジションです。法律事務所のパートナー弁護士や大企業の法務部長クラスと直接対話する機会が多く、ビジネスパーソンとして大きく成長できます。法律とテクノロジーの両方のドメイン知識を習得できるため、市場価値の高い人材になれます。カスタマーサクセスの仕組みをゼロから構築するフェーズであり、自分のアイデアを直接形にできるやりがいがあります。',
  '法律業界のクライアントは正確性と機密性への要求が非常に高いため、信頼関係の構築に時間がかかる場合があります。AIの判定結果に対する法律専門家からのフィードバックを正確に理解し、プロダクトチームに伝える「翻訳力」が求められます。また、契約書の種類や業種によって最適な活用方法が異なるため、幅広いケースに対応する応用力も必要です。',
  'ビジネスチーム4名で、セールス2名・カスタマーサクセス2名の構成です。弁護士資格を持つメンバーが在籍しており、法律的な質問にすぐ回答できる体制です。',
  'リーガルテックのカスタマーサクセススキル、法律業界のビジネス知識、AIプロダクトの活用支援スキル、ハイタッチ型のカスタマーサクセス設計力が身につきます。',
  '[]'::jsonb,
  '["カスタマーサクセス","リーガルテック","法務","SaaS","オンボーディング","AI"]'::jsonb,
  'カスタマーサクセスまたはコンサルティングの実務経験2年以上。法人顧客への対応経験。',
  '法律事務所または企業法務部門との業務経験。SaaSプロダクトのカスタマーサクセス経験。AIプロダクトの活用支援経験。法律の基礎知識。',
  '宮城県仙台市（フルリモート勤務可）',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  'フレックスタイム制（コアタイムなし）標準労働時間8時間',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇',
  400, 700,
  '月給33万円〜58万円（固定残業代45時間分を含む）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙（喫煙専用室あり）',
  E'フルリモート手当月3万円\n書籍購入費全額補助\n資格取得費補助\n副業OK',
  'フルリモート',
  '書類選考 → 一次面接 → 最終面接 → 内定',
  now()
) ON CONFLICT DO NOTHING;

-- 14-4: セールス
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
  content_blocks, tags,
  required_qualifications, preferred_qualifications,
  work_location, work_location_change_scope, job_description_change_scope,
  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd0140000-0000-0000-0000-000000000004',
  'b0000000-0000-0000-0000-000000000014',
  'c0014000-0000-0000-0000-000000000003',
  'b1000000-0000-0000-0000-000000000014',
  'open',
  'セールス｜AI×リーガルテックで法務DXの新市場を開拓',
  'セールス',
  '正社員',
  '1名',
  'AI契約書レビューサービスの法人営業を担当していただきます。法律事務所、企業の法務部門、スタートアップに対して、契約書レビューの効率化とリスク低減を提案する営業活動を行います。初回商談でのデモンストレーションからクロージング、導入後のフォローアップまでを一貫して担当します。セミナー・ウェビナーの企画・登壇を通じたリード獲得、法律系カンファレンスへの出展、弁護士会との連携による認知拡大など、マーケティングと連動した営業活動も推進します。契約書レビューの工数削減や見落としリスクの低減を定量的に示すROI提案が鍵となるポジションです。',
  'リーガルテック市場は日本ではまだ黎明期であり、市場を創っていく面白さがあります。AIの進化により契約書レビューの自動化ニーズは急速に高まっており、追い風の中で営業活動ができます。法律事務所のパートナー弁護士や上場企業の法務部長といったハイレベルなクライアントとの商談を通じて、プレゼンテーション力と提案力を大きく伸ばせます。仙台を拠点にフルリモートで働ける柔軟性も魅力です。',
  '法律業界は保守的な面があり、AIへの信頼を獲得するまでの長いセールスサイクルに対する忍耐力が求められます。法律の専門知識がある程度必要であり、入社後に法律の基礎を学ぶ意欲が不可欠です。また、弁護士や法務担当者は論理的で厳密なコミュニケーションを好むため、提案内容の正確さと論理性が特に重視されます。',
  'ビジネスチーム4名で、セールスとカスタマーサクセスが密に連携しています。弁護士メンバーが商談に同席してくれる体制もあり、法律的なサポートは手厚い環境です。',
  'リーガルテック業界のセールスノウハウ、AIプロダクトの提案営業スキル、法律業界のビジネス知識、ハイタッチセールスの実践力が身につきます。',
  '[]'::jsonb,
  '["法人営業","リーガルテック","AI","SaaS","新規開拓","コンサルティング営業"]'::jsonb,
  '法人向け営業経験3年以上。SaaSまたはIT業界での営業経験。',
  '法律事務所または企業法務部門への営業経験。AIプロダクトの営業経験。セミナー・ウェビナーの企画・登壇経験。長期セールスサイクルの案件管理経験。',
  '宮城県仙台市（フルリモート勤務可）',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  'フレックスタイム制（コアタイムなし）標準労働時間8時間',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇',
  450, 850,
  '月給38万円〜71万円（固定残業代45時間分を含む）。インセンティブ制度あり。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙（喫煙専用室あり）',
  E'フルリモート手当月3万円\n書籍購入費全額補助\n資格取得費補助\n副業OK',
  'フルリモート',
  '書類選考 → 一次面接 → 最終面接 → 内定',
  now()
) ON CONFLICT DO NOTHING;


