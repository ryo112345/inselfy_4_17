  contract_type, probation_period, work_hours, break_time, holidays,
  salary_min, salary_max, salary_detail, insurance, smoking_policy,
  benefits, remote_policy, selection_process, published_at
) VALUES (
  'd00b0000-0000-0000-0000-000000000001',
  'b0000000-0000-0000-0000-00000000000b',
  'c000b000-0000-0000-0000-000000000001',
  'b1000000-0000-0000-0000-00000000000b',
  'open',
  'バックエンドエンジニア｜毎秒数千件のEC決済を支えるAPI基盤を設計',
  'エンジニア',
  '正社員',
  '1〜2名',
  'コマースクラフトが運営するマルチテナント型ECプラットフォームのバックエンドAPI開発をリードしていただきます。商品検索、在庫管理、決済処理、配送連携など、ECに不可欠な機能群をマイクロサービスアーキテクチャで構築しています。特にブラックフライデーやセール期間中のトラフィックスパイクに耐えうるスケーラブルなシステム設計が求められるポジションです。リアルタイム在庫同期やレコメンデーションエンジンとの連携など、データ量の多い処理を高速に捌く技術力を発揮していただけます。',
  '年間流通額100億円規模のECプラットフォームを少人数精鋭チームで開発しています。技術選定からアーキテクチャ設計まで裁量が大きく、エンジニア主導でプロダクトの技術基盤を進化させられる環境です。パフォーマンスチューニングやキャッシュ戦略など、大規模トラフィックならではの技術課題に日常的に取り組めます。Go言語とKubernetesを中心としたモダンな技術スタックを採用しており、技術的負債の返済にもチームとして積極的に投資しています。',
  'マルチテナント環境でのデータ分離と共有のバランス設計が大きなチャレンジです。また、決済・在庫という失敗が許されない領域でのトランザクション設計には高い正確性が要求されます。EC特有のドメイン知識を身につけながら、システムの信頼性とスケーラビリティを両立させる技術的判断を日々求められる環境です。外部APIとの連携も多く、障害対応やリトライ戦略の設計など実践的なスキルが鍛えられます。',
  'バックエンドチーム6名で構成され、全員がGoでの開発経験を持っています。週次の技術共有会とペアプログラミングを推奨するカルチャーです。',
  'Go言語での大規模API設計スキル、マイクロサービスアーキテクチャの設計・運用経験、決済システムのドメイン知識、Kubernetesの運用スキルが身につきます。',
  '[]'::jsonb,
  '["Go","Kubernetes","PostgreSQL","Redis","マイクロサービス","EC","決済"]'::jsonb,
  'Go言語でのWebアプリケーション開発経験3年以上。RDBMSを用いたバックエンド開発の実務経験。',
  'ECサイトやマーケットプレイスの開発経験。Kubernetesの運用経験。決済システムの開発経験。パフォーマンスチューニングの実務経験。',
  '神奈川県横浜市（リモート併用可）',
  '当面なし',
  '当面なし',
  '無期',
  '入社後3ヶ月（条件変更なし）',
  'フレックスタイム制（コアタイム11:00〜15:00）標準労働時間8時間',
  '60分',
  '完全週休2日制（土日祝）、年末年始休暇、有給休暇（入社半年後10日付与）、慶弔休暇、産前産後休暇、育児休暇',
  550, 950,
  '月給46万円〜79万円（固定残業代40時間分を含む）。経験・能力を考慮の上決定。',
  '健康保険、厚生年金、雇用保険、労災保険',
  '屋内原則禁煙（喫煙専用室あり）',
  E'リモートワーク手当月2万円\n書籍購入費補助（年5万円）\n社員割引制度\n副業OK',
  'リモート併用（週2日出社）',
  '書類選考 → 技術面接（コーディングテスト含む） → 最終面接 → 内定',
  now()
) ON CONFLICT DO NOTHING;

-- 0b-2: データアナリスト
INSERT INTO job_postings (
  id, company_id, team_id, created_by, status, title, job_category, employment_type, hiring_count,
  description, appeal_points, challenges, team_description, skills_gained,
