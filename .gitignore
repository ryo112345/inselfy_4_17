.env
.env.*

# ルートの node_modules（lefthook 用。frontend は frontend/.gitignore 側）
node_modules/

# Uploaded files (runtime data, not source code)
backend/uploads/
backend/private-uploads/
!.env.example

# Test coverage profile (make test-cover / CI)
backend/coverage.out

# Terraform の生成物（provider バイナリは 100MB 超・state は秘匿情報）。
# infra/.gitignore にも同じ除外があるが、infra/ 追加前の古いブランチに checkout すると
# infra/.gitignore ごとディスクから消えて無防備になるため、ルートにも保険として置く
.terraform/
*.tfstate
*.tfstate.*
